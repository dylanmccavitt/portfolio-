---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/sera/PageHeader.astro';
import ProjectCard from '../../components/sera/ProjectCard.astro';
import Pager from '../../components/sera/Pager.astro';
import { PROJECTS } from '../../data/projects';
---

<Base
  title="Projects — Dylan McCavitt"
  description="Selected work from Dylan McCavitt."
>
  <main class="projects-page">
    <PageHeader
      kicker="02 / projects"
      title="Selected work"
      sub="A short list. Happy to walk through any of these."
    />

    <section class="projects-page__grid" aria-label="Selected projects">
      {
        PROJECTS.map((project) => (
          <ProjectCard
            slug={project.slug}
            name={project.name}
            kind={project.kind}
            blurb={project.blurb}
            coverSrc={project.cover.src}
            coverAlt={project.cover.alt}
          />
        ))
      }
    </section>

    <div class="projects-page__pager">
      <Pager
        prev={{ href: '/about', label: 'about' }}
        next={{ href: '/experience', label: 'experience' }}
      />
    </div>
  </main>
</Base>

<style>
  .projects-page {
    max-width: 64rem;
    margin: 0 auto;
    padding: 64px 24px;
  }

  .projects-page__grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 40px 24px;
  }

  .projects-page__pager {
    margin-top: 64px;
  }

  @media (max-width: 760px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
