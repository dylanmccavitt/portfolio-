---
/**
 * Project detail view — one static page per catalog project, ported from the
 * prototype `renderProject()` (`15-player-v4.html` lines 823-867). Static,
 * zero client JS; the scroll rail is pure CSS. The big-play button renders a
 * stable DOM contract (`data-play` / `data-project`) for #24 — no behavior.
 *
 * Routing: this `[id]` route coexists with the legacy `[slug].astro` markdown
 * route in the same dir. Astro resolves the higher-priority `[id]` route for
 * overlapping paths (homeserver, bellas-beads, nhf, work-orders) and still
 * serves non-overlapping legacy slugs (epl-ml-model). The build does not error
 * — it emits an informational WARN for the superseded legacy paths.
 */
import PlayerLayout from '../../layouts/Player.astro';
import ProjectArt from '../../components/player/ProjectArt.astro';
import StatusBadge from '../../components/player/StatusBadge.astro';
import ShotsRail from '../../components/player/ShotsRail.astro';
import CreditsList from '../../components/player/CreditsList.astro';
import AlbumCard from '../../components/player/AlbumCard.astro';
import { CATALOG, getProjectById, type Project } from '../../data/catalog';

export function getStaticPaths() {
  return CATALOG.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}
const { project } = Astro.props as Props;

// Fallback for direct prop typing; getStaticPaths always supplies `project`.
const p = project ?? getProjectById(Astro.params.id as string)!;

const related = CATALOG.filter((o) => o.area === p.area && o.id !== p.id).slice(0, 5);
---

<PlayerLayout
  title={`${p.title} — Dylan McCavitt`}
  description={p.line}
  active={p.area}
  now={p}
>
  <div class="view">
    <div class="head">
      <a class="back" href="/">Library</a>
      <div class="hero">
        <ProjectArt sym={p.sym} hue={p.hue} size="lg" />
        <div class="info">
          <span class="kind">{p.area} · {p.year}</span>
          <h1>{p.title}</h1>
          <p>{p.line}</p>
          <div class="meta">
            <StatusBadge status={p.status} />
            <span><b>{p.activity}</b></span>
          </div>
        </div>
      </div>
    </div>

    <div class="actions">
      <button
        class="bigplay"
        type="button"
        title="play"
        aria-label={`Play ${p.title}`}
        data-play
        data-project={p.id}
      ></button>
      {
        p.links.map(([label, url]) => (
          <a class="act-link" href={url} target="_blank" rel="noopener">
            {label}
          </a>
        ))
      }
    </div>

    {
      p.metrics.length > 0 && (
        <div class="stats">
          {p.metrics.map(([value, label]) => (
            <div class="stat">
              <b>{value}</b>
              <span>{label}</span>
            </div>
          ))}
        </div>
      )
    }

    <ShotsRail shots={p.shots} hue={p.hue} />

    <div class="pbody">
      <div>
        <h3>About</h3>
        {p.about.map((para) => <p>{para}</p>)}
        <h3>Liner notes</h3>
        <ul class="notes">
          {p.notes.map((note) => <li>{note}</li>)}
        </ul>
      </div>
      <div>
        <h3>Credits</h3>
        <CreditsList rows={p.stack} />
      </div>
    </div>

    {
      related.length > 0 && (
        <div class="more">
          <h3>More from {p.area}</h3>
          <div class="albums">
            {related.map((r) => (
              <AlbumCard project={r} />
            ))}
          </div>
        </div>
      )
    }
  </div>
</PlayerLayout>

<style>
  /* ---- hero (shared shape with the shell demo page; `.art`/`.badge`
     primitives come from player.css) ---- */
  .hero {
    display: flex;
    gap: 24px;
    align-items: flex-end;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--pl-dim);
    font-size: 13px;
    margin-bottom: 18px;
  }
  .back:hover {
    color: var(--pl-text);
  }
  .back::before {
    content: '←';
    font-size: 15px;
  }
  .kind {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-dim);
  }
  h1 {
    font-size: clamp(26px, 4.2vw, 44px);
    font-weight: 800;
    letter-spacing: -1.5px;
    margin: 6px 0 8px;
  }
  .hero p {
    color: var(--pl-dim);
    max-width: 58ch;
    font-size: 13.5px;
  }
  .meta {
    margin-top: 12px;
    font-size: 12.5px;
    color: var(--pl-faint);
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .meta b {
    color: var(--pl-text);
    font-weight: 500;
  }

  /* ---- action row ---- */
  .actions {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 30px 6px;
  }
  .bigplay {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--pl-green);
    display: grid;
    place-items: center;
    transition: transform 0.12s, filter 0.12s;
    flex-shrink: 0;
  }
  .bigplay:hover {
    transform: scale(1.05);
    filter: brightness(1.08);
  }
  .bigplay::after {
    content: '';
    width: 0;
    height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 13px solid #0e1410;
    margin-left: 4px;
  }
  .act-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--pl-dim);
    border: 1px solid var(--pl-line);
    padding: 8px 16px;
    border-radius: 99px;
    white-space: nowrap;
  }
  .act-link:hover {
    color: var(--pl-text);
    border-color: var(--pl-faint);
  }

  /* ---- metric stat tiles ---- */
  .stats {
    display: flex;
    gap: 10px;
    padding: 18px 30px 0;
    flex-wrap: wrap;
  }
  .stat {
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 10px;
    padding: 12px 18px;
    min-width: 130px;
  }
  .stat b {
    font-family: var(--pl-mono);
    font-size: 17px;
    font-weight: 500;
    display: block;
  }
  .stat span {
    font-size: 11px;
    color: var(--pl-faint);
  }

  /* ---- about / liner notes / credits columns ---- */
  .pbody {
    padding: 8px 30px 36px;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 36px;
  }
  @media (max-width: 820px) {
    .pbody {
      grid-template-columns: 1fr;
    }
  }
  .pbody h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 18px 0 8px;
  }
  .pbody p {
    color: var(--pl-dim);
    font-size: 13.5px;
  }
  .pbody p + p {
    margin-top: 9px;
  }
  .notes {
    list-style: disc;
  }
  .notes li {
    color: var(--pl-dim);
    font-size: 13px;
    margin: 7px 0 0 16px;
  }
  .notes li::marker {
    color: var(--pl-green);
  }

  /* ---- "More from {area}" related rail ---- */
  .more {
    padding: 0 30px 40px;
  }
  .more h3 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .albums {
    display: flex;
    gap: 14px;
    overflow-x: auto;
  }
</style>
