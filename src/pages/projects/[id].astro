---
/**
 * Project detail view — one static page per catalog project, rebuilt as a
 * centered **Editorial** case study (#87): a minimal monogram/back bar, a large
 * recruiter-readable hero, a full-width lead screenshot, a comfortable reading
 * column (About / Metrics / Highlights / Details), a responsive screenshot
 * gallery with a zero-JS `:target` lightbox, and a "More projects" row built
 * from the canonical Typographic card language (#85).
 *
 * Static-first: the gallery lightbox is pure CSS `:target`, and the only client
 * island is the deliberate contextual DM popup. Routes and SEO are preserved —
 * one prerendered page per `CATALOG` entry, meta via `projectMeta(p)`. Tokens,
 * the two web fonts, and the global `.badge.<kind>` classes come from
 * `player.css` (imported by the Editorial layout).
 */
import Editorial from '@/layouts/Editorial.astro';
import ProjectCardGrid from '@/components/ProjectCardGrid.astro';
import {
  isImageShot,
  type ProjectShot,
} from '@/data/catalog';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';
import { publicProjectStaticPaths } from '@/lib/public-project-route-resolver';
import { loadPublicProjectDetails } from '@/lib/public-projects';
import { projectMeta } from '@/lib/seo';
import { AGENT_NAME } from '@/lib/dm/client';
import '@/styles/dm.css';

export async function getStaticPaths() {
  const { projects } = await loadPublicProjectDetails();
  return publicProjectStaticPaths(projects);
}

interface Props {
  project: ProjectDetailReadModel;
  projects: ProjectDetailReadModel[];
}
const { project, projects } = Astro.props as Props;

const p = project;
const related = projects.filter((o) => o.area === p.area && o.id !== p.id).slice(0, 5);
const meta = projectMeta(p);
const agentDialogId = `project-agent-${p.id}`;
const agentTitleId = `${agentDialogId}-title`;
const agentDescriptionId = `${agentDialogId}-description`;
const defaultProjectPrompt = `Tell me about ${p.title} and what Dylan did.`;

const isPhone = (shot: ProjectShot): boolean =>
  isImageShot(shot) ? shot.phone === true : shot.kind === 'phone';

/** Explicit intrinsic dimensions so images reserve layout (zero CLS). */
const DIMS = { wide: { w: 1200, h: 800 }, phone: { w: 360, h: 640 } } as const;

/** Plain-language label for a skeleton placeholder kind. */
const SKEL_LABEL: Record<string, string> = {
  chart: 'Chart',
  dash: 'Dashboard',
  list: 'List',
  code: 'Code',
  phone: 'Mobile',
};

const lead = p.shots[0];
const gallery = p.shots.slice(1);
---

<Editorial title={meta.title} meta={meta}>
  <article class="editorial" style={`--accent:${p.hue}`}>
    <header class="topbar">
      <span class="mono" aria-hidden="true">DM</span>
      <a class="ed-back" href="/library">← Back to projects</a>
    </header>

    <div class="wrap">
      <section class="ed-hero">
        <p class="eyebrow">{p.area} · {p.year}</p>
        <h1 class="title">{p.title}</h1>
        <p class="lead-line">{p.line}</p>
        <div class="hero-meta">
          <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
          <span class="activity">{p.activity}</span>
        </div>
        {
          p.links.length > 0 && (
            <div class="cta">
              {p.links.map(([label, url], i) => (
                <a
                  class:list={['btn', i === 0 ? 'btn-fill' : 'btn-out']}
                  href={url}
                  target="_blank"
                  rel="noopener"
                >
                  {label}
                </a>
              ))}
            </div>
          )
        }

        <div class="project-agent" data-dm-root data-dm-project-id={p.id}>
          <button
            class="project-agent-trigger"
            type="button"
            data-dm-open
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls={agentDialogId}
          >
            <span>Ask DM about this</span>
            <small>Answers in place</small>
          </button>

          <div class="dm-popup" data-dm-dialog hidden>
            <section
              class="dm-popup-panel"
              data-dm-panel
              id={agentDialogId}
              role="dialog"
              aria-modal="true"
              aria-labelledby={agentTitleId}
              aria-describedby={agentDescriptionId}
              tabindex="-1"
            >
              <header class="dm-popup-head">
                <div>
                  <p class="dm-label">DM project guide</p>
                  <h2 id={agentTitleId}>Ask DM about {p.title}</h2>
                </div>
                <button class="dm-popup-close" type="button" data-dm-close>
                  <span aria-hidden="true">×</span>
                  <span class="dm-sr-only">Close DM project guide</span>
                </button>
              </header>

              <div class="dm-main dm-main--popup">
                <p id={agentDescriptionId} class="dm-sr-only">
                  Chat with {AGENT_NAME} about this project without leaving the page.
                </p>
                <div class="dm-stage">
                  <div class="dm-empty">
                    <div class="dm-card">
                      <span class="dm-card-tile" aria-hidden="true">✦</span>
                      <h3 class="dm-greeting">Ask DM about this project.</h3>
                      <p class="dm-subgreeting">
                        {AGENT_NAME} will use {p.title} as the active project context.
                      </p>
                      <ul class="dm-suggest project-agent-suggest">
                        <li>
                          <button
                            class="dm-suggest-row"
                            type="button"
                            data-dm-send
                            data-label={defaultProjectPrompt}
                          >
                            <span class="dm-suggest-label">Start with the project overview</span>
                            <span class="dm-suggest-hint">context.projectIds: {p.id}</span>
                          </button>
                        </li>
                      </ul>
                    </div>
                  </div>

                  <div
                    class="dm-thread"
                    data-dm-thread
                    role="log"
                    aria-label={`${AGENT_NAME} conversation about ${p.title}`}
                  ></div>
                </div>

                <form class="dm-composer" data-dm-form>
                  <div class="dm-composer-inner">
                    <span class="dm-composer-glyph" aria-hidden="true">⌁</span>
                    <input
                      class="dm-input"
                      data-dm-input
                      type="text"
                      name="message"
                      autocomplete="off"
                      spellcheck="false"
                      placeholder={`Ask about ${p.title}…`}
                      aria-label={`Ask ${AGENT_NAME} about ${p.title}`}
                    />
                    <button class="dm-send" type="submit" data-dm-submit aria-label="Send message">
                      →
                    </button>
                  </div>
                </form>
              </div>
            </section>
          </div>
        </div>
      </section>

      {
        lead && (
          <figure class:list={['lead', { phone: isPhone(lead) }]}>
            {isImageShot(lead) ? (
              <a class="frame" href="#shot-0" aria-label={`Expand screenshot: ${lead.cap}`}>
                <img
                  src={lead.img}
                  alt={lead.cap}
                  width={(isPhone(lead) ? DIMS.phone : DIMS.wide).w}
                  height={(isPhone(lead) ? DIMS.phone : DIMS.wide).h}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ) : (
              <div
                class:list={['frame', 'skel', { phone: isPhone(lead) }]}
                data-kind={lead.kind}
                style={`--tint:${p.hue}`}
              >
                <span class="skel-kind">{SKEL_LABEL[lead.kind] ?? lead.kind}</span>
              </div>
            )}
            <figcaption>{lead.cap}</figcaption>
          </figure>
        )
      }

      <div class="read">
        {
          p.about.length > 0 && (
            <section class="block">
              <h2 class="h">About</h2>
              {p.about.map((para) => (
                <p class="para">{para}</p>
              ))}
            </section>
          )
        }

        {
          p.metrics.length > 0 && (
            <section class="metrics" aria-label="Metrics">
              {p.metrics.map(([value, label]) => (
                <div class="metric">
                  <b class="metric-v">{value}</b>
                  <span class="metric-l">{label}</span>
                </div>
              ))}
            </section>
          )
        }

        {
          p.notes.length > 0 && (
            <section class="block">
              <h2 class="h">Highlights</h2>
              <ul class="highlights">
                {p.notes.map((note) => (
                  <li>{note}</li>
                ))}
              </ul>
            </section>
          )
        }

        {
          p.stack.length > 0 && (
            <section class="block">
              <h2 class="h">Details</h2>
              <dl class="details">
                {p.stack.map(([label, value]) => (
                  <div class="detail-row">
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>
            </section>
          )
        }
      </div>

      {
        gallery.length > 0 && (
          <section class="gallery-wrap">
            <h2 class="h">Screenshots</h2>
            <div class="gallery">
              {gallery.map((shot, idx) => {
                const i = idx + 1;
                const phone = isPhone(shot);
                const dims = phone ? DIMS.phone : DIMS.wide;
                return (
                  <figure class:list={['shot', { phone }]}>
                    {isImageShot(shot) ? (
                      <a
                        class="frame"
                        href={`#shot-${i}`}
                        aria-label={`Expand screenshot: ${shot.cap}`}
                      >
                        <img
                          src={shot.img}
                          alt={shot.cap}
                          width={dims.w}
                          height={dims.h}
                          loading="lazy"
                          decoding="async"
                        />
                      </a>
                    ) : (
                      <div
                        class:list={['frame', 'skel', { phone }]}
                        data-kind={shot.kind}
                        style={`--tint:${p.hue}`}
                      >
                        <span class="skel-kind">{SKEL_LABEL[shot.kind] ?? shot.kind}</span>
                      </div>
                    )}
                    <figcaption>{shot.cap}</figcaption>
                  </figure>
                );
              })}
            </div>
          </section>
        )
      }

      {
        related.length > 0 && (
          <section class="ed-more">
            <h2 class="h">More projects</h2>
            <ProjectCardGrid projects={related} />
          </section>
        )
      }
    </div>

    {/* Zero-JS lightbox: each real screenshot links to `#shot-N`; `:target`
        reveals the matching fixed overlay; the overlay itself is the close link. */}
    {
      p.shots.map(
        (shot, i) =>
          isImageShot(shot) && (
            <a class="lightbox" id={`shot-${i}`} href="#!" aria-label={`Close expanded screenshot: ${shot.cap}`}>
              <img src={shot.img} alt={shot.cap} loading="lazy" decoding="async" />
              <span class="lb-cap">{shot.cap}</span>
            </a>
          ),
      )
    }
  </article>
  <script src="../../scripts/dm.ts"></script>
</Editorial>

<style>
  .editorial {
    --accent: var(--pl-accent);
    --measure: 68ch;
    --wide: 920px;
    min-height: 100dvh;
    color: var(--pl-text);
    font-family: var(--pl-sans);
  }

  /* ---- sticky top bar ---- */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 13px clamp(18px, 5vw, 40px);
    border-bottom: 1px solid var(--pl-line);
    background: color-mix(in srgb, var(--pl-bg) 84%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .topbar .mono {
    font-family: var(--pl-mono);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 38%, var(--pl-line));
    border-radius: 7px;
    padding: 4px 8px;
    line-height: 1;
  }
  .topbar .ed-back {
    font-size: 13px;
    color: var(--pl-dim);
    transition: color 0.15s ease;
  }
  .topbar .ed-back:hover {
    color: var(--pl-text);
  }

  /* ---- centered measure ---- */
  .wrap {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 0 clamp(18px, 5vw, 40px) clamp(64px, 12vw, 110px);
  }

  /* ---- hero ---- */
  .ed-hero {
    max-width: var(--measure);
    margin: 0 auto;
    text-align: center;
    padding: clamp(44px, 9vw, 96px) 0 clamp(26px, 4vw, 40px);
  }
  .eyebrow {
    font-family: var(--pl-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .title {
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .lead-line {
    margin: 18px auto 0;
    max-width: 46ch;
    font-size: clamp(16px, 2.4vw, 20px);
    line-height: 1.5;
    color: var(--pl-dim);
  }
  .hero-meta {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }
  .hero-meta .activity {
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-faint);
  }
  .cta {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .btn {
    font-size: 13px;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 99px;
    border: 1px solid transparent;
    transition:
      filter 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease,
      background 0.15s ease;
  }
  .btn-fill {
    background: var(--accent);
    color: #0c0e13;
  }
  .btn-fill:hover {
    filter: brightness(1.08);
  }
  .btn-out {
    background: var(--pl-tile);
    color: var(--pl-text);
    border-color: var(--pl-line);
  }
  .btn-out:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--pl-line));
    color: #fff;
  }

  /* ---- lead screenshot ---- */
  .lead {
    margin: clamp(6px, 1.5vw, 14px) auto 0;
  }
  .lead.phone {
    max-width: 360px;
  }
  .lead figcaption {
    margin-top: 12px;
    text-align: center;
    font-size: 12.5px;
    color: var(--pl-faint);
  }

  /* shared framed surface for images + skeletons */
  .frame {
    display: block;
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--pl-panel);
    box-shadow: 0 30px 60px -34px rgba(0, 0, 0, 0.7);
  }
  a.frame {
    cursor: zoom-in;
  }
  .frame img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* skeleton placeholder */
  .skel {
    aspect-ratio: 3 / 2;
    display: grid;
    place-items: center;
    background:
      radial-gradient(
        130% 120% at 50% 0%,
        color-mix(in srgb, var(--tint) 20%, transparent),
        transparent 62%
      ),
      var(--pl-tile);
  }
  .skel.phone {
    aspect-ratio: 9 / 16;
  }
  .skel-kind {
    font-family: var(--pl-mono);
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tint) 72%, var(--pl-text));
    border: 1px solid color-mix(in srgb, var(--tint) 32%, var(--pl-line));
    border-radius: 8px;
    padding: 8px 14px;
    background: color-mix(in srgb, var(--tint) 8%, transparent);
  }

  /* ---- reading column ---- */
  .read {
    max-width: var(--measure);
    margin: clamp(40px, 7vw, 72px) auto 0;
    display: flex;
    flex-direction: column;
    gap: clamp(34px, 5vw, 52px);
  }
  .h {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--pl-faint);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--pl-line);
  }
  .para {
    font-size: 15.5px;
    line-height: 1.78;
    color: var(--pl-text);
  }
  .para + .para {
    margin-top: 16px;
  }

  /* metrics strip */
  .metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .metric {
    flex: 1 1 140px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 12px;
    padding: 16px 18px;
  }
  .metric-v {
    display: block;
    font-family: var(--pl-mono);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.1;
    color: var(--accent);
  }
  .metric-l {
    display: block;
    margin-top: 7px;
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--pl-faint);
  }

  /* highlights */
  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .highlights li {
    position: relative;
    padding-left: 26px;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--pl-dim);
  }
  .highlights li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
  }

  /* details key/value grid */
  .details {
    display: grid;
    grid-template-columns: max-content 1fr;
    border-top: 1px solid var(--pl-line);
  }
  .detail-row {
    display: contents;
  }
  .detail-row dt {
    padding: 12px 24px 12px 0;
    font-size: 12px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--pl-faint);
    border-bottom: 1px solid var(--pl-line);
  }
  .detail-row dd {
    padding: 12px 0;
    font-family: var(--pl-mono);
    font-size: 13.5px;
    color: var(--pl-text);
    text-align: right;
    border-bottom: 1px solid var(--pl-line);
    word-break: break-word;
  }

  /* ---- gallery ---- */
  .gallery-wrap {
    margin-top: clamp(48px, 8vw, 84px);
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  .shot {
    margin: 0;
  }
  .shot figcaption {
    margin-top: 10px;
    font-size: 12px;
    color: var(--pl-faint);
  }
  .shot.phone .frame {
    max-width: 280px;
    margin: 0 auto;
  }

  /* ---- lightbox (zero JS, :target) ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    place-items: center;
    padding: 4vmin;
    background: rgba(8, 9, 12, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: zoom-out;
  }
  .lightbox:target {
    display: grid;
  }
  .lightbox img {
    max-width: min(1100px, 96vw);
    max-height: 86vh;
    width: auto;
    height: auto;
    border-radius: 12px;
    border: 1px solid var(--pl-line);
    box-shadow: 0 40px 90px -24px rgba(0, 0, 0, 0.75);
  }
  .lb-cap {
    position: absolute;
    bottom: 5vmin;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 12.5px;
    color: var(--pl-faint);
  }

  /* ---- more projects (canonical Typographic cards, #85) ---- */
  .ed-more {
    margin-top: clamp(48px, 8vw, 84px);
  }

  /* ---- mobile: single column ---- */
  @media (max-width: 820px) {
    .gallery {
      grid-template-columns: 1fr;
    }
    .metric {
      flex-basis: 100%;
    }
  }

</style>
