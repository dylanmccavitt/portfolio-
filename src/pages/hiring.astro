---
/**
 * `/hiring` — the "I'm hiring" guided tour (#62). A standalone, stepped tour
 * one beat per screen, Back/Next + dots, opened from the "I'm hiring" route.
 *
 * Nine beats in order:
 *   0  hook / agenda      — name, title, "In this tour" numbered list
 *   1-5 selected work     — one card per featured project (FEATURED_IDS)
 *   6  resume timeline    — the resume timeline (RESUME.tracks)
 *   7  the ask            — resume + contact CTAs (the one resume CTA here)
 *   8  handoff            — "Continue to the full site →" → /library
 *
 * All project/resume copy reads from the gated public project source and
 * `resume.ts` — nothing is duplicated here. Built on the lightweight `Tour`
 * layout.
 * The stepper is progressive enhancement: with JS off, every beat is stacked
 * and scrollable (see the scoped `<style>` and `src/scripts/tour.ts`).
 */
import Tour from '@/layouts/Tour.astro';
import ShotRail from '@/components/ShotRail.astro';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';
import { loadPublicProjectDetails, shouldRenderPublicProjectsLive } from '@/lib/public-projects';
import { resolveRequiredPublicProjectByReference } from '@/lib/public-project-route-resolver';
import { RESUME } from '@/data/resume';
import { libraryMeta, personJsonLd } from '@/lib/seo';

export const prerender = !shouldRenderPublicProjectsLive(process.env);

/**
/** Site convention for the off-site CTAs. */
const RESUME_URL = 'https://dylanmccavitt.xyz/resume.pdf';
const EMAIL_URL = 'mailto:dylanmccavitt@outlook.com';
const GITHUB_URL = 'https://github.com/DylanMcCavitt';

/**
 * The featured project ids, in tour order (beat 2 = these 5 cards). The agenda
 * count below reads `FEATURED_IDS.length` — never a hardcoded "5".
 */
const FEATURED_IDS = [
  'bellas-beads',
  'evalgate',
  'agentic-trader',
  'tradingview-mcp',
  'slurmlet',
] as const;

const { projects: publicProjects, source: publicProjectSource } = await loadPublicProjectDetails();

/**
 * Resolve featured projects from the gated public source. THROW on a missing
 * id/slug match so a drifted featured reference fails the build loudly rather
 * than rendering a silent gap.
 */
const FEATURED: ProjectDetailReadModel[] = FEATURED_IDS.map((id) =>
  resolveRequiredPublicProjectByReference(publicProjects, id, {
    route: 'hiring.astro',
    source: publicProjectSource,
    label: 'featured project id',
  }),
);

// The full career timeline, in chronological order, for the resume beat.
const TRACKS = RESUME.tracks;

/**
 * The agenda's numbered list. Item 01's count is data-driven from the featured
 * set, so adding/removing a featured project keeps the copy honest.
 */
const AGENDA: [label: string, detail: string][] = [
  ['Some of my work', `${FEATURED.length} projects`],
  ['Resume', 'Education & experience'],
  ['Resume & contact', 'The fastest way to reach me'],
];

const meta = {
  ...libraryMeta(
    "I'm hiring · Dylan McCavitt",
    'A 2-minute guided tour: best work, then the resume. Software engineer · Backend · AI.',
  ),
  jsonLd: personJsonLd(),
};
---

<Tour title="I'm hiring · Dylan McCavitt" meta={meta}>
  <main class="tour-main">
    <div class="tbar">
      <a class="tour-back" href="/" title="Back to the concierge">‹ What brings you here?</a>
      <a class="resbtn" href={RESUME_URL} data-tour-resume>Resume ↓</a>
    </div>

    <div class="tour" data-tour>
      {/* Beat 0 — hook / agenda */}
      <section class="step" data-step>
        <div class="card hook">
          <div class="upper kicker">A 2-minute tour · best work + resume</div>
          <h1>Dylan McCavitt</h1>
          <p class="arc">Software engineer · Backend · AI.</p>
          <div class="ag-head upper">In this tour</div>
          <div class="ag-list">
            {
              AGENDA.map(([label, detail], i) => (
                <div class="ag-row">
                  <span class="agn">0{i + 1}</span>
                  <div>
                    <b>{label}</b>
                    <span class="agd">{detail}</span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      {/* Beats 1-5 — selected work, one card per featured project */}
      {
        FEATURED.map((project, i) => {
          // Proof line: no `proof` field exists on Project, so map the first
          // liner note (notes[0]) into the ✓ slot.
          const proof = project.notes[0];
          // Repo link: render every link when present (bella's beads → live
          // site, agentic-trader → repo); empty links → "Source private"
          // (evalgate, slurmlet, tradingview-mcp).
          const links = project.links;
          return (
            <section class="step" data-step>
              <div class="card work">
                <div class="upper kicker">
                  Selected work · {i + 1}/{FEATURED.length}
                </div>
                <div class="wtop">
                  <div>
                    <span class="work-id" style={`--accent:${project.hue}`}>{project.id}</span>
                    <h2>{project.title}</h2>
                    <div class="meta">
                      <span class:list={['badge', project.status[0]]}>{project.status[1]}</span>
                      <span>{project.area}</span>
                    </div>
                  </div>
                </div>
                <div class="wbody">
                  <div class="wcol">
                    <p class="wline">{project.line}</p>
                    {proof && <p class="wproof">{proof}</p>}
                    <details class="wdetail" data-tour-details>
                      <summary>More on this</summary>
                      <div class="wdetail-body">
                        {project.about.map((para) => (
                          <p>{para}</p>
                        ))}
                        <div class="dmetrics">
                          {project.metrics.map(([value, label]) => (
                            <div class="dm">
                              <b>{value}</b>
                              <span>{label}</span>
                            </div>
                          ))}
                        </div>
                        {links.length > 0 ? (
                          <div class="dlinks">
                            {links.map(([label, url]) => (
                              <a class="dlink" href={url}>
                                {label}
                              </a>
                            ))}
                          </div>
                        ) : (
                          <span class="dlink off">Source private</span>
                        )}
                      </div>
                    </details>
                  </div>
                  <div class="wshot">
                    <ShotRail shots={project.shots} hue={project.hue} />
                  </div>
                </div>
              </div>
            </section>
          );
        })
      }

      {/* Beat 6 — resume timeline */}
      <section class="step" data-step>
        <div class="card">
          <div class="upper kicker">Resume timeline</div>
          <div class="arc-list">
            {
              TRACKS.map((track) => (
                <div class:list={['arc-row', { now: track.current }]}>
                  <span class="yr">{track.when}</span>
                  <span class="arc-main">
                    <b>{track.title}</b>
                    <span class="role"> · {track.role}</span>
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      {/* Beat 7 — the ask. This card's resume CTA is the one CTA on this step. */}
      <section class="step" data-step>
        <div class="card">
          <div class="upper kicker">The ask</div>
          <div class="ask">
            <p class="lead">That's the tour. If it's a fit, here's the fastest way in:</p>
            <a class="btn accent" href={RESUME_URL}>Download resume ↓</a>
            <a class="btn" href={EMAIL_URL}>Email me</a>
            <a class="btn" href={GITHUB_URL}>GitHub ↗</a>
          </div>
        </div>
      </section>

      {/* Beat 8 — handoff into the full site */}
      <section class="step" data-step>
        <div class="card handoff">
          <div class="upper kicker">That's the tour</div>
          <h2>Thanks for the time.</h2>
          <p class="hlede">
            The full library has everything: every project, the resume timeline,
            and the live builds.
          </p>
          <a class="btn primary" href="/library">Continue to the full site →</a>
        </div>
      </section>

      {/* Pinned bottom nav — dots injected by the island. */}
      <nav class="tour-nav" aria-label="Tour steps">
        <button class="ghostbtn" type="button" data-tour-prev>‹ Back</button>
        <div class="dots" data-tour-dots></div>
        <button class="btn primary navnext" type="button" data-tour-next>Next →</button>
      </nav>
    </div>
  </main>
</Tour>

<style>
  /* ---- top chrome ---- */
  .tour-main {
    /* 100dvh so the pinned nav never leaves the viewport while the card
       scrolls internally; the card carries flex:1 + overflow:auto below. */
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }
  .tbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    padding: 22px 40px 0;
  }
  .tbar .tour-back {
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-dim);
    text-decoration: none;
  }
  .tbar .tour-back:hover {
    color: var(--pl-text);
  }
  .resbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    /* shares the 44px tap-target height + vertical padding of the tour CTAs */
    min-height: 44px;
    min-width: 44px;
    padding: 11px 18px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--pl-tile-line);
    color: var(--pl-text);
    text-decoration: none;
  }
  .resbtn:hover {
    border-color: var(--pl-focus);
  }

  /* ---- tour shell ---- */
  .tour {
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    padding: 14px 40px 40px;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .upper {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 11px;
    color: var(--pl-faint);
    font-family: var(--pl-mono);
  }

  /*
    No-JS default: every beat is stacked and scrollable, the stepper nav/dots
    are hidden, the card sizes to its content. The island sets
    `html[data-tour-js]`, which flips to the single-screen stepper below.
  */
  .step {
    margin-bottom: 18px;
  }
  .card {
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 20px;
    padding: 34px;
    display: flex;
    flex-direction: column;
  }
  .tour-nav {
    display: none;
  }

  /* ---- JS-on: single-screen stepper ---- */
  :global(html[data-tour-js]) .tour {
    height: calc(100dvh - 58px);
  }
  :global(html[data-tour-js]) .step {
    display: none;
    flex: 1 1 auto;
    min-height: 0;
    margin-bottom: 0;
  }
  :global(html[data-tour-js]) .step.is-active {
    display: flex;
    flex-direction: column;
  }
  :global(html[data-tour-js]) .card {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
    scrollbar-width: thin;
  }
  :global(html[data-tour-js]) .tour-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 16px;
    flex: 0 0 auto;
    /* Honor the home indicator on iOS; pairs with viewport-fit=cover. */
    padding-bottom: env(safe-area-inset-bottom);
  }

  /* ---- hook / agenda beat ---- */
  .hook h1 {
    font-size: 40px;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 16px 0 10px;
  }
  .hook .arc {
    color: var(--pl-dim);
    font-size: 18px;
    margin-bottom: 22px;
  }
  .ag-head {
    margin: 16px 0 4px;
  }
  .ag-row {
    display: grid;
    grid-template-columns: 46px 1fr;
    gap: 14px;
    align-items: baseline;
    padding: 15px 4px;
    border-bottom: 1px solid var(--pl-line);
  }
  .ag-row:last-child {
    border-bottom: none;
  }
  .agn {
    font-family: var(--pl-mono);
    font-size: 13px;
    color: var(--pl-accent);
  }
  .ag-row b {
    font-size: 17px;
  }
  .ag-row .agd {
    display: block;
    font-size: 13px;
    color: var(--pl-dim);
    margin-top: 3px;
  }

  /* ---- work beats ---- */
  .kicker {
    margin-bottom: 16px;
  }
  .wtop {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 14px;
  }
  .work-id {
    display: inline-block;
    margin-bottom: 7px;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--accent) 64%, var(--pl-faint));
  }
  .wtop h2 {
    font-size: 28px;
    letter-spacing: -0.02em;
  }
  .wtop .meta {
    display: flex;
    gap: 9px;
    align-items: center;
    margin-top: 5px;
  }
  .wtop .meta span {
    font-size: 12.5px;
    color: var(--pl-faint);
    font-family: var(--pl-mono);
  }
  .wbody {
    display: grid;
    grid-template-columns: 1fr 322px;
    gap: 26px;
    align-items: start;
    margin-top: 6px;
  }
  /* Grid items default to min-width:auto, so a wide child (the screenshot rail
     or a long unwrapped line) blows the row past the viewport on narrow
     screens. min-width:0 lets both columns shrink and the text wrap. */
  .wbody > * {
    min-width: 0;
  }
  .wline {
    font-size: 16px;
    max-width: 60ch;
    margin-bottom: 8px;
  }
  .wproof {
    color: var(--pl-dim);
    font-size: 13.5px;
    margin-bottom: 6px;
  }
  .wproof::before {
    content: '✓ ';
    color: var(--pl-green);
  }
  /* Let the screenshot rail bleed to the card edge. */
  .wshot {
    margin: 0 -10px;
  }
  .wshot :global(.shots) {
    padding: 6px 10px 8px;
    scroll-padding-inline: 10px;
  }

  /* ---- "More on this" disclosure ---- */
  .wdetail {
    margin-top: 12px;
  }
  .wdetail > summary {
    list-style: none;
    cursor: pointer;
    color: var(--pl-focus);
    font-family: var(--pl-mono);
    font-size: 12.5px;
    letter-spacing: 0.03em;
    width: fit-content;
  }
  .wdetail > summary::-webkit-details-marker {
    display: none;
  }
  .wdetail > summary::after {
    content: ' ↓';
  }
  .wdetail[open] > summary::after {
    content: ' ↑';
  }
  .wdetail > summary:hover {
    text-decoration: underline;
  }
  .wdetail-body {
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--pl-line);
  }
  .wdetail-body p {
    color: var(--pl-dim);
    font-size: 14px;
    line-height: 1.55;
    max-width: 74ch;
    margin-bottom: 16px;
  }
  .dmetrics {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .dm {
    padding: 9px 13px;
    border-radius: 10px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
  }
  .dm b {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .dm span {
    display: block;
    font-size: 10.5px;
    color: var(--pl-dim);
    font-family: var(--pl-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
  }
  .dlinks {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .dlink {
    color: var(--pl-focus);
    font-size: 13px;
    font-family: var(--pl-mono);
    text-decoration: none;
  }
  .dlink:hover {
    text-decoration: underline;
  }
  .dlink.off {
    color: var(--pl-faint);
  }

  /* ---- resume timeline beat ---- */
  .arc-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 6px;
  }
  .arc-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 14px;
    align-items: baseline;
    padding: 11px 6px;
    border-bottom: 1px solid var(--pl-line);
  }
  .arc-row:last-child {
    border-bottom: none;
  }
  .arc-row .yr {
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-faint);
  }
  .arc-row b {
    font-size: 15px;
  }
  .arc-row .role {
    font-size: 12.5px;
    color: var(--pl-dim);
  }
  .arc-row.now b {
    color: var(--pl-focus);
  }

  /* ---- ask beat ---- */
  .ask {
    margin-top: 8px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .ask .lead {
    width: 100%;
    color: var(--pl-dim);
    font-size: 14px;
    margin-bottom: 4px;
  }

  /* ---- handoff beat ---- */
  .handoff h2 {
    font-size: 30px;
    letter-spacing: -0.02em;
    margin: 14px 0 10px;
  }
  .handoff .hlede {
    color: var(--pl-dim);
    font-size: 16px;
    max-width: 56ch;
    margin-bottom: 22px;
  }

  /* ---- buttons (shared) ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    /* 44px min tap target (WCAG 2.5.5); shared height + vertical padding across
       every tour control so the CTAs and the Back/Next pair read as one set */
    min-height: 44px;
    min-width: 44px;
    padding: 11px 20px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--pl-tile-line);
    color: var(--pl-text);
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    width: fit-content;
    /* never wrap a label into a taller, mis-sized pill */
    white-space: nowrap;
  }
  .btn.primary {
    background: var(--pl-text);
    color: #111;
    border-color: transparent;
  }
  .btn.accent {
    background: var(--pl-accent);
    color: #fff;
    border-color: transparent;
  }
  .btn:hover {
    border-color: var(--pl-focus);
  }

  /* ---- bottom nav (stepper chrome) ---- */
  .dots {
    display: flex;
    gap: 7px;
    align-items: center;
    /* the dots absorb the leftover row width and shrink/scroll on narrow
       screens, so the Back/Next pills always keep their full 44px box */
    flex: 0 1 auto;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .dots::-webkit-scrollbar {
    display: none;
  }
  .navnext {
    border: none;
  }
  /* nav pills never shrink below their content; only the dots give way */
  .ghostbtn,
  .navnext {
    flex: 0 0 auto;
  }
  .ghostbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* match the Next button's box exactly (height, padding, font) so the
       Back/Next pair is coherent; ghost styling is the only difference */
    min-height: 44px;
    min-width: 44px;
    background: transparent;
    border: 1px solid var(--pl-tile-line);
    color: var(--pl-dim);
    border-radius: 999px;
    padding: 11px 20px;
    font-size: 14px;
    cursor: pointer;
    font-weight: 600;
  }
  .ghostbtn:hover {
    color: var(--pl-text);
    border-color: var(--pl-focus);
  }
  .ghostbtn[disabled] {
    opacity: 0.35;
    cursor: default;
  }
  /* Dots injected by the island carry `.dot` / `.dot.on`. */
  .dots :global(.dot) {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--pl-line);
    transition: 0.2s;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .dots :global(.dot:hover) {
    background: var(--pl-faint);
  }
  .dots :global(.dot.on) {
    background: var(--pl-accent);
    width: 24px;
    border-radius: 5px;
  }
  .dots :global(.dot.on:hover) {
    background: var(--pl-accent);
  }

  /* ---- mobile (site-standard 820px breakpoint) ---- */
  @media (max-width: 820px) {
    .tbar,
    .tour {
      padding-left: 18px;
      padding-right: 18px;
    }
    .card {
      padding: 24px;
    }
    .hook h1 {
      font-size: 30px;
    }
    .wtop h2 {
      font-size: 23px;
    }
    .wbody {
      grid-template-columns: 1fr;
    }
    .arc-row {
      grid-template-columns: 90px 1fr;
    }
    /* Explicitly hold every tap target at >=44x44 with consistent height +
       vertical padding + font-size on mobile, so no desktop value leaks
       through unchecked (incl. <=375px). */
    .btn,
    .ghostbtn,
    .resbtn {
      min-height: 44px;
      min-width: 44px;
      padding-top: 11px;
      padding-bottom: 11px;
      font-size: 14px;
    }
  }
</style>
