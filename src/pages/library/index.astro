---
/**
 * All-work library, relocated from `/` in #60. The home route became the
 * concierge ("What brings you here?"), so the full player-style "now playing"
 * library now lives here at `/library`. Old `/`, `/projects`, and `/player`
 * links resolve here via the vercel.json 301s.
 *
 * This does NOT collide with `/library/[filter]`: `PLAYLIST_SLUGS` excludes
 * `all`, so no filter route ever emits `/library`.
 */
import PlayerLayout from '../../layouts/Player.astro';
import LibraryView from '../../components/player/LibraryView.astro';
import { CATALOG } from '../../data/catalog';
import { libraryMeta } from '../../lib/seo';

const now = CATALOG[0];
const title = 'Dylan McCavitt · All work';
const meta = {
  ...libraryMeta(
    'All work',
    `All work, ${CATALOG.length} projects: ${CATALOG.map((p) => p.title).join(', ')}.`,
  ),
  title,
};
---

<PlayerLayout title={title} meta={meta} active="all" now={now}>
  <LibraryView filter="all" now={now} />
</PlayerLayout>
