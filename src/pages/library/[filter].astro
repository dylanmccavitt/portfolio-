---
/**
 * Filtered library views — one static route per project category except `all`,
 * which lives at `/library`.
 *
 * Routing (#25): the URL segment is the canonical lowercase-kebab slug from
 * `PLAYLIST_SLUGS` (e.g. `Agents & MCP` → `/library/agents-mcp`), not the raw
 * playlist id. `getStaticPaths` emits those slugs and `playlistFromSlug`
 * resolves the param back to the playlist id, so this route and the sitemap
 * share one stable slug scheme.
 *
 * Static rendering, zero client JS — the filter is the route, not a click.
 */
import type { GetStaticPaths } from 'astro';
import Editorial from '@/layouts/Editorial.astro';
import LibraryView from '@/components/LibraryView.astro';
import {
  PLAYLIST_SLUGS,
  playlistFromSlug,
  type PlaylistId,
} from '@/data/catalog';
import { filterPublicProjectDetails, loadPublicProjectDetails, shouldRenderPublicProjectsLive } from '@/lib/public-projects';
import { libraryMeta } from '@/lib/seo';

/** Page titles per filter; areas fall back to their own label. */
const PAGE_TITLE: Partial<Record<PlaylistId, string>> = {
  wip: 'Now building',
  School: 'School · Stevens',
  Research: 'Research & retired',
};

export const prerender = !shouldRenderPublicProjectsLive(process.env);

export const getStaticPaths = (() => {
  return Object.values(PLAYLIST_SLUGS).map((filter) => ({ params: { filter } }));
}) satisfies GetStaticPaths;

const { filter: slug } = Astro.params as { filter: string };
// `getStaticPaths` only emits known slugs, so this always resolves.
const filter = playlistFromSlug(slug)!;

const label = PAGE_TITLE[filter] ?? filter;
const title = `Dylan McCavitt · ${label}`;
const { projects: allProjects } = await loadPublicProjectDetails();
const projects = filterPublicProjectDetails(allProjects, filter);
const meta = {
  ...libraryMeta(
    label,
    `${label}, ${projects.length} ${
      projects.length === 1 ? 'project' : 'projects'
    }: ${projects.map((p) => p.title).join(', ')}.`,
  ),
  title,
};
---

<Editorial title={title} meta={meta}>
  <LibraryView filter={filter} projects={allProjects} />
</Editorial>
