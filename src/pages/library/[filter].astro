---
/**
 * Filtered library views — one static route per playlist except `all`, which
 * lives at `/`. Each route renders the library hero + the tracklist filtered to
 * that playlist.
 *
 * Routing (#25): the URL segment is the canonical lowercase-kebab slug from
 * `PLAYLIST_SLUGS` (e.g. `Agents & MCP` → `/library/agents-mcp`), not the raw
 * playlist id. `getStaticPaths` emits those slugs and `playlistFromSlug`
 * resolves the param back to the playlist id, so the sidebar link, this route,
 * and the sitemap all share one stable slug scheme.
 *
 * Static rendering, zero client JS — the filter is the route, not a click.
 */
import type { GetStaticPaths } from 'astro';
import PlayerLayout from '../../layouts/Player.astro';
import LibraryView from '../../components/player/LibraryView.astro';
import {
  CATALOG,
  PLAYLIST_SLUGS,
  playlistFromSlug,
  type PlaylistId,
} from '../../data/catalog';

/** Page titles per filter; areas fall back to their own label. */
const PAGE_TITLE: Partial<Record<PlaylistId, string>> = {
  wip: 'Now building',
  money: 'Live with real money',
  School: 'School · Stevens',
  Research: 'Research & retired',
};

export const getStaticPaths = (() => {
  return Object.values(PLAYLIST_SLUGS).map((filter) => ({ params: { filter } }));
}) satisfies GetStaticPaths;

const { filter: slug } = Astro.params as { filter: string };
// `getStaticPaths` only emits known slugs, so this always resolves.
const filter = playlistFromSlug(slug)!;

const now = CATALOG[0];
const title = `Dylan McCavitt — ${PAGE_TITLE[filter] ?? filter}`;
---

<PlayerLayout title={title} active={filter} now={now}>
  <LibraryView filter={filter} now={now} />
</PlayerLayout>
