---
const diagramHref = "/diagrams/homelab-topology.png";

return Astro.redirect(diagramHref, 302);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${diagramHref}`} />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>
      Redirecting to the homelab topology diagram.
      <a href={diagramHref}>Continue</a>
    </p>
  </body>
</html>
