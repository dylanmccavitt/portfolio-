---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TopologyMap from '../../components/topology/TopologyMap.astro';
import '../../styles/topology.css';
---

<Base title="Homelab Topology — Dylan McCavitt" description="Interactive topology map of Dylan's homelab infrastructure">
  <div class="topology-page">
    <div class="topology-breadcrumb">
      <Breadcrumb slug="topology" section="homelab" />
    </div>

    <TopologyMap />

    <div class="topology-controls">
      <button id="zoom-in" aria-label="Zoom in">+</button>
      <button id="zoom-out" aria-label="Zoom out">-</button>
      <button id="reset-view" aria-label="Reset view">Reset</button>
    </div>

    <div class="topology-legend">
      <div class="topology-legend-item">
        <span class="legend-swatch legend-swatch--physical"></span>
        <span>Physical</span>
      </div>
      <div class="topology-legend-item">
        <span class="legend-swatch legend-swatch--runtime"></span>
        <span>Runtime</span>
      </div>
      <div class="topology-legend-item">
        <span class="legend-swatch legend-swatch--policy"></span>
        <span>Policy</span>
      </div>
    </div>

    <div id="popcard-container"></div>
  </div>
</Base>
