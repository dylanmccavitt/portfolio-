---
import DMLayout from '@/layouts/DM.astro';
import {
  AGENT_NAME,
  FIT_CHECK_CONTEXT_LIMIT,
  FIT_CHECK_INPUT_LIMIT,
  FIT_CHECK_MIN_CHARS,
} from '@/lib/dm/client';
import { libraryMeta, personJsonLd } from '@/lib/seo';

const meta = {
  ...libraryMeta(
    'Fit check',
    "Paste a job description and ask DM for an evidence-grounded read against Dylan McCavitt's portfolio and resume.",
  ),
  jsonLd: personJsonLd(),
};
---

<DMLayout title="Fit check · Dylan McCavitt" meta={meta}>
  <div class="dm-root dm-root--fit" data-dm-root>
    <aside class="dm-side">
      <div class="dm-id">
        <span class="dm-monogram" aria-hidden="true">▤</span>
        <span class="dm-id-text">
          <span class="dm-id-name">Fit check</span>
          <span class="dm-id-sub">recruiter flow</span>
        </span>
        <span class="dm-dot" title="online" aria-hidden="true"></span>
      </div>

      <section class="dm-section dm-section--fit">
        <p class="dm-label">Privacy</p>
        <p class="dm-fit-note">
          Paste text for one active request. DM sends a bounded, sanitized excerpt to the chat endpoint and does not store the full paste in the conversation.
        </p>
      </section>

      <a class="dm-reset" href="/">
        <span aria-hidden="true">←</span> Back to DM
      </a>
    </aside>

    <main class="dm-main">
      <header class="dm-bar">
        <span class="dm-bar-title"
          >{AGENT_NAME} <span class="dm-bar-sub">· job-description fit check</span></span
        >
        <span class="dm-bar-status"
          ><span class="dm-dot" aria-hidden="true"></span> ready</span
        >
      </header>

      <div class="dm-stage">
        <div class="dm-thread" data-dm-thread role="log" aria-label="Conversation with DM"></div>

        <div class="dm-empty dm-empty--fit">
          <form class="dm-fit" data-dm-fit-form novalidate>
            <div class="dm-fit-head">
              <p class="dm-label">Recruiter flow</p>
              <h1 class="dm-greeting">Paste a job description for an evidence-grounded fit check.</h1>
              <p class="dm-subgreeting">
                DM will compare the role against Dylan's canonical portfolio and resume, then call out strengths, evidence, gaps, and contact steps.
              </p>
            </div>

            <label class="dm-fit-label" for="fit-check-job-description">Job description</label>
            <textarea
              id="fit-check-job-description"
              class="dm-fit-textarea"
              data-dm-fit-input
              name="jobDescription"
              minlength={FIT_CHECK_MIN_CHARS}
              maxlength={FIT_CHECK_INPUT_LIMIT}
              rows="12"
              placeholder="Paste the role description, responsibilities, and requirements..."
              aria-describedby="fit-check-help fit-check-count fit-check-error"
            ></textarea>
            <div class="dm-fit-meta">
              <span id="fit-check-count" data-dm-fit-count>0 / {FIT_CHECK_INPUT_LIMIT.toLocaleString()}</span>
              <span id="fit-check-help">
                Minimum {FIT_CHECK_MIN_CHARS.toLocaleString()} characters. DM reads up to {FIT_CHECK_CONTEXT_LIMIT.toLocaleString()} sanitized characters.
              </span>
            </div>
            <p class="dm-fit-error" id="fit-check-error" data-dm-fit-error hidden></p>
            <button class="dm-fit-submit" type="submit" data-dm-fit-submit>
              Fit-check with DM
            </button>
          </form>
        </div>
      </div>

      <form class="dm-composer" data-dm-form>
        <div class="dm-composer-inner">
          <span class="dm-composer-glyph" aria-hidden="true">⌁</span>
          <input
            class="dm-input"
            data-dm-input
            type="text"
            name="message"
            autocomplete="off"
            spellcheck="false"
            placeholder="Ask a follow-up about the fit..."
            aria-label="Ask DM a follow-up"
          />
          <button class="dm-send" type="submit" data-dm-submit aria-label="Send message">→</button>
        </div>
      </form>
    </main>
  </div>
</DMLayout>
