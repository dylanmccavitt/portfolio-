---
import Base from '../layouts/Base.astro';
---

<Base title="Dylan McCavitt" showPaletteNav={true}>
  <main>
    <section class="about" id="about">
      <h2 class="section-heading section-heading--about">about</h2>
      <p class="about__text">
        Software engineer who likes to move around. I've built SaaS products,
        written CLI tools, automated deployments, and run my own infrastructure
        from scratch. I'd rather learn the whole system than own one slice of
        it — always picking up new tools along the way. Brooklyn, looking for
        my next role.
      </p>
    </section>

    <section class="skills" id="skills">
      <details class="skills__reveal">
        <summary class="skills__toggle">
          <h2 class="section-heading section-heading--skills">.skills</h2>
        </summary>
        <div class="skills__content">
          <div class="skills__prompt">$ ls -a</div>
          <div class="skills__listing">
            <div class="skills__row">
              <span class="skills__name skills__name--1">languages</span>
              <span class="skills__items">typescript  python  go  c++  bash</span>
            </div>
            <div class="skills__row">
              <span class="skills__name skills__name--2">infrastructure</span>
              <span class="skills__items">linux  docker  terraform</span>
            </div>
            <div class="skills__row">
              <span class="skills__name skills__name--3">web</span>
              <span class="skills__items">next.js  astro  express  postgresql  stripe</span>
            </div>
          </div>
        </div>
      </details>
    </section>

    <section class="projects" id="projects">
      <h2 class="section-heading section-heading--projects">projects</h2>
      <div class="projects__listing">
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/homeserver/" class="projects__link projects__link--1">homeserver/</a>
          <span class="projects__desc">— self-hosted infrastructure and automation</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/bellas-beads/" class="projects__link projects__link--2">bellas-beads/</a>
          <span class="projects__desc">— ecommerce site for jewelry</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/nhf/" class="projects__link projects__link--3">nhf/</a>
          <span class="projects__desc">— website for a band</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/work-orders/" class="projects__link projects__link--4">work-orders/</a>
          <span class="projects__desc">— work order management system, school project</span>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <h2 class="section-heading section-heading--contact">contact</h2>
      <div class="contact__links">
        <a href="https://github.com/DylanMcCavitt" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com/in/dylanmccavitt" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:dylan@example.com">Email</a>
      </div>
    </section>
  </main>
</Base>

<style>
  /* Section headings */
  .section-heading {
    font-size: var(--text-xl);
    font-weight: 600;
    opacity: 0.7;
    text-transform: lowercase;
    margin-bottom: var(--space-5);
  }
  .section-heading::before {
    content: "/";
    color: var(--border);
    margin-right: var(--space-1);
  }
  .section-heading--projects { color: var(--nav-1); }
  .section-heading--about { color: var(--nav-2); }
  .section-heading--contact { color: var(--nav-3); }
  .section-heading--skills { color: var(--nav-4); }

  /* About */
  .about {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-6);
  }
  .about__text {
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* Skills — dotfile listing */
  .skills {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .skills__reveal {
    border: none;
  }
  .skills__toggle {
    list-style: none;
    cursor: pointer;
  }
  .skills__toggle::-webkit-details-marker {
    display: none;
  }
  .skills__toggle:hover .section-heading {
    opacity: 1;
  }
  .skills__prompt {
    color: var(--border);
    margin-bottom: var(--space-2);
  }
  .skills__listing {
    line-height: 2.4;
  }
  .skills__row {
    white-space: nowrap;
  }
  .skills__name {
    font-weight: 600;
    margin-right: var(--space-4);
  }
  .skills__name--1 { color: var(--nav-1); }
  .skills__name--2 { color: var(--nav-2); }
  .skills__name--3 { color: var(--nav-3); }
  .skills__items {
    color: var(--text-muted);
  }

  /* Projects — terminal listing */
  .projects {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .projects__listing {
    line-height: 2.4;
  }
  .projects__row {
    white-space: nowrap;
  }
  .projects__chevron {
    color: var(--accent);
    margin-right: var(--space-2);
  }
  .projects__link {
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px dashed currentColor;
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }
  .projects__link:hover {
    text-decoration: none;
    border-bottom-style: solid;
    border-bottom-color: currentColor;
  }
  .projects__link--1 { color: var(--nav-1); }
  .projects__link--2 { color: var(--nav-2); }
  .projects__link--3 { color: var(--nav-3); }
  .projects__link--4 { color: var(--nav-4); }
  .projects__desc {
    color: var(--text-muted);
    margin-left: var(--space-3);
  }

  /* Contact */
  .contact {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-7);
  }
  .contact__links {
    display: flex;
    gap: var(--space-6);
  }
  .contact__links a {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .contact__links a:hover { color: var(--text); }
</style>
