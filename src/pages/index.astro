---
/**
 * Home — the Split-canvas Eve landing (#86). The portfolio is agent-first: you
 * land on Eve, a chat agent that answers questions about Dylan and renders
 * project, résumé, and contact artifacts. This is the winning Split-canvas
 * layout folded into production and wired to the Eve streaming endpoint (#84)
 * via the chat island (`scripts/eve.ts`); canned demo driver/data are not
 * shipped.
 *
 * Structure: a persistent left rail (Eve identity, suggested prompts,
 * new-conversation) and a main pane (empty-state greeting, the
 * conversation thread the island fills, and a docked composer). The thread's
 * turns are built client-side from streamed payloads — see `scripts/eve.ts`.
 *
 * This page renders the static shell only; all interaction lives in the island.
 */
import EveLayout from '../layouts/Eve.astro';
import { AGENT_NAME, CONTACT, GREETING, SUBGREETING, SUGGESTED } from '../lib/eve';
import { libraryMeta, personJsonLd } from '../lib/seo';

const meta = {
  ...libraryMeta(
    'Dylan McCavitt',
    'Software engineer in NYC building practical tools, client software, AI-assisted workflows, and grounded side-project evidence. Ask DM or browse directly.',
  ),
  jsonLd: personJsonLd(),
};

const ENTRY_LINKS = [
  {
    label: 'Project library',
    href: '/library',
    eyebrow: 'Evidence',
    text: 'Practical tools, client software, and side-project proof.',
  },
  {
    label: 'Resume / journey',
    href: '/journey',
    eyebrow: 'Background',
    text: 'Economics, legal ops, cyber risk, CS, and current work.',
  },
  {
    label: 'Hiring tour',
    href: '/hiring',
    eyebrow: 'Recruiter path',
    text: 'A guided read on fit, strengths, and strongest examples.',
  },
  {
    label: 'Fit check',
    href: '/fit-check',
    eyebrow: 'Job description',
    text: 'Paste a role and get an evidence-grounded DM read.',
  },
  {
    label: 'Contact Dylan',
    href: `mailto:${CONTACT.email}`,
    eyebrow: 'Next step',
    text: 'Email directly from the current resume contact details.',
  },
] as const;
---

<EveLayout title="Dylan McCavitt · Software engineer" meta={meta}>
  <div class="eve-root eve-root--home" data-eve-root>
    <!-- ============ persistent left rail ============ -->
    <aside class="eve-side">
      <div class="eve-id">
        <span class="eve-monogram" aria-hidden="true">✦</span>
        <span class="eve-id-text">
          <span class="eve-id-name">{AGENT_NAME}</span>
          <span class="eve-id-sub">portfolio agent</span>
        </span>
        <span class="eve-dot" title="online" aria-hidden="true"></span>
      </div>

      <section class="eve-section eve-section--grow">
        <p class="eve-label">Suggested</p>
        <ul class="eve-suggest">
          {
            SUGGESTED.map((prompt) => (
              <li>
                <button
                  class="eve-suggest-row"
                  type="button"
                  data-eve-send
                  data-label={prompt.label}
                >
                  <span class="eve-suggest-label">{prompt.label}</span>
                </button>
              </li>
            ))
          }
        </ul>
      </section>

      <button class="eve-reset" type="button" data-eve-reset>
        <span aria-hidden="true">↺</span> New conversation
      </button>
      <a class="eve-reset eve-fit-link" href="/fit-check">
        <span aria-hidden="true">▤</span> Paste a job description
      </a>
    </aside>

    <!-- ============ main conversation pane ============ -->
    <main class="eve-main">
      <header class="eve-bar">
        <span class="eve-bar-title"
          >{AGENT_NAME} <span class="eve-bar-sub">· portfolio agent</span></span
        >
        <span class="eve-bar-status"
          ><span class="eve-dot" aria-hidden="true"></span> ready</span
        >
      </header>

      <div class="eve-stage">
        <!-- empty state -->
        <div class="eve-empty">
          <div class="eve-card">
            <span class="eve-card-tile" aria-hidden="true">✦</span>
            <p class="eve-entry-kicker">Dylan McCavitt · software engineer</p>
            <h1 class="eve-greeting">{GREETING}</h1>
            <p class="eve-subgreeting">{SUBGREETING}</p>
            <nav class="eve-entry-grid" aria-label="Recruiter entry paths">
              {
                ENTRY_LINKS.map((link) => (
                  <a class="eve-entry-link" href={link.href}>
                    <span class="eve-entry-eyebrow">{link.eyebrow}</span>
                    <span class="eve-entry-label">{link.label}</span>
                    <span class="eve-entry-text">{link.text}</span>
                  </a>
                ))
              }
            </nav>
            <p class="eve-hint">Suggested questions stay in the side rail, or type your own below ↓</p>
          </div>
        </div>

        <!-- conversation thread (filled by the island) -->
        <div class="eve-thread" data-eve-thread role="log" aria-label="Conversation with DM"></div>
      </div>

      <!-- docked composer -->
      <form class="eve-composer" data-eve-form>
        <div class="eve-composer-inner">
          <span class="eve-composer-glyph" aria-hidden="true">⌁</span>
          <input
            class="eve-input"
            data-eve-input
            type="text"
            name="message"
            autocomplete="off"
            spellcheck="false"
            placeholder="Ask DM about Dylan's work…"
            aria-label="Ask DM about Dylan"
          />
          <button class="eve-send" type="submit" data-eve-submit aria-label="Send message">→</button>
        </div>
      </form>
    </main>
  </div>
</EveLayout>
