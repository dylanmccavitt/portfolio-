---
import Base from '../layouts/Base.astro';
---

<Base title="Dylan McCavitt" showPaletteNav={true}>
  <main>
    <section class="about" id="about">
      <h2 class="section-heading section-heading--about">about</h2>
      <p class="about__text">
        Software engineer in NYC. I build web apps, manage infrastructure,
        and always expanding what I can work with. Currently open to opportunities.
      </p>
    </section>

    <section class="skills" id="skills">
      <h2 class="section-heading section-heading--skills">.skills</h2>
      <div class="skills__listing">
        <div class="skills__row">
          <span class="skills__name skills__name--1">languages</span>
          <span class="skills__items">typescript  python  go  c++  bash</span>
        </div>
        <div class="skills__row">
          <span class="skills__name skills__name--2">infrastructure</span>
          <span class="skills__items">linux  docker  terraform</span>
        </div>
        <div class="skills__row">
          <span class="skills__name skills__name--3">web</span>
          <span class="skills__items">next.js  astro  express  postgresql  stripe</span>
        </div>
      </div>
    </section>

    <section class="projects" id="projects">
      <h2 class="section-heading section-heading--projects">projects</h2>
      <div class="projects__listing">
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/homeserver/" class="projects__link projects__link--1">homeserver/</a>
          <span class="projects__desc">-infrastructure</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/bellas-beads/" class="projects__link projects__link--2">bellas-beads/</a>
          <span class="projects__desc">-web app</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/nhf/" class="projects__link projects__link--3">nhf/</a>
          <span class="projects__desc">-band site</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/work-orders/" class="projects__link projects__link--4">work-orders/</a>
          <span class="projects__desc">-web app</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/epl-ml-model/" class="projects__link projects__link--5">epl-ml-model/</a>
          <span class="projects__desc">-ML model</span>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <h2 class="section-heading section-heading--contact">contact</h2>
      <p class="contact__blurb">Open to opportunities or collaboration. Reach out wherever works.</p>
      <div class="contact__links">
        <a href="mailto:dylanmccavitt@outlook.com" class="contact__item">
          <svg class="contact__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 4 10 8 10-8"/></svg>
          <span>Email</span>
        </a>
        <a href="https://github.com/DylanMcCavitt" target="_blank" rel="noopener noreferrer" class="contact__item">
          <svg class="contact__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
          <span>GitHub</span>
        </a>
        <a href="https://www.linkedin.com/in/dylan-mccavitt" target="_blank" rel="noopener noreferrer" class="contact__item">
          <svg class="contact__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href="https://x.com/dylanmccavitt_" target="_blank" rel="noopener noreferrer" class="contact__item">
          <svg class="contact__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>X</span>
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  /* Section headings */
  .section-heading {
    font-size: var(--text-xl);
    font-weight: 600;
    opacity: 0.7;
    text-transform: lowercase;
    margin-bottom: var(--space-5);
  }
  .section-heading::before {
    content: "/";
    color: var(--border);
    margin-right: var(--space-1);
  }
  .section-heading--projects { color: var(--nav-1); }
  .section-heading--about { color: var(--nav-2); }
  .section-heading--contact { color: var(--nav-3); }
  .section-heading--skills { color: var(--nav-4); }

  /* About */
  .about {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-6);
  }
  .about__text {
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* Skills — dotfile listing */
  .skills {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .skills__listing {
    line-height: 2.4;
  }
  .skills__row {
    white-space: nowrap;
  }
  .skills__name {
    font-weight: 600;
    margin-right: var(--space-4);
  }
  .skills__name--1 { color: var(--nav-1); }
  .skills__name--2 { color: var(--nav-2); }
  .skills__name--3 { color: var(--nav-3); }
  .skills__items {
    color: var(--text-muted);
  }

  /* Projects — terminal listing */
  .projects {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .projects__listing {
    line-height: 2.4;
  }
  .projects__row {
    white-space: nowrap;
  }
  .projects__chevron {
    color: var(--accent);
    margin-right: var(--space-2);
  }
  .projects__link {
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px dashed currentColor;
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }
  .projects__link:hover {
    text-decoration: none;
    border-bottom-style: solid;
    border-bottom-color: currentColor;
  }
  .projects__link--1 { color: var(--nav-1); }
  .projects__link--2 { color: var(--nav-2); }
  .projects__link--3 { color: var(--nav-3); }
  .projects__link--4 { color: var(--nav-4); }
  .projects__link--5 { color: var(--accent); }
  .projects__desc {
    color: var(--text-muted);
    margin-left: var(--space-3);
  }

  /* Contact */
  .contact {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-7);
  }
  .contact__blurb {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
    line-height: 1.6;
  }
  .contact__links {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .contact__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .contact__item:hover {
    color: var(--text);
    text-decoration: none;
  }
  .contact__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .skills__row {
      white-space: normal;
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: var(--space-3);
    }
    .skills__name {
      margin-right: 0;
      margin-bottom: var(--space-1);
    }
    .skills__items {
      font-size: var(--text-sm);
      padding-left: var(--space-3);
    }
    .skills__listing {
      line-height: 1.8;
    }

    .projects__row {
      white-space: normal;
    }
    .projects__desc {
      font-size: var(--text-sm);
    }
  }
</style>
