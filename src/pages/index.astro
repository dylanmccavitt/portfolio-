---
import NavLink from '../components/sera/NavLink.astro';
import IconButton from '../components/sera/IconButton.astro';

const NAV = [
  { to: '/about', label: 'about' },
  { to: '/projects', label: 'projects' },
  { to: '/experience', label: 'experience' },
  { to: '/log', label: 'log' },
  { to: '/contact', label: 'contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Dylan McCavitt — software engineer in NYC." />
    <meta property="og:title" content="Dylan McCavitt | Portfolio" />
    <meta property="og:description" content="Portfolio" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:title" content="Dylan McCavitt" />
    <meta name="twitter:description" content="Dylan McCavitt — software engineer in NYC." />
    <title>Dylan McCavitt</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)'
          ).matches;
          const isDark = stored === 'dark' || (stored === null && prefersDark);
          if (isDark) document.documentElement.classList.add('dark');
        } catch {
          /* noop — pre-paint theme application is best-effort. */
        }
      })();
    </script>
  </head>
  <body class="paper">
    <main class="landing">
      <div class="landing__actions">
        <IconButton
          ariaLabel="GitHub"
          href="https://github.com/DylanMcCavitt"
          external
        >
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.18A10.94 10.94 0 0 1 12 6.8c.98 0 1.97.13 2.89.38 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
          </svg>
        </IconButton>
        <IconButton ariaLabel="Toggle theme" class="landing-theme-btn">
          <svg
            class="landing-theme-icon landing-theme-icon--sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            ></path>
          </svg>
          <svg
            class="landing-theme-icon landing-theme-icon--moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </IconButton>
      </div>

      <div class="landing__column">
        <header class="landing__header">
          <div class="landing__monogram" aria-hidden="true">
            <span>D</span>
          </div>
          <h1 class="landing__name">Dylan McCavitt</h1>
          <p class="sera-label landing__tagline">
            Software engineer · NYC
          </p>
        </header>

        <nav class="landing__nav" aria-label="Primary">
          {
            NAV.map((item, i) => (
              <NavLink index={i + 1} label={item.label} to={item.to} />
            ))
          }
        </nav>

        <a
          class="landing__resume"
          href="https://www.dylanmccavitt.xyz/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Download resume</span>
          <span aria-hidden="true" class="landing__resume-arrow">↗</span>
        </a>
      </div>
    </main>

    <script is:inline>
      (function () {
        const btn = document.querySelector('.landing-theme-btn');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const root = document.documentElement;
          const isDark = root.classList.toggle('dark');
          try {
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          } catch {
            /* best effort */
          }
        });
      })();
    </script>

    <style is:global>
      @import '../styles/global.css';

      .landing {
        position: relative;
        z-index: 2;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 64px 24px;
      }
      .landing__actions {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .landing__column {
        width: 100%;
        max-width: 440px;
        display: flex;
        flex-direction: column;
      }
      .landing__header {
        text-align: center;
        margin-bottom: 40px;
      }
      .landing__monogram {
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        margin: 0 auto 24px;
        border: 1px solid var(--line);
        background: var(--card);
        color: var(--ink);
        transition: transform 0.4s var(--ease);
      }
      .landing__monogram:hover {
        transform: rotate(-4deg) scale(1.06);
      }
      .landing__monogram > span {
        font-size: 17px;
        font-weight: 700;
        line-height: 1;
      }
      .landing__name {
        font-size: 20px;
        font-weight: 700;
        line-height: 1.15;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink);
        margin: 0;
      }
      .landing__tagline {
        margin-top: 10px;
        color: var(--muted);
      }
      .landing__nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .landing__resume {
        margin-top: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        align-self: center;
        font-family: var(--font-mono);
        font-size: 10.5px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.25s var(--ease);
      }
      .landing__resume:hover {
        color: var(--ink);
        text-decoration: none;
      }
      .landing__resume-arrow {
        display: inline-block;
        transition: transform 0.3s var(--ease);
      }
      .landing__resume:hover .landing__resume-arrow {
        transform: translate(2px, -2px);
      }
      .landing-theme-icon {
        width: 14px;
        height: 14px;
      }
      .landing-theme-icon--sun {
        display: none;
      }
      html.dark .landing-theme-icon--sun {
        display: block;
      }
      html.dark .landing-theme-icon--moon {
        display: none;
      }
    </style>
  </body>
</html>
