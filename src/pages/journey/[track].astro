---
/**
 * Resume detail view — one static page per career entry. The route keeps the
 * existing `/journey/[track]` parameter for compatibility while presenting the
 * content as plain resume history.
 */
import Editorial from '@/layouts/Editorial.astro';
import ProjectCardGrid from '@/components/ProjectCardGrid.astro';
import { RESUME, getResumeTrackById, type ResumeTrack } from '@/data/resume';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';
import { loadPublicProjectDetails } from '@/lib/public-projects';
import { resolveRequiredPublicProjectByReference } from '@/lib/public-project-route-resolver';
import { journeyTrackMeta } from '@/lib/seo';

export function getStaticPaths() {
  return RESUME.tracks.map((track) => ({
    params: { track: track.id },
    props: { track },
  }));
}

interface Props {
  track: ResumeTrack;
}
const { track } = Astro.props as Props;

const t = track ?? getResumeTrackById(Astro.params.track as string)!;
const { projects: publicProjects, source: publicProjectSource } = await loadPublicProjectDetails();
const index = RESUME.tracks.findIndex((x) => x.id === t.id);
const previous = index > 0 ? RESUME.tracks[index - 1] : null;
const next = RESUME.tracks[index + 1] ?? null;
const era: ProjectDetailReadModel[] = t.era.map((id) =>
  resolveRequiredPublicProjectByReference(publicProjects, id, {
    route: `journey/[track].astro (${t.id})`,
    source: publicProjectSource,
    label: 'featured project id',
  }),
);

const LINKS = {
  email: 'mailto:dylanmccavitt@outlook.com',
  linkedin: 'https://www.linkedin.com/in/dylan-mccavitt',
};

const meta = journeyTrackMeta(t);
---

<Editorial title={meta.title} meta={meta}>
  <article class="device-route-screen resume-detail" style={`--accent:${t.hue}`}>
    <nav class="screen-nav" aria-label="Primary">
      <a href="/journey">DM / Journey / {t.title}</a>
      <span class="screen-nav-links">
        <a href="/">Home</a>
        <a href="/library">Work</a>
        <a href="/journey">Journey</a>
        <a href="/resume">Resume</a>
        <button type="button" data-open-guide>Ask DM</button>
      </span>
    </nav>

    <div class="detail-wrap">
      <a class="back" href="/journey">Back to resume</a>

      <section class="detail-hero">
        <p class="eyebrow">{t.when}</p>
        <h1>{t.title}</h1>
        <p>{t.role}</p>
        <div class="hero-meta">
          <span class:list={['badge', t.current ? 'live' : 'done']}>
            {t.current ? 'Current' : t.when}
          </span>
        </div>
        {
          t.current && (
            <div class="detail-actions">
              <a class="btn btn-fill" href={LINKS.email}>Email Dylan</a>
              <a class="btn btn-out" href={LINKS.linkedin} target="_blank" rel="noopener">
                LinkedIn
              </a>
            </div>
          )
        }
      </section>

      <div class="read">
        <section class="block">
          <h2>About</h2>
          {t.about.map((para) => <p>{para}</p>)}
        </section>

        <section class="block">
          <h2>Highlights</h2>
          <ul class="notes">
            {t.notes.map((note) => <li>{note}</li>)}
          </ul>
        </section>

        <section class="block">
          <h2>Details</h2>
          <dl class="details">
            {t.credits.map(([label, value]) => (
              <div>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </div>
            ))}
          </dl>
        </section>
      </div>

      {
        era.length > 0 && (
          <section class="related">
            <h2>Related projects</h2>
            <ProjectCardGrid projects={era} />
          </section>
        )
      }

      <nav class="entry-nav" aria-label="Resume entries">
        {previous ? <a href={`/journey/${previous.id}`}>Previous: {previous.title}</a> : <span></span>}
        {next ? <a href={`/journey/${next.id}`}>Next: {next.title}</a> : <a href="/library">View projects</a>}
      </nav>
    </div>
  </article>
</Editorial>

<script is:inline>
  document.querySelectorAll('[data-open-guide]').forEach((button) => {
    button.addEventListener('click', () => document.querySelector('[data-dm-open]')?.click());
  });
</script>

<style>
  .resume-detail {
    --accent: var(--pl-accent);
    padding: clamp(30px, 4.7vw, 70px);
    color: var(--pl-text);
    font-family: var(--pl-sans);
  }

  .screen-nav button {
    min-height: 44px;
    padding: 0 0.75rem;
    color: inherit;
    background: transparent;
    border: 1px solid var(--pl-accent);
    text-transform: uppercase;
    cursor: pointer;
  }

  .detail-wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: clamp(32px, 6vw, 70px) clamp(18px, 5vw, 40px) clamp(64px, 10vw, 112px);
  }

  .back {
    display: inline-flex;
    color: var(--pl-dim);
    font-size: 13px;
    margin-bottom: clamp(32px, 5vw, 56px);
  }
  .back:hover {
    color: var(--pl-text);
  }

  .detail-hero {
    max-width: 720px;
    margin: 0 auto clamp(40px, 7vw, 72px);
    text-align: center;
  }
  .eyebrow {
    font-family: var(--pl-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .detail-hero h1 {
    font-size: clamp(34px, 7vw, 68px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .detail-hero p {
    max-width: 54ch;
    margin: 18px auto 0;
    color: var(--pl-dim);
    font-size: clamp(16px, 2.4vw, 20px);
    line-height: 1.5;
  }
  .hero-meta {
    margin-top: 22px;
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 28px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 13px;
    font-weight: 600;
  }
  .btn-fill {
    background: var(--accent);
    color: #0c0e13;
  }
  .btn-out {
    background: var(--pl-tile);
    color: var(--pl-text);
    border-color: var(--pl-line);
  }
  .btn-out:hover {
    border-color: var(--accent);
  }

  .read {
    max-width: 68ch;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(34px, 5vw, 52px);
  }
  .block h2,
  .related h2 {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--pl-faint);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--pl-line);
  }
  .block p {
    color: var(--pl-text);
    font-size: 15.5px;
    line-height: 1.78;
  }
  .block p + p {
    margin-top: 16px;
  }
  .notes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .notes li {
    position: relative;
    padding-left: 26px;
    color: var(--pl-dim);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .notes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .details {
    display: grid;
    border-top: 1px solid var(--pl-line);
  }
  .details div {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    gap: 24px;
    border-bottom: 1px solid var(--pl-line);
    padding: 12px 0;
  }
  .details dt {
    font-size: 12px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .details dd {
    font-family: var(--pl-mono);
    font-size: 13px;
    color: var(--pl-text);
    text-align: right;
    word-break: break-word;
  }

  .related {
    margin-top: clamp(48px, 8vw, 84px);
  }

  .entry-nav {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: clamp(48px, 8vw, 84px);
    padding-top: 18px;
    border-top: 1px solid var(--pl-line);
    color: var(--pl-dim);
    font-size: 13px;
  }
  .entry-nav a:hover {
    color: var(--pl-text);
  }

  @media (max-width: 640px) {
    .details div {
      grid-template-columns: 1fr;
      gap: 6px;
    }
    .details dd {
      text-align: left;
    }
    .entry-nav {
      flex-direction: column;
    }
  }
</style>
