---
/**
 * Helpful 404 for the agent-first portfolio. Static, no client JavaScript.
 * Renders through the shared `device-route-screen` shell so the miss looks like
 * every other route on the device instead of a standalone full-height page.
 */
import Editorial from '@/layouts/Editorial.astro';
import { libraryMeta } from '@/lib/seo';

const meta = libraryMeta(
  'Page not found',
  'That portfolio URL is no longer active. Ask DM, browse projects, or contact Dylan directly.',
);
---

<Editorial title="Page not found · Dylan McCavitt" meta={meta}>
  <section class="device-route-screen notfound-console">
    <nav class="screen-nav" aria-label="Primary">
      <a href="/">DM / 404</a>
      <span class="screen-nav-links">
        <a href="/">Home</a>
        <a href="/library">Work</a>
        <a href="/journey">Journey</a>
        <a href="/resume">Resume</a>
        <a href="/contact">Contact</a>
      </span>
    </nav>

    <header class="notfound-console-head">
      <p class="screen-kicker">404</p>
      <h1 class="screen-title">Page not found</h1>
      <p class="screen-lede">
        That portfolio URL is no longer active. DM can answer questions about
        Dylan's work, or you can jump straight to projects, resume, or email.
      </p>
    </header>

    <nav class="notfound-console-actions" aria-label="Recovery">
      <a class="console-button console-button--fill" href="/">Ask DM</a>
      <a class="console-button" href="/library">Projects</a>
      <a class="console-button" href="/resume">Resume</a>
      <a href="mailto:dylanmccavitt@outlook.com">Email Dylan</a>
    </nav>
    <p class="screen-footer">Tab move · Enter open · Esc home</p>
  </section>
</Editorial>

<style>
  .notfound-console { padding: clamp(30px, 4.7vw, 70px); }
  .notfound-console-head { border-bottom: 1px solid var(--pl-line); padding-bottom: 1.4rem; }
  .notfound-console .screen-lede { margin-top: 1.3rem; }
  .notfound-console-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin-top: clamp(2rem, 5vh, 4rem); }
  .notfound-console-actions a { min-height: 44px; display: inline-flex; align-items: center; justify-content: center; color: var(--pl-accent); text-transform: uppercase; font-size: .78rem; text-decoration: none; }
  .console-button { min-width: 180px; padding: .7rem 1.2rem; border: 1px solid var(--pl-accent); }
  .console-button--fill { background: #7084a9; color: #eef1f7 !important; }
  @media (max-width: 768px) { .notfound-console-actions { align-items: stretch; flex-direction: column; } .notfound-console-actions a { width: 100%; } }
</style>
