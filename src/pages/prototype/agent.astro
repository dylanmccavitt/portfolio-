---
/**
 * PROTOTYPE — throwaway, do not ship. Chat-first agent landing exploration.
 *
 * Question: when you land on the portfolio, what should the centered chat/agent
 * box look like, and how should the conversation flow once you ask something?
 * The production agent will be a Vercel **Eve** agent (an `agent/` directory:
 * `instructions.md` + TS tools `search_catalog` / `read_resume` / `get_contact`,
 * streamed via the AI SDK). Here answers are canned (`_agentData.ts`) so the
 * variants can be judged on layout + flow without a backend.
 *
 *   ?variant=A   Launcher      — centered prompt that expands into an inline thread
 *   ?variant=B   Split canvas  — Codex-app: thread left, live artifact canvas right
 *   ?variant=C   Terminal      — Codex-CLI-style monospace REPL
 *
 * Floating bottom-center switcher cycles variants (←/→). Real tokens
 * (player.css) + real data (catalog/resume); only the view markup is
 * prototype-local. Sub-shape B (new route) because the landing swaps the whole
 * surface — the production layout can't host that per-variant. Delete this
 * folder once a winner is folded into `index.astro`; see `_NOTES.md`.
 */
import '../../styles/player.css';
import AgentSwitcher from './_AgentSwitcher.astro';
import VariantA from './_AgentVariantA.astro';
import VariantB from './_AgentVariantB.astro';
import VariantC from './_AgentVariantC.astro';

const VARIANTS = [
  { key: 'A', name: 'Launcher' },
  { key: 'B', name: 'Split canvas' },
  { key: 'C', name: 'Terminal' },
];
// Static project: the server can't vary by `?variant=`, so all three panes are
// rendered and toggled client-side via `body[data-variant]` (the switcher owns
// that). `data-variant` below is the no-JS / production fallback (B, the winner).
const showSwitch = !import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <title>Agent landing prototype</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="proto-agent-body" data-variant="B">
    <div class="vpane" data-v="A"><VariantA /></div>
    <div class="vpane" data-v="B"><VariantB /></div>
    <div class="vpane" data-v="C"><VariantC /></div>
    {showSwitch && <AgentSwitcher variants={VARIANTS} />}
    <script src="./_agentProto.client.ts"></script>
  </body>
</html>

<style is:global>
  /* Base reset/palette for the prototype body. Mirrors the `.player-body`
     reset so variants that don't wrap in `.player-body` (A/B/C) still get a
     clean dark surface, the right fonts, and no UA chrome. The body never
     scrolls — each variant owns its internal scroll region. */
  .proto-agent-body {
    margin: 0;
    height: 100vh;
    height: 100dvh;
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 13.5px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
  }
  .proto-agent-body *,
  .proto-agent-body *::before,
  .proto-agent-body *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .proto-agent-body a {
    color: inherit;
    text-decoration: none;
  }
  .proto-agent-body button {
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
  }
  /* Only the active variant pane shows; the switcher toggles body[data-variant].
     Each pane is full-height so the variant roots (height:100%) resolve. */
  .vpane {
    display: none;
    height: 100%;
  }
  .proto-agent-body[data-variant='A'] .vpane[data-v='A'],
  .proto-agent-body[data-variant='B'] .vpane[data-v='B'],
  .proto-agent-body[data-variant='C'] .vpane[data-v='C'],
  .proto-agent-body[data-variant='D'] .vpane[data-v='D'] {
    display: block;
  }
  /* Shared entrance the driver triggers on reveal. Transform-only on purpose:
     an opacity fade with fill-mode `both` leaves content INVISIBLE if the
     animation stalls (e.g. a throttled/occluded surface freezing the timeline
     mid-flight). Resting opacity stays 1, so a stalled entrance just shows the
     content shifted a few px — never hidden. Variants may override. */
  .proto-in {
    animation: proto-slide-in 0.32s ease both;
  }
  @keyframes proto-slide-in {
    from {
      transform: translateY(8px);
    }
  }
</style>
