---
/**
 * PROTOTYPE — throwaway, do not ship. Project card + icon exploration.
 *
 * Dylan dislikes the current project cards and the 2-letter hue album-art tile
 * ("icon"). This route shows four different card + icon design directions over
 * the same curated set of real projects, so they can be compared head-to-head.
 * The winner gets applied to the agent landing + project-detail prototypes.
 *
 *   ?variant=A   Screenshot   — image-led cards (real first screenshot, no tile)
 *   ?variant=B   Typographic  — no icon at all; type + hue accent rule
 *   ?variant=C   Line icon    — semantic inline-SVG glyph per `area`
 *   ?variant=D   Generative   — abstract generated mark from hue/id (not letters)
 *
 * Variant chosen client-side via `body[data-variant]` (static site — same
 * pattern as the other prototypes). Real data, real tokens; only the card
 * markup is prototype-local. See `_CARDS_NOTES.md`.
 */
import '../../styles/player.css';
import ProtoSwitcher from './_AgentSwitcher.astro';
import VariantA from './_CardsVariantA.astro';
import VariantB from './_CardsVariantB.astro';
import VariantC from './_CardsVariantC.astro';
import VariantD from './_CardsVariantD.astro';
import { getProjectById, type Project } from '../../data/catalog';

// Curated set: spans areas + statuses + shot kinds (wide img, phone img, and
// `hood` which has only skeleton shots → exercises the no-image fallback).
const IDS = ['exit-manager', 'agentic-trader', 'dog-log', 'homeserver', 'epl-ml', 'hood'];
const projects = IDS.map((id) => getProjectById(id)).filter((p): p is Project => Boolean(p));

const VARIANTS = [
  { key: 'A', name: 'Screenshot' },
  { key: 'B', name: 'Typographic' },
  { key: 'C', name: 'Line icon' },
  { key: 'D', name: 'Generative' },
];
const showSwitch = !import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <title>Card + icon prototype</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="proto-doc-body" data-variant="B">
    <div class="vpane" data-v="A"><VariantA projects={projects} /></div>
    <div class="vpane" data-v="B"><VariantB projects={projects} /></div>
    <div class="vpane" data-v="C"><VariantC projects={projects} /></div>
    <div class="vpane" data-v="D"><VariantD projects={projects} /></div>
    {showSwitch && <ProtoSwitcher variants={VARIANTS} />}
  </body>
</html>

<style is:global>
  .proto-doc-body {
    margin: 0;
    min-height: 100dvh;
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  .proto-doc-body *,
  .proto-doc-body *::before,
  .proto-doc-body *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .proto-doc-body a {
    color: inherit;
    text-decoration: none;
  }
  .proto-doc-body button {
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
  }
  .vpane {
    display: none;
  }
  .proto-doc-body[data-variant='A'] .vpane[data-v='A'],
  .proto-doc-body[data-variant='B'] .vpane[data-v='B'],
  .proto-doc-body[data-variant='C'] .vpane[data-v='C'],
  .proto-doc-body[data-variant='D'] .vpane[data-v='D'] {
    display: block;
  }
</style>
