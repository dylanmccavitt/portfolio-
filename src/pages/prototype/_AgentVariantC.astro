---
/**
 * PROTOTYPE — throwaway, do not ship. Variant C: "Terminal".
 *
 * A full-screen monospace Codex-CLI-style REPL. The whole surface is
 * `--pl-mono`: faux window chrome, a boot banner + greeting + runnable
 * suggested commands as the empty state, and a persistent `eve ❯` prompt line
 * pinned to the bottom. Each turn echoes the command, prints a tool-call
 * trace, then renders the answer in terminal idiom (project "records",
 * a résumé tree, aligned contact key/values). Reveal/streaming is owned by the
 * shared driver (`_agentProto.client.ts`); the only local JS is cosmetic
 * (auto-sizing input + blinking block caret). Self-contained, scoped styles.
 */
import {
  AGENT_NAME,
  GREETING,
  SUBGREETING,
  SUGGESTED,
  CONVERSATION,
  CONTACT,
  projectById,
  trackById,
} from './_agentData';

/** Leading tool name of a trace line ("search_catalog({…})" → "search_catalog"). */
const toolName = (line: string): string => line.split(/[(·]/)[0].trim();

/** Distinct tool names for the collapsed "# used: …" line. */
const usedTools = (trace: string[]): string => {
  const seen = new Set<string>();
  for (const l of trace) seen.add(toolName(l));
  return [...seen].join(', ');
};

/** Box-block "EVE" wordmark for the boot banner. */
const WORDMARK = [
  '█████ █   █ █████',
  '█     █   █ █    ',
  '████  █   █ ████ ',
  '█      █ █  █    ',
  '█████   █   █████',
].join('\n');

const ghDisplay = CONTACT.github.replace(/^https?:\/\//, '');
const promptName = AGENT_NAME.toLowerCase();
---

<div class="term" data-proto-root>
  <!-- faux window chrome -->
  <header class="chrome">
    <span class="dots" aria-hidden="true"><i class="r"></i><i class="y"></i><i class="g"></i></span>
    <span class="win-title">{promptName} — portfolio agent</span>
    <button type="button" class="clear-btn" data-proto-reset aria-label="Clear the session">clear</button>
  </header>

  <!-- scroll region (the "screen") -->
  <div class="screen">
    <!-- empty state: boot banner + greeting + runnable commands -->
    <section class="boot" data-proto-empty>
      <pre class="banner" aria-label="eve">{WORDMARK}</pre>
      <p class="banner-sub">{promptName} · portfolio agent · v0.1</p>

      <div class="boot-log" aria-hidden="true">
        <div><span class="prx">$</span> npx eve@latest --portfolio</div>
        <div><span class="chk">✔</span> agent loaded · instructions.md</div>
        <div><span class="chk">✔</span> tools · search_catalog · read_resume · get_contact</div>
        <div><span class="chk">✔</span> ready in 0.42s — ask me anything about dylan</div>
      </div>

      <div class="comments">
        <p class="cmt"># {GREETING}</p>
        <p class="cmt"># {SUBGREETING}</p>
      </div>

      <p class="cmd-head"># available commands — click one to run, or type your own below:</p>
      <div class="chips">
        {
          SUGGESTED.map((p) => (
            <button type="button" class="cmd-chip" data-proto-send data-turn={p.id}>
              <span class="run">try ▸</span>
              <span class="lbl">{p.label}</span>
              {p.hint && <span class="tool"># {p.hint}</span>}
            </button>
          ))
        }
      </div>
    </section>

    <!-- conversation output -->
    <div class="thread" data-proto-thread>
      {
        CONVERSATION.map((turn) => (
          <article class="turn" data-proto-turn={turn.id} hidden>
            <p class="cmd" data-proto-user>{turn.q}</p>

            <div class="typing" data-proto-typing>
              {turn.trace.map((l) => (
                <div class="trace-run">
                  <span class="tri">▸</span> running <b>{toolName(l)}</b>…
                </div>
              ))}
              <span class="pulse" aria-hidden="true"></span>
            </div>

            <div class="answer" data-proto-answer hidden>
              <details class="used">
                <summary># used: {usedTools(turn.trace)}</summary>
                <div class="trace-full">
                  {turn.trace.map((l) => (
                    <div>→ {l}</div>
                  ))}
                </div>
              </details>

              {turn.answer.map((block) => (
                <>
                  {block.kind === 'text' && <p class="out">{block.text}</p>}

                  {block.kind === 'projects' && (
                    <div class="records">
                      {block.ids.map((id) => {
                        const p = projectById(id);
                        return (
                          <a class="rec" href={`/projects/${p.id}`} style={`--hue:${p.hue}`}>
                            <span class="rec-head">
                              <span class="sym">{p.sym}</span>
                              <span class="rec-title">{p.title}</span>
                              <span class={`badge ${p.status[0]}`}>[{p.status[1].toUpperCase()}]</span>
                              <span class="goto">→ /projects/{p.id}</span>
                            </span>
                            <span class="rec-line">{p.line}</span>
                          </a>
                        );
                      })}
                    </div>
                  )}

                  {block.kind === 'resume' && (
                    <div class="tree">
                      {block.trackIds.map((tid, i) => {
                        const t = trackById(tid);
                        const last = i === block.trackIds.length - 1;
                        return (
                          <div class="tree-row" style={`--hue:${t.hue}`}>
                            <span class="branch">{last ? '└─' : '├─'}</span>
                            <span class="dot" aria-hidden="true">●</span>
                            <span class="when">{t.when}</span>
                            <span class="ttl">{t.title}</span>
                            <span class="emdash">—</span>
                            <span class="role">{t.role}</span>
                            {t.current && <span class="cur">● now</span>}
                          </div>
                        );
                      })}
                    </div>
                  )}

                  {block.kind === 'contact' && (
                    <div class="kv">
                      <div class="kv-row">
                        <span class="k">email</span><span class="sep">:</span>
                        <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
                      </div>
                      <div class="kv-row">
                        <span class="k">github</span><span class="sep">:</span>
                        <a href={CONTACT.github}>{ghDisplay}</a>
                      </div>
                      <div class="kv-row">
                        <span class="k">resume</span><span class="sep">:</span>
                        <a href={CONTACT.resume}>{CONTACT.resume}</a>
                      </div>
                      <div class="kv-row">
                        <span class="k">location</span><span class="sep">:</span>
                        <span class="v">{CONTACT.location}</span>
                      </div>
                      <div class="kv-row">
                        <span class="k">status</span><span class="sep">:</span>
                        <span class="v ok">{CONTACT.status}</span>
                      </div>
                    </div>
                  )}

                  {block.kind === 'links' && (
                    <div class="chips next-chips">
                      {block.items.map(([label, href]) => (
                        <a class="cmd-chip" href={href}>
                          <span class="run">open ▸</span>
                          <span class="lbl">{label}</span>
                        </a>
                      ))}
                    </div>
                  )}
                </>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- persistent live REPL prompt -->
  <form class="prompt-line" data-proto-form>
    <span class="ps1"><span class="ps-name">{promptName}</span> <span class="ps-arrow">❯</span></span>
    <span class="input-wrap">
      <input
        class="cmd-input"
        data-proto-input
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Ask Eve about Dylan's work — type a question and press Enter"
      />
      <span class="caret" aria-hidden="true"></span>
      <span class="hint" aria-hidden="true">type a question and hit ⏎</span>
    </span>
    <span class="term-ghost" data-term-ghost aria-hidden="true"></span>
  </form>
</div>

<style>
  .term {
    height: 100%;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: var(--pl-mono);
    font-size: 13px;
    line-height: 1.65;
    overflow: hidden;
  }
  .term * { box-sizing: border-box; }

  /* ---- window chrome ---- */
  .chrome {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    background: var(--pl-side);
    border-bottom: 1px solid var(--pl-line);
  }
  .dots { display: flex; gap: 7px; }
  .dots i { display: block; width: 11px; height: 11px; border-radius: 50%; }
  .dots .r { background: #ff5f57; }
  .dots .y { background: #febc2e; }
  .dots .g { background: #28c840; }
  .win-title { flex: 1; text-align: center; color: var(--pl-faint); font-size: 12px; letter-spacing: 0.4px; }
  .clear-btn {
    color: var(--pl-faint);
    font-size: 12px;
    padding: 3px 9px;
    border: 1px solid var(--pl-line);
    border-radius: 6px;
  }
  .clear-btn::before { content: '⌫ '; opacity: 0.7; }
  .clear-btn:hover { color: var(--pl-text); border-color: var(--pl-faint); background: var(--pl-panel); }

  /* ---- the "screen" (internal scroll region) ---- */
  .screen {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 18px 18px 8px;
    scroll-behavior: smooth;
  }

  /* ---- boot / empty state ---- */
  .banner {
    margin: 2px 0 2px;
    color: var(--pl-accent);
    font-size: 13px;
    line-height: 1.15;
    white-space: pre;
    overflow-x: auto;
  }
  .banner-sub { color: var(--pl-faint); font-size: 12px; margin-bottom: 14px; }
  .boot-log { display: grid; gap: 2px; margin-bottom: 14px; color: var(--pl-dim); }
  .boot-log .prx { color: var(--pl-accent); }
  .boot-log .chk { color: var(--pl-green); }
  .comments { margin-bottom: 16px; }
  .cmt { color: var(--pl-faint); max-width: 82ch; padding-left: 2ch; text-indent: -2ch; }
  .cmt + .cmt { margin-top: 4px; }
  .cmd-head { color: var(--pl-dim); margin-bottom: 8px; }

  /* ---- runnable command chips (empty + fallback) ---- */
  .chips { display: grid; gap: 3px; }
  .cmd-chip {
    display: flex;
    align-items: baseline;
    gap: 10px;
    width: 100%;
    text-align: left;
    padding: 5px 10px;
    border: 1px solid transparent;
    border-radius: 7px;
    color: var(--pl-text);
    font: inherit;
  }
  .cmd-chip:hover { background: var(--pl-panel); border-color: var(--pl-tile-line); }
  .cmd-chip .run { flex-shrink: 0; color: var(--pl-green); }
  .cmd-chip .lbl { flex: 1; }
  .cmd-chip .tool { flex-shrink: 0; color: var(--pl-faint); font-size: 11.5px; }
  .next-chips { margin-top: 6px; }

  /* ---- thread / turns ---- */
  .turn { padding: 12px 0 6px; }
  .turn + .turn { border-top: 1px dashed var(--pl-line); }
  .cmd { color: var(--pl-text); word-break: break-word; }
  .cmd::before { content: 'eve ❯ '; color: var(--pl-green); }

  .typing { margin: 6px 0; display: grid; gap: 2px; color: var(--pl-dim); }
  .trace-run .tri { color: var(--pl-green); }
  .trace-run b { color: var(--pl-accent); font-weight: 500; }
  .pulse {
    display: inline-block;
    width: 0.6ch;
    height: 1.05em;
    margin-top: 3px;
    background: var(--pl-green);
    animation: blink 1s step-end infinite;
  }

  .answer { display: grid; gap: 11px; margin: 7px 0 2px; }
  .used { color: var(--pl-faint); font-size: 12px; }
  .used summary { cursor: pointer; list-style: none; color: var(--pl-faint); }
  .used summary::-webkit-details-marker { display: none; }
  .used summary::before { content: '▸ '; }
  .used[open] summary::before { content: '▾ '; }
  .trace-full { margin: 4px 0 0 2ch; display: grid; gap: 2px; color: var(--pl-faint); }

  .out { color: var(--pl-text); max-width: 82ch; word-break: break-word; }

  /* ---- project "records" ---- */
  .records { display: grid; gap: 8px; }
  .rec {
    display: block;
    padding: 9px 12px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-left: 3px solid var(--hue, var(--pl-accent));
    border-radius: 8px;
    transition: background 0.12s, border-color 0.12s;
  }
  .rec:hover { background: var(--pl-panel); border-color: var(--hue, var(--pl-accent)); }
  .rec-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .sym {
    flex-shrink: 0;
    padding: 1px 6px;
    border: 1px solid var(--hue, var(--pl-accent));
    border-radius: 5px;
    color: var(--hue, var(--pl-accent));
    background: var(--pl-panel-hi);
    background: color-mix(in srgb, var(--hue, var(--pl-accent)) 13%, transparent);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .rec-title { color: var(--pl-text); font-weight: 500; }
  /* terminal-tag override of the global pill `.badge` — keep the kind color, drop the pill */
  .rec .badge {
    padding: 0;
    border-radius: 0;
    background: transparent !important;
    font-family: var(--pl-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.4px;
    text-transform: none;
  }
  .goto { margin-left: auto; color: var(--pl-faint); font-size: 12px; white-space: nowrap; }
  .rec:hover .goto { color: var(--pl-text); }
  .rec-line { display: block; margin-top: 5px; color: var(--pl-dim); font-size: 12.5px; max-width: 80ch; }

  /* ---- résumé tree ---- */
  .tree { display: grid; gap: 3px; padding-left: 2px; }
  .tree-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .tree-row .branch { color: var(--pl-faint); }
  .tree-row .dot { color: var(--hue, var(--pl-accent)); font-size: 9px; }
  .tree-row .when { display: inline-block; min-width: 13ch; color: var(--pl-faint); }
  .tree-row .ttl { color: var(--pl-text); font-weight: 500; }
  .tree-row .emdash { color: var(--pl-faint); }
  .tree-row .role { color: var(--pl-dim); }
  .tree-row .cur { color: var(--pl-green); font-size: 11.5px; }

  /* ---- contact key/value ---- */
  .kv { display: grid; gap: 3px; }
  .kv-row { display: flex; gap: 8px; align-items: baseline; flex-wrap: wrap; }
  .kv .k { display: inline-block; min-width: 9ch; color: var(--pl-faint); }
  .kv .sep { color: var(--pl-faint); }
  .kv .v { color: var(--pl-text); }
  .kv .v.ok { color: var(--pl-green); }
  .kv a { color: var(--pl-focus); }
  .kv a:hover { text-decoration: underline; }

  /* ---- persistent prompt line ---- */
  .prompt-line {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.8ch;
    padding: 13px 18px calc(13px + env(safe-area-inset-bottom, 0px));
    border-top: 1px solid var(--pl-line);
    background: var(--pl-side);
    position: relative;
  }
  .ps1 { flex-shrink: 0; white-space: nowrap; }
  .ps-name { color: var(--pl-accent); }
  .ps-arrow { color: var(--pl-green); }
  .input-wrap { flex: 1; min-width: 0; display: flex; align-items: center; }
  .cmd-input {
    width: 0;
    max-width: 100%;
    padding: 0;
    border: 0;
    outline: none;
    background: transparent;
    color: var(--pl-text);
    font: inherit;
    caret-color: transparent;
  }
  .caret {
    display: inline-block;
    width: 0.62ch;
    height: 1.05em;
    margin-left: 1px;
    background: var(--pl-green);
    animation: blink 1s step-end infinite;
  }
  .hint {
    margin-left: 1.2ch;
    color: var(--pl-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .has-text .hint { display: none; }
  .term-ghost {
    position: absolute;
    left: -9999px;
    top: 0;
    visibility: hidden;
    white-space: pre;
    font: inherit;
  }

  /* driver toggles: hide the empty state once a turn fires */
  .proto-started [data-proto-empty] { display: none; }

  @keyframes blink { 50% { opacity: 0; } }

  /* a11y focus ring (we're outside .player-body) */
  .term a:focus-visible,
  .term button:focus-visible,
  .term input:focus-visible {
    outline: 2px solid var(--pl-focus);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* ---- mobile (≤820px): smaller type, single column ---- */
  @media (max-width: 820px) {
    .term { font-size: 12px; }
    .screen { padding: 14px 12px 6px; }
    .banner { font-size: 11px; }
    .rec-head { gap: 7px; }
    .goto { margin-left: 0; width: 100%; }
    .tree-row .when { min-width: 0; }
    .prompt-line { padding: 11px 12px calc(11px + env(safe-area-inset-bottom, 0px)); }
    .hint { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret, .pulse { animation: none; }
    .screen { scroll-behavior: auto; }
  }
</style>

<script>
  // Cosmetic only: auto-size the input so the block caret hugs the typed text,
  // and focus on desktop. The conversation reveal is owned by the shared driver.
  const root = document.querySelector<HTMLElement>('[data-proto-root].term');
  if (root) {
    const input = root.querySelector<HTMLInputElement>('[data-proto-input]');
    const ghost = root.querySelector<HTMLElement>('[data-term-ghost]');
    const form = root.querySelector<HTMLFormElement>('[data-proto-form]');
    if (input && ghost && form) {
      const sync = (): void => {
        ghost.textContent = input.value;
        input.style.width = ghost.offsetWidth + 'px';
        form.classList.toggle('has-text', input.value.length > 0);
      };
      input.addEventListener('input', sync);
      // driver clears the value on submit; resync after its handler runs
      form.addEventListener('submit', () => window.setTimeout(sync, 0));
      form.addEventListener('mousedown', (e) => {
        if (e.target !== input) {
          e.preventDefault();
          input.focus();
        }
      });
      sync();
      if (window.matchMedia('(min-width: 821px)').matches) input.focus();
    }
  }
</script>
