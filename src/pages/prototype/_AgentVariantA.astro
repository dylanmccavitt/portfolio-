---
/**
 * PROTOTYPE — throwaway, do not ship.
 *
 * Variant A · "Launcher" — a single centered prompt box (the ChatGPT/Claude
 * empty-state feel) that, once you ask something, collapses into a scrolling
 * thread with the composer docked at the bottom. No sidebars, no panels: one
 * 720px column, the antithesis of an app shell.
 *
 * Layout/flow only; the reveal + streaming beat comes from the shared driver
 * (`_agentProto.client.ts`) via the `data-proto-*` hooks below.
 */
import {
  AGENT_NAME,
  GREETING,
  SUBGREETING,
  SUGGESTED,
  CONVERSATION,
  CONTACT,
  projectById,
  trackById,
} from './_agentData';

const githubLabel = CONTACT.github.replace(/^https?:\/\//, '');
---

<section class="lc" data-proto-root aria-label={`${AGENT_NAME} — Dylan's portfolio agent`}>
  {/* ---- empty state: centered hero ---- */}
  <div class="lc-hero" data-proto-empty>
    <div class="lc-hero-in">
      <div class="lc-avatar lc-avatar-lg" aria-hidden="true">E</div>
      <h1 class="lc-greeting">{GREETING}</h1>
      <p class="lc-sub">{SUBGREETING}</p>
    </div>
  </div>

  {/* ---- conversation thread (scrolls once started) ---- */}
  <div class="lc-thread" data-proto-thread role="log" aria-live="polite" aria-relevant="additions">
    <div class="lc-thread-in">
      {
        CONVERSATION.map((turn) => (
          <article class="lc-turn" data-proto-turn={turn.id} hidden>
            {/* visitor question */}
            <div class="lc-row lc-row-user">
              <p class="lc-bubble lc-user" data-proto-user>{turn.q}</p>
            </div>

            {/* agent reply */}
            <div class="lc-row lc-row-eve">
              <div class="lc-avatar lc-avatar-sm" aria-hidden="true">E</div>
              <div class="lc-eve">
                <div class="lc-who">{AGENT_NAME}</div>

                {/* thinking beat: 3-dot pulse + first trace line */}
                <div class="lc-typing" data-proto-typing>
                  <span class="lc-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                  <span class="lc-typing-line">{turn.trace[0]}</span>
                </div>

                {/* answer body (driver un-hides after the beat) */}
                <div class="lc-answer" data-proto-answer hidden>
                  <details class="lc-tools">
                    <summary>
                      <span class="lc-check">✓</span>
                      Used {turn.trace.length} tool{turn.trace.length === 1 ? '' : 's'}
                    </summary>
                    <div class="lc-trace">
                      {turn.trace.map((t) => <span>{t}</span>)}
                    </div>
                  </details>

                  {
                    turn.answer.map((block) => {
                      if (block.kind === 'text') {
                        return <p class="lc-prose">{block.text}</p>;
                      }
                      if (block.kind === 'projects') {
                        return (
                          <div class="lc-cards">
                            {block.ids.map((id) => {
                              const p = projectById(id);
                              return (
                                <a class="lc-card" href={`/projects/${p.id}`} style={`--a:${p.hue}`}>
                                  <div class="art lc-card-art">{p.sym.toUpperCase()}</div>
                                  <div class="lc-card-body">
                                    <div class="lc-card-head">
                                      <b>{p.title}</b>
                                      <span class={`badge ${p.status[0]}`}>{p.status[1]}</span>
                                    </div>
                                    <div class="lc-card-area">{p.area}</div>
                                    <p class="lc-card-line">{p.line}</p>
                                    {p.metrics[0] && (
                                      <div class="lc-card-metric">
                                        <b>{p.metrics[0][0]}</b> {p.metrics[0][1]}
                                      </div>
                                    )}
                                  </div>
                                  <span class="lc-card-go" aria-hidden="true">→</span>
                                </a>
                              );
                            })}
                          </div>
                        );
                      }
                      if (block.kind === 'resume') {
                        return (
                          <div class="lc-resume">
                            {block.trackIds.map((id) => {
                              const t = trackById(id);
                              return (
                                <div class="lc-track" style={`--a:${t.hue}`}>
                                  <div class="art lc-track-art">{t.sym.toUpperCase()}</div>
                                  <div class="lc-track-body">
                                    <b>{t.title}</b>
                                    <span class="lc-track-role">{t.role}</span>
                                  </div>
                                  {t.current && <span class="badge live">Now</span>}
                                  <span class="lc-track-when">{t.when}</span>
                                </div>
                              );
                            })}
                          </div>
                        );
                      }
                      if (block.kind === 'contact') {
                        return (
                          <div class="lc-contact">
                            <a class="lc-contact-row" href={`mailto:${CONTACT.email}`}>
                              <span class="k">Email</span>
                              <span class="v lc-mono">{CONTACT.email}</span>
                            </a>
                            <a class="lc-contact-row" href={CONTACT.github}>
                              <span class="k">GitHub</span>
                              <span class="v lc-mono">{githubLabel}</span>
                            </a>
                            <a class="lc-contact-row" href={CONTACT.resume}>
                              <span class="k">Résumé</span>
                              <span class="v">Download PDF ↗</span>
                            </a>
                            <div class="lc-contact-pills">
                              <span class="badge done">{CONTACT.location}</span>
                              <span class="badge live">{CONTACT.status}</span>
                            </div>
                          </div>
                        );
                      }
                      // kind === 'links' → fallback. items is empty here, so the
                      // SUGGESTED prompts become the next-step chips.
                      return (
                        <div class="lc-chips lc-chips-inline">
                          {block.items.length > 0
                            ? block.items.map(([label, href]) => (
                                <a class="lc-chip" href={href}>{label}</a>
                              ))
                            : SUGGESTED.map((p) => (
                                <button class="lc-chip" type="button" data-proto-send data-turn={p.id}>
                                  {p.label}
                                </button>
                              ))}
                        </div>
                      );
                    })
                  }
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  {/* ---- composer: centered in the hero group, then docks to the bottom ---- */}
  <div class="lc-dock">
    <div class="lc-dock-in">
      <button class="lc-newchat" type="button" data-proto-reset>
        <span aria-hidden="true">＋</span> New chat
      </button>

      <form class="lc-composer" data-proto-form>
        <input
          class="lc-input"
          data-proto-input
          type="text"
          name="q"
          placeholder="Ask about Dylan…"
          autocomplete="off"
          aria-label="Ask Eve about Dylan"
        />
        <button class="lc-send" type="submit" aria-label="Send">↑</button>
      </form>

      <div class="lc-chips lc-chips-empty">
        {
          SUGGESTED.map((p) => (
            <button class="lc-chip" type="button" data-proto-send data-turn={p.id}>
              {p.label}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ---------- shell: one centered column, owns its own scroll ---------- */
  .lc {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: relative;
  }
  /* empty state: vertically center the hero + composer group */
  .lc:not(.proto-started) {
    justify-content: center;
  }

  /* ---------- hero (empty state) ---------- */
  .lc-hero {
    text-align: center;
  }
  .lc.proto-started .lc-hero {
    display: none;
  }
  .lc-hero-in {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .lc-avatar {
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--pl-sans);
    font-weight: 700;
    color: var(--pl-accent);
    background:
      radial-gradient(120% 120% at 30% 25%, #8b7cf63a, #8b7cf614 60%, transparent);
    border: 1px solid #8b7cf64a;
  }
  .lc-avatar-lg {
    width: 58px;
    height: 58px;
    font-size: 24px;
    margin: 0 auto 20px;
  }
  .lc-greeting {
    font-size: clamp(19px, 2.6vw, 25px);
    font-weight: 600;
    line-height: 1.34;
    letter-spacing: -0.012em;
    color: var(--pl-text);
  }
  .lc-sub {
    margin-top: 12px;
    color: var(--pl-dim);
    font-size: 14px;
    line-height: 1.5;
  }

  /* ---------- thread (scrolls once started) ---------- */
  .lc-thread {
    display: none;
  }
  .lc.proto-started .lc-thread {
    display: block;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scroll-padding-top: 20px;
  }
  .lc-thread-in {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 20px 32px;
  }

  .lc-turn {
    padding-bottom: 30px;
  }
  .lc-turn[hidden] {
    display: none;
  }
  .lc-turn + .lc-turn {
    border-top: 1px solid var(--pl-line);
    padding-top: 26px;
  }

  /* user bubble (right) */
  .lc-row-user {
    display: flex;
    justify-content: flex-end;
  }
  .lc-user {
    max-width: 80%;
    background: var(--pl-panel-hi);
    border: 1px solid var(--pl-line);
    border-radius: 15px 15px 4px 15px;
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--pl-text);
  }

  /* agent reply (left, with avatar) */
  .lc-row-eve {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-top: 18px;
  }
  .lc-avatar-sm {
    width: 30px;
    height: 30px;
    font-size: 13px;
    flex-shrink: 0;
  }
  .lc-eve {
    flex: 1;
    min-width: 0;
  }
  .lc-who {
    font-size: 12px;
    font-weight: 600;
    color: var(--pl-dim);
    margin-bottom: 4px;
  }

  /* thinking beat */
  .lc-typing {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-faint);
  }
  .lc-typing[hidden] {
    display: none;
  }
  .lc-typing-line {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lc-dots {
    display: inline-flex;
    gap: 4px;
    flex-shrink: 0;
  }
  .lc-dots i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pl-accent);
    animation: lc-pulse 1.2s ease-in-out infinite;
  }
  .lc-dots i:nth-child(2) {
    animation-delay: 0.18s;
  }
  .lc-dots i:nth-child(3) {
    animation-delay: 0.36s;
  }
  @keyframes lc-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: translateY(0);
    }
    50% {
      opacity: 1;
      transform: translateY(-3px);
    }
  }

  /* answer body */
  .lc-answer[hidden] {
    display: none;
  }
  .lc-answer > * + * {
    margin-top: 12px;
  }
  .lc-prose {
    font-size: 14px;
    line-height: 1.62;
    color: var(--pl-text);
  }

  /* collapsed "used N tools" line */
  .lc-tools {
    font-family: var(--pl-mono);
    font-size: 11px;
  }
  .lc-tools summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--pl-faint);
    user-select: none;
  }
  .lc-tools summary::-webkit-details-marker {
    display: none;
  }
  .lc-tools summary:hover {
    color: var(--pl-dim);
  }
  .lc-check {
    color: var(--pl-green);
  }
  .lc-trace {
    margin-top: 7px;
    display: grid;
    gap: 4px;
    margin-left: 4px;
    padding-left: 11px;
    border-left: 1px solid var(--pl-line);
  }
  .lc-trace span {
    color: var(--pl-faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ---------- project cards (compact horizontal) ---------- */
  .lc-cards {
    display: grid;
    gap: 8px;
  }
  .lc-card {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 11px 13px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 12px;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      transform 0.15s ease;
  }
  .lc-card:hover {
    border-color: var(--a, var(--pl-accent));
    background: var(--pl-panel-hi);
    transform: translateY(-1px);
  }
  .lc-card-art {
    width: 44px;
    height: 44px;
    font-size: 15px;
    border-radius: 10px;
  }
  .lc-card-body {
    flex: 1;
    min-width: 0;
  }
  .lc-card-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .lc-card-head b {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--pl-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lc-card-area {
    margin-top: 1px;
    font-size: 11px;
    color: var(--pl-faint);
  }
  .lc-card-line {
    margin-top: 5px;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--pl-dim);
  }
  .lc-card-metric {
    margin-top: 7px;
    font-family: var(--pl-mono);
    font-size: 11.5px;
    color: var(--pl-faint);
  }
  .lc-card-metric b {
    color: var(--pl-text);
    font-weight: 500;
  }
  .lc-card-go {
    align-self: center;
    flex-shrink: 0;
    color: var(--pl-faint);
    font-size: 15px;
    transition: transform 0.15s ease, color 0.15s ease;
  }
  .lc-card:hover .lc-card-go {
    color: var(--a, var(--pl-accent));
    transform: translateX(2px);
  }

  /* ---------- résumé rows ---------- */
  .lc-resume {
    display: grid;
    gap: 6px;
  }
  .lc-track {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 10px;
  }
  .lc-track-art {
    width: 36px;
    height: 36px;
    font-size: 13px;
    border-radius: 8px;
  }
  .lc-track-body {
    flex: 1;
    min-width: 0;
  }
  .lc-track-body b {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--pl-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lc-track-role {
    font-size: 11.5px;
    color: var(--pl-faint);
  }
  .lc-track-when {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
    white-space: nowrap;
  }

  /* ---------- contact ---------- */
  .lc-contact {
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 12px;
    padding: 6px;
    display: grid;
    gap: 2px;
  }
  .lc-contact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 10px 11px;
    border-radius: 8px;
    transition: background 0.12s ease;
  }
  .lc-contact-row:hover {
    background: var(--pl-panel-hi);
  }
  .lc-contact-row .k {
    font-size: 10.5px;
    letter-spacing: 0.7px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .lc-contact-row .v {
    font-size: 13px;
    color: var(--pl-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .lc-mono {
    font-family: var(--pl-mono);
    font-size: 12px;
  }
  .lc-contact-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px 11px 4px;
  }

  /* ---------- composer dock ---------- */
  .lc-dock {
    flex-shrink: 0;
    padding: 16px 0 18px;
  }
  /* not-started: sits directly under the hero in the centered group */
  .lc:not(.proto-started) .lc-dock {
    margin-top: 28px;
  }
  /* started: pinned to the bottom with a hairline + blur */
  .lc.proto-started .lc-dock {
    padding: 12px 0 16px;
    border-top: 1px solid var(--pl-line);
    background: color-mix(in srgb, var(--pl-bg) 86%, transparent);
    backdrop-filter: blur(10px);
  }
  .lc-dock-in {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .lc-newchat {
    display: none;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
    padding: 5px 12px;
    font-size: 12px;
    color: var(--pl-dim);
    border: 1px solid var(--pl-line);
    border-radius: 99px;
    transition: all 0.15s ease;
  }
  .lc.proto-started .lc-newchat {
    display: inline-flex;
  }
  .lc-newchat:hover {
    color: var(--pl-text);
    border-color: var(--pl-tile-line);
    background: var(--pl-panel);
  }

  .lc-composer {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 7px 7px 16px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 16px;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .lc-composer:focus-within {
    border-color: var(--pl-focus);
    box-shadow: 0 0 0 3px #8b7cf626;
  }
  .lc-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: none;
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 14.5px;
    padding: 8px 0;
  }
  .lc-input::placeholder {
    color: var(--pl-faint);
  }
  .lc-send {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 11px;
    background: var(--pl-accent);
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    transition: transform 0.12s ease, opacity 0.12s ease;
  }
  .lc-send:hover {
    transform: translateY(-1px);
  }
  .lc-send:active {
    transform: translateY(0);
  }

  /* ---------- chips ---------- */
  .lc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .lc-chips-empty {
    justify-content: center;
    margin-top: 16px;
  }
  /* the empty-state chips retire once a conversation starts */
  .lc.proto-started .lc-chips-empty {
    display: none;
  }
  .lc-chips-inline {
    justify-content: flex-start;
    margin-top: 4px;
  }
  .lc-chip {
    padding: 8px 13px;
    font-size: 12.5px;
    color: var(--pl-dim);
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 99px;
    transition: all 0.15s ease;
  }
  .lc-chip:hover {
    color: var(--pl-text);
    border-color: var(--pl-accent);
    background: var(--pl-panel-hi);
  }

  /* ---------- mobile (single column, tighter) ---------- */
  @media (max-width: 820px) {
    .lc-hero-in,
    .lc-thread-in,
    .lc-dock-in {
      padding-left: 14px;
      padding-right: 14px;
    }
    .lc-greeting {
      font-size: 20px;
    }
    .lc-user {
      max-width: 88%;
    }
    .lc:not(.proto-started) .lc-dock {
      margin-top: 22px;
    }
    .lc-card {
      flex-wrap: wrap;
    }
    .lc-card-go {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lc-dots i,
    .lc-card,
    .lc-send,
    .lc-card-go {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
