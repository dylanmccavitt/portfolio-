---
/**
 * PROTOTYPE — throwaway, do not ship.
 *
 * Variant B — "Split canvas" (Codex-app / IDE feel). A full-height app shell:
 * a persistent left sidebar (Eve identity + the agent's TS tool directory +
 * suggested prompts) and a main conversation pane. Structurally the opposite of
 * Variant A's bare centered column. The differentiator: each revealed turn lays
 * the agent's PROSE in a left text column and the RICH ARTIFACTS (large project
 * cards / résumé timeline / contact) in a right "canvas" column.
 *
 * Interaction is owned by the shared driver (`_agentProto.client.ts`); this file
 * only renders DOM and wires the `data-proto-*` hooks. No props, scoped styles.
 */
import {
  AGENT_NAME,
  GREETING,
  SUBGREETING,
  SUGGESTED,
  CONVERSATION,
  CONTACT,
  projectById,
  trackById,
} from './_agentData';

/** The agent's file-based tools — sells the Eve "an agent is a directory" pitch. */
const TOOLS = ['search_catalog', 'rank_projects', 'read_resume', 'filter_catalog', 'get_contact'];

/** Pre-split each turn's blocks into a prose stream (left) + artifact stream (right canvas). */
const TURNS = CONVERSATION.map((t) => ({
  ...t,
  prose: t.answer.filter((b) => b.kind === 'text' || b.kind === 'links'),
  artifacts: t.answer.filter((b) => b.kind === 'projects' || b.kind === 'resume' || b.kind === 'contact'),
}));
---

<div class="b-root" data-proto-root>
  <!-- ============ persistent left sidebar ============ -->
  <aside class="b-side">
    <div class="b-id">
      <span class="art b-monogram" style="--a: var(--pl-accent)">✦</span>
      <span class="b-id-text">
        <span class="b-id-name">{AGENT_NAME}</span>
        <span class="b-id-sub">portfolio agent</span>
      </span>
      <span class="b-id-dot" title="online" aria-hidden="true"></span>
    </div>

    <section class="b-section b-section--tools">
      <p class="b-label">Tools</p>
      <p class="b-path">agent/tools/</p>
      <ul class="b-tools">
        {
          TOOLS.map((t) => (
            <li class="b-tool">
              <span class="b-tool-glyph" aria-hidden="true">›</span>
              <code>{t}</code>
              <span class="b-tool-ext">.ts</span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="b-section b-section--grow b-section--suggest">
      <p class="b-label">Suggested</p>
      <ul class="b-suggest">
        {
          SUGGESTED.map((s) => (
            <li>
              <button class="b-suggest-row" data-proto-send data-turn={s.id} type="button">
                <span class="b-suggest-label">{s.label}</span>
                {s.hint && <span class="b-suggest-hint">{s.hint}</span>}
              </button>
            </li>
          ))
        }
      </ul>
    </section>

    <button class="b-reset" data-proto-reset type="button">
      <span aria-hidden="true">↺</span> New conversation
    </button>
  </aside>

  <!-- ============ main conversation pane ============ -->
  <main class="b-main">
    <header class="b-bar">
      <span class="b-bar-title">{AGENT_NAME} <span class="b-bar-sub">· portfolio agent</span></span>
      <span class="b-bar-status"><span class="b-id-dot" aria-hidden="true"></span> ready</span>
    </header>

    <div class="b-stage">
      <!-- empty state -->
      <div class="b-empty" data-proto-empty>
        <div class="b-card">
          <span class="art b-card-tile" style="--a: var(--pl-accent)">✦</span>
          <h1 class="b-greeting">{GREETING}</h1>
          <p class="b-subgreeting">{SUBGREETING}</p>
          <p class="b-hint">Pick a suggested prompt, or type your own below ↓</p>
        </div>
      </div>

      <!-- conversation thread -->
      <div class="b-thread" data-proto-thread>
        {
          TURNS.map((turn) => (
            <article class="b-turn" data-proto-turn={turn.id} hidden>
              <div class="b-user-row">
                <span class="b-user-tag">You</span>
                <p class="b-user" data-proto-user>{turn.q}</p>
              </div>

              <div class="b-typing" data-proto-typing>
                <div class="b-typing-head">
                  <span class="eq" aria-hidden="true"><i /><i /><i /></span>
                  {AGENT_NAME} is working…
                </div>
                <ul class="b-log">
                  {turn.trace.map((line, i) => (
                    <li class="b-log-line" style={`--i:${i}`}>
                      <span class="b-spin" aria-hidden="true" />
                      <code>{line}</code>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="b-answer" data-proto-answer hidden>
                <div class="b-answer-head">
                  <span class="b-eve-tag">{AGENT_NAME}</span>
                  <details class="b-used">
                    <summary>
                      <span class="b-check" aria-hidden="true">✓</span>
                      used {turn.trace.length} tool call{turn.trace.length === 1 ? '' : 's'}
                    </summary>
                    <ul class="b-used-list">
                      {turn.trace.map((line) => (
                        <li><code>{line}</code></li>
                      ))}
                    </ul>
                  </details>
                </div>

                <div class={`b-split${turn.artifacts.length ? '' : ' b-split--solo'}`}>
                  <div class="b-prose">
                    {turn.prose.map((block) =>
                      block.kind === 'text' ? (
                        <p class="b-p">{block.text}</p>
                      ) : block.kind === 'links' ? (
                        <div class="b-next">
                          <p class="b-next-label">Suggested next steps:</p>
                          <div class="b-next-chips">
                            {block.items.map(([label, href]) => (
                              <a class="b-chip" href={href}>
                                {label}
                              </a>
                            ))}
                          </div>
                        </div>
                      ) : null,
                    )}
                  </div>

                  {turn.artifacts.length > 0 && (
                    <div class="b-canvas">
                      <p class="b-canvas-label" aria-hidden="true">artifacts</p>
                      {turn.artifacts.map((block) =>
                        block.kind === 'projects' ? (
                          <div class="b-projs">
                            {block.ids.map((id) => {
                              const p = projectById(id);
                              return (
                                <a class="b-proj" href={`/projects/${p.id}`} style={`--a:${p.hue}`}>
                                  <div class="b-proj-head">
                                    <span class="art b-proj-tile">{p.sym}</span>
                                    <span class="b-proj-titles">
                                      <span class="b-proj-title">{p.title}</span>
                                      <span class="b-proj-area">{p.area}</span>
                                    </span>
                                    <span class={`badge ${p.status[0]}`}>{p.status[1]}</span>
                                  </div>
                                  <p class="b-proj-line">{p.line}</p>
                                  <div class="b-proj-stats">
                                    {p.metrics.slice(0, 2).map((m) => (
                                      <div class="stat">
                                        <b>{m[0]}</b>
                                        <span>{m[1]}</span>
                                      </div>
                                    ))}
                                  </div>
                                  <span class="b-proj-view">View project →</span>
                                </a>
                              );
                            })}
                          </div>
                        ) : block.kind === 'resume' ? (
                          <div class="b-resume">
                            {block.trackIds.map((id) => {
                              const tr = trackById(id);
                              return (
                                <div class="b-track" style={`--a:${tr.hue}`}>
                                  <span class="art b-track-tile">{tr.sym}</span>
                                  <span class="b-track-body">
                                    <span class="b-track-top">
                                      <span class="b-track-title">{tr.title}</span>
                                      {tr.current && <span class="badge live">Now</span>}
                                    </span>
                                    <span class="b-track-role">{tr.role}</span>
                                    <span class="b-track-when">{tr.when}</span>
                                  </span>
                                </div>
                              );
                            })}
                          </div>
                        ) : block.kind === 'contact' ? (
                          <div class="b-contact">
                            <a class="b-contact-row" href={`mailto:${CONTACT.email}`}>
                              <span class="b-contact-key">email</span>
                              <span class="b-contact-val">{CONTACT.email}</span>
                            </a>
                            <a class="b-contact-row" href={CONTACT.github} target="_blank" rel="noopener">
                              <span class="b-contact-key">github</span>
                              <span class="b-contact-val">{CONTACT.github.replace('https://', '')}</span>
                            </a>
                            <a class="b-contact-row" href={CONTACT.resume}>
                              <span class="b-contact-key">résumé</span>
                              <span class="b-contact-val">Download PDF →</span>
                            </a>
                            <div class="b-contact-row">
                              <span class="b-contact-key">based</span>
                              <span class="b-contact-val">{CONTACT.location}</span>
                            </div>
                            <div class="b-contact-row">
                              <span class="b-contact-key">status</span>
                              <span class="b-contact-val b-status">
                                <span class="b-id-dot" aria-hidden="true" />
                                {CONTACT.status}
                              </span>
                            </div>
                          </div>
                        ) : null,
                      )}
                    </div>
                  )}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- docked composer -->
    <form class="b-composer" data-proto-form>
      <div class="b-composer-inner">
        <span class="b-composer-glyph" aria-hidden="true">⌁</span>
        <input
          class="b-input"
          data-proto-input
          type="text"
          autocomplete="off"
          spellcheck="false"
          placeholder="Ask Eve about Dylan's work…"
          aria-label="Ask Eve about Dylan"
        />
        <button class="b-send" type="submit" aria-label="Send message">→</button>
      </div>
    </form>
  </main>
</div>

<style>
  /* ============ shell ============ */
  .b-root {
    height: 100%;
    height: 100dvh;
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: var(--pl-sans);
    overflow: hidden;
  }

  /* the driver toggles `hidden`; guard our own display rules so it always wins */
  .b-turn[hidden],
  .b-answer[hidden],
  .b-typing[hidden] {
    display: none !important;
  }

  /* ============ sidebar ============ */
  .b-side {
    background: var(--pl-side);
    border-right: 1px solid var(--pl-line);
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .b-id {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 16px 16px 14px;
    border-bottom: 1px solid var(--pl-line);
  }
  .b-monogram {
    width: 38px;
    height: 38px;
    font-size: 17px;
  }
  .b-id-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }
  .b-id-name {
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.2px;
  }
  .b-id-sub {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }
  .b-id-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pl-green);
    box-shadow: 0 0 0 3px #50c87822;
    flex: none;
  }

  .b-section {
    padding: 16px 16px 6px;
  }
  .b-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--pl-faint);
    font-weight: 600;
  }
  .b-path {
    font-family: var(--pl-mono);
    font-size: 10.5px;
    color: var(--pl-dim);
    margin-top: 3px;
  }
  .b-tools {
    list-style: none;
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .b-tool {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    border-radius: 7px;
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-dim);
    transition: background 0.15s, color 0.15s;
  }
  .b-tool:hover {
    background: var(--pl-panel);
    color: var(--pl-text);
  }
  .b-tool-glyph {
    color: var(--pl-accent);
  }
  .b-tool code {
    color: inherit;
  }
  .b-tool-ext {
    margin-left: auto;
    font-size: 10.5px;
    color: var(--pl-faint);
  }

  .b-section--grow {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding-bottom: 12px;
  }
  .b-suggest {
    list-style: none;
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
    min-height: 0;
  }
  .b-suggest-row {
    width: 100%;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 9px 11px;
    border-radius: 9px;
    border: 1px solid transparent;
    background: var(--pl-panel);
    transition: border-color 0.15s, background 0.15s, transform 0.12s;
  }
  .b-suggest-row:hover {
    border-color: var(--pl-accent);
    background: var(--pl-panel-hi);
    transform: translateX(2px);
  }
  .b-suggest-label {
    font-size: 12.5px;
    color: var(--pl-text);
    line-height: 1.35;
  }
  .b-suggest-hint {
    font-family: var(--pl-mono);
    font-size: 10px;
    color: var(--pl-faint);
  }

  .b-reset {
    margin-top: auto;
    padding: 13px 16px;
    border-top: 1px solid var(--pl-line);
    font-family: var(--pl-mono);
    font-size: 11.5px;
    color: var(--pl-dim);
    text-align: left;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.15s, background 0.15s;
  }
  .b-reset:hover {
    color: var(--pl-text);
    background: var(--pl-panel);
  }

  /* ============ main pane ============ */
  .b-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
  }
  .b-bar {
    flex: none;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 22px;
    border-bottom: 1px solid var(--pl-line);
    background: var(--pl-bg);
  }
  .b-bar-title {
    font-weight: 600;
    font-size: 13.5px;
  }
  .b-bar-sub {
    color: var(--pl-dim);
    font-weight: 400;
  }
  .b-bar-status {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }

  .b-stage {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  /* empty state */
  .b-empty {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 28px;
  }
  .b-root.proto-started .b-empty {
    display: none;
  }
  .b-card {
    max-width: 480px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 13px;
  }
  .b-card-tile {
    width: 54px;
    height: 54px;
    font-size: 24px;
  }
  .b-greeting {
    font-size: 19px;
    font-weight: 600;
    line-height: 1.45;
    color: var(--pl-text);
    text-wrap: balance;
  }
  .b-subgreeting {
    font-size: 13.5px;
    color: var(--pl-dim);
    line-height: 1.5;
  }
  .b-hint {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
    margin-top: 4px;
  }

  /* thread (internal scroll region) */
  .b-thread {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    padding: 22px 28px 30px;
  }
  .b-turn {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 1080px;
    padding-bottom: 24px;
    margin-bottom: 22px;
    border-bottom: 1px solid var(--pl-line);
  }
  .b-turn:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .b-user-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .b-user-tag {
    font-family: var(--pl-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--pl-faint);
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    padding: 2px 7px;
    border-radius: 6px;
    flex: none;
  }
  .b-user {
    font-size: 15.5px;
    font-weight: 600;
    color: var(--pl-text);
    line-height: 1.4;
  }

  /* thinking / tool-call log */
  .b-typing {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 12px;
    padding: 14px 16px;
    max-width: 560px;
  }
  .b-typing-head {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 12.5px;
    color: var(--pl-dim);
  }
  .b-log {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .b-log-line {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--pl-mono);
    font-size: 11.5px;
    color: var(--pl-faint);
    animation: b-linein 0.3s ease both;
    animation-delay: calc(var(--i) * 0.12s);
  }
  .b-log-line code {
    color: var(--pl-dim);
    overflow-wrap: anywhere;
  }
  .b-spin {
    width: 9px;
    height: 9px;
    flex: none;
    border-radius: 50%;
    border: 1.5px solid var(--pl-line);
    border-top-color: var(--pl-accent);
    animation: b-spin 0.7s linear infinite;
  }
  @keyframes b-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes b-linein {
    from {
      transform: translateX(-7px);
    }
  }

  /* answer */
  .b-answer {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .b-answer-head {
    display: flex;
    align-items: center;
    gap: 11px;
    flex-wrap: wrap;
  }
  .b-eve-tag {
    font-family: var(--pl-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--pl-accent);
    background: #8b7cf61f;
    border: 1px solid #8b7cf63a;
    padding: 2px 7px;
    border-radius: 6px;
  }
  .b-used {
    font-family: var(--pl-mono);
    font-size: 11px;
  }
  .b-used > summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--pl-dim);
  }
  .b-used > summary::-webkit-details-marker {
    display: none;
  }
  .b-used > summary:hover {
    color: var(--pl-text);
  }
  .b-check {
    color: var(--pl-green);
  }
  .b-used-list {
    list-style: none;
    margin-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 2px;
  }
  .b-used-list code {
    color: var(--pl-faint);
    overflow-wrap: anywhere;
  }

  /* the key split: prose left, artifact canvas right */
  .b-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 26px;
    align-items: start;
  }
  .b-split--solo {
    grid-template-columns: minmax(0, 1fr);
    max-width: 640px;
  }
  .b-prose {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }
  .b-p {
    font-size: 14px;
    line-height: 1.62;
    color: var(--pl-dim);
  }
  .b-canvas {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
  }
  .b-canvas-label {
    font-family: var(--pl-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--pl-faint);
  }

  /* project cards (large + detailed) */
  .b-projs {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .b-proj {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    padding: 16px;
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
  }
  .b-proj:hover {
    border-color: var(--a, var(--pl-accent));
    background: var(--pl-panel-hi);
    transform: translateY(-2px);
  }
  .b-proj-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .b-proj-tile {
    width: 44px;
    height: 44px;
    font-size: 16px;
  }
  .b-proj-titles {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .b-proj-title {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--pl-text);
    overflow-wrap: anywhere;
  }
  .b-proj-area {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
    margin-top: 2px;
  }
  .b-proj-line {
    font-size: 13px;
    line-height: 1.5;
    color: var(--pl-dim);
  }
  .b-proj-stats {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .b-proj-stats .stat {
    flex: 1;
    min-width: 0;
    padding: 10px 13px;
  }
  .b-proj-view {
    font-family: var(--pl-mono);
    font-size: 11.5px;
    color: var(--a, var(--pl-accent));
  }

  /* résumé timeline */
  .b-resume {
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    padding: 6px 16px;
  }
  .b-track {
