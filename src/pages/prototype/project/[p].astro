---
/**
 * PROTOTYPE — throwaway, do not ship. Cleaner project-detail exploration.
 *
 * Question: after you click into a project, what should the page look like once
 * we drop the Spotify/player-shell metaphor? Three simpler/cleaner layouts:
 *
 *   ?variant=A   Editorial   — centered single-column case study, content-first
 *   ?variant=B   Spec sheet  — two-column, sticky meta rail + content
 *   ?variant=C   Gallery     — screenshot-led, visual-first
 *
 * Path param `[p]` selects the showcased project (prerendered per catalog
 * entry — query params don't vary a static page in this project, so the project
 * is a path param and only the variant is toggled client-side via
 * `body[data-variant]`, same as the agent prototype). Entry point:
 * `/prototype/project/exit-manager`. Related cards link to
 * `/prototype/project/<id>`; a tiny script preserves the active variant on
 * click. Real data (catalog), real tokens (player.css); only the variant
 * markup is prototype-local. Delete `src/pages/prototype/` when a winner is
 * folded into `src/pages/projects/[id].astro`; see `_PROJECT_NOTES.md`.
 */
import '../../../styles/player.css';
import ProtoSwitcher from '../_AgentSwitcher.astro';
import VariantA from '../_ProjectVariantA.astro';
import VariantB from '../_ProjectVariantB.astro';
import VariantC from '../_ProjectVariantC.astro';
import { CATALOG, type Project } from '../../../data/catalog';

export function getStaticPaths() {
  return CATALOG.map((project) => ({
    params: { p: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}
const { project } = Astro.props as Props;
const related = CATALOG.filter((o) => o.area === project.area && o.id !== project.id).slice(0, 5);

const VARIANTS = [
  { key: 'A', name: 'Editorial' },
  { key: 'B', name: 'Spec sheet' },
  { key: 'C', name: 'Gallery' },
];
const showSwitch = !import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <title>Project detail prototype · {project.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="proto-doc-body" data-variant="A">
    <div class="vpane" data-v="A"><VariantA project={project} related={related} /></div>
    <div class="vpane" data-v="B"><VariantB project={project} related={related} /></div>
    <div class="vpane" data-v="C"><VariantC project={project} related={related} /></div>
    {showSwitch && <ProtoSwitcher variants={VARIANTS} />}

    <script is:inline define:vars={{ variants: VARIANTS }}>
      (() => {
        const keys = variants.map((v) => v.key);
        const q = new URLSearchParams(location.search).get('variant');
        if (q && keys.includes(q.toUpperCase())) {
          document.body.dataset.variant = q.toUpperCase();
        }
      })();
    </script>

    {/* Preserve the active variant when clicking through to a related project. */}
    <script is:inline>
      document.addEventListener('click', (e) => {
        const a = e.target.closest && e.target.closest('a[href^="/prototype/project/"]');
        if (!a) return;
        const v = document.body.dataset.variant;
        if (!v) return;
        e.preventDefault();
        const u = new URL(a.getAttribute('href'), location.origin);
        u.searchParams.set('variant', v);
        location.assign(u.href);
      });
    </script>
  </body>
</html>

<style is:global>
  /* Base reset/palette. Unlike the agent prototype, a detail page is a normal
     scrolling document — no fixed height, no scroll trap. */
  .proto-doc-body {
    margin: 0;
    min-height: 100dvh;
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  .proto-doc-body *,
  .proto-doc-body *::before,
  .proto-doc-body *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  .proto-doc-body a {
    color: inherit;
    text-decoration: none;
  }
  .proto-doc-body button {
    font: inherit;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
  }
  /* Only the active variant pane shows; the switcher toggles body[data-variant]. */
  .vpane {
    display: none;
  }
  .proto-doc-body[data-variant='A'] .vpane[data-v='A'],
  .proto-doc-body[data-variant='B'] .vpane[data-v='B'],
  .proto-doc-body[data-variant='C'] .vpane[data-v='C'] {
    display: block;
  }
</style>
