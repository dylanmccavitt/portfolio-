---
/**
 * PROTOTYPE — throwaway, do not ship. Floating variant switcher for the
 * chat-agent landing prototype (shared by `agent.astro`). High-contrast pill,
 * bottom-center, obviously not part of the design being evaluated.
 *
 * This is a STATIC Astro project (`output: 'static'`), so the server can't vary
 * the page by `?variant=` — variant panes are rendered and toggled CLIENT-SIDE
 * via `document.body[data-variant]` (same approach as the existing `home.astro`
 * prototype). This script owns both the initial read from the URL
 * and the cycling. The route only renders it outside production builds, so a
 * stray merge can't ship the bar.
 */
export interface Props {
  variants: { key: string; name: string }[];
}
const { variants } = Astro.props;
---

<div class="ag-switch" data-ag-switch>
  <span class="ag-tag">prototype</span>
  <div class="ag-grp">
    <button type="button" data-prev aria-label="Previous variant">‹</button>
    <span class="ag-val" data-ag-val>—</span>
    <button type="button" data-next aria-label="Next variant">›</button>
  </div>
  <span class="ag-hint">← / →</span>
</div>

<script is:inline define:vars={{ variants }}>
  (() => {
    const keys = variants.map((v) => v.key);
    const nameOf = Object.fromEntries(variants.map((v) => [v.key, v.name]));
    const bar = document.querySelector('[data-ag-switch]');
    const valEl = bar.querySelector('[data-ag-val]');

    const norm = (k) => (keys.includes(k) ? k : keys[0]);
    const fallback = () => norm((document.body.dataset.variant || '').toUpperCase());
    let current = norm((new URLSearchParams(location.search).get('variant') || fallback()).toUpperCase());

    const apply = () => {
      document.body.dataset.variant = current;
      valEl.innerHTML = '<b>' + current + '</b>&nbsp;·&nbsp;<span class="ag-name">' + nameOf[current] + '</span>';
      const u = new URL(location.href);
      u.searchParams.set('variant', current);
      history.replaceState(null, '', u.href);
    };
    const cycle = (dir) => {
      current = keys[(keys.indexOf(current) + dir + keys.length) % keys.length];
      apply();
    };

    bar.querySelector('[data-prev]').addEventListener('click', () => cycle(-1));
    bar.querySelector('[data-next]').addEventListener('click', () => cycle(1));
    document.addEventListener('keydown', (e) => {
      const t = e.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      if (e.key === 'ArrowLeft') { e.preventDefault(); cycle(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); cycle(1); }
    });

    apply();
  })();
</script>

<style>
  .ag-switch {
    position: fixed;
    left: 50%;
    bottom: 22px;
    transform: translateX(-50%);
    z-index: 9000;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 10px 7px 12px;
    background: #07080a;
    border: 1px solid #454a58;
    border-radius: 13px;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.6);
    font-family: var(--pl-mono, ui-monospace, monospace);
    font-size: 11.5px;
    color: #c9cdd8;
    user-select: none;
    max-width: 94vw;
  }
  .ag-tag {
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 9px;
    color: #7e8493;
    border-right: 1px solid #2e323d;
    padding-right: 10px;
  }
  .ag-grp {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .ag-grp button {
    color: #c9cdd8;
    font-size: 16px;
    line-height: 1;
    padding: 2px 8px;
    border-radius: 8px;
    cursor: pointer;
    background: none;
    border: none;
  }
  .ag-grp button:hover {
    color: #fff;
    background: #1b1d23;
  }
  .ag-val {
    min-width: 168px;
    text-align: center;
  }
  .ag-val :global(b) {
    color: #fff;
  }
  .ag-val :global(.ag-name) {
    color: #c9cdd8;
  }
  .ag-hint {
    color: #5b6070;
    font-size: 10px;
    border-left: 1px solid #2e323d;
    padding-left: 10px;
  }
  @media (max-width: 560px) {
    .ag-hint {
      display: none;
    }
  }
</style>
