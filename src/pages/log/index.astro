---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/sera/PageHeader.astro';
import RowLink from '../../components/sera/RowLink.astro';
import Pager from '../../components/sera/Pager.astro';
import { getCollection } from 'astro:content';

const WORDS_PER_MINUTE = 200;
const DATE_FMT = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric',
});

const entries = (await getCollection('log'))
  .filter((e) => !e.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((e) => {
    const raw = (e.body ?? '').trim();
    const words = raw ? raw.split(/\s+/).length : 0;
    const minutes = Math.max(1, Math.round(words / WORDS_PER_MINUTE));
    return {
      slug: e.id,
      title: e.data.title,
      date: DATE_FMT.format(e.data.date),
      read: `${minutes} min`,
    };
  });
---

<Base title="Log — Dylan McCavitt" description="Notes and writing — irregularly updated.">
  <main class="log">
    <PageHeader
      kicker="04 / log"
      title="Notes & writing"
      sub="Irregularly updated."
    />

    {entries.length > 0 && (
      <ul class="log__list">
        {entries.map((entry) => (
          <li class="log__item">
            <RowLink
              href={`/log/${entry.slug}/`}
              meta={entry.date}
              title={entry.title}
              trailing={entry.read}
            />
          </li>
        ))}
      </ul>
    )}

    <p class="log__note">more posts coming — this is a fresh log.</p>

    <Pager
      prev={{ href: '/experience', label: 'experience' }}
      next={{ href: '/contact', label: 'contact' }}
    />
  </main>
</Base>

<style>
  .log {
    max-width: 48rem;
    margin: 0 auto;
    padding: 64px 24px;
  }
  .log__list {
    margin: 40px 0 0;
    padding: 0;
    list-style: none;
    border-bottom: 1px solid var(--line);
  }
  .log__item {
    display: block;
  }
  .log__note {
    margin: 32px 0 64px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
</style>
