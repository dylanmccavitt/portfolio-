---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Base title="Resume — Dylan McCavitt">
  <main class="resume">
    <Breadcrumb slug="resume" section="resume" />

    <div class="resume__header">
      <h1 class="resume__title">Dylan McCavitt</h1>
      <p class="resume__subtitle">Software Engineer, NYC</p>
      <a href="/resume.pdf" class="resume__download" target="_blank">Download Resume</a>
    </div>

    <section class="resume__section">
      <h2 class="resume__heading">experience</h2>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Bella's Beads</h3>
            <p class="resume__role">Freelance Full-Stack Developer</p>
          </div>
          <span class="resume__date">2025</span>
        </div>
        <p class="resume__desc">Built a live ecommerce site end to end. React + TypeScript frontend, Node/Express backend, Supabase, Stripe payments, Shippo shipping automation.</p>
      </div>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Manhattan Board of Elections</h3>
            <p class="resume__role">Technical Support Intern</p>
          </div>
          <span class="resume__date">2025</span>
        </div>
      </div>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Kroll, Inc.</h3>
            <p class="resume__role">Associate, Cyber Strategy & Risk</p>
          </div>
          <span class="resume__date">2023 - 2024</span>
        </div>
      </div>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Paul, Weiss</h3>
            <p class="resume__role">Practice Assistant, Private Funds</p>
          </div>
          <span class="resume__date">2020 - 2023</span>
        </div>
      </div>
    </section>

    <section class="resume__section">
      <h2 class="resume__heading">education</h2>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Stevens Institute of Technology</h3>
            <p class="resume__role">M.S. Computer Science</p>
          </div>
          <span class="resume__date">2026</span>
        </div>
      </div>

      <div class="resume__entry">
        <div class="resume__entry-header">
          <div>
            <h3 class="resume__company">Syracuse University</h3>
            <p class="resume__role">B.S. Economics</p>
          </div>
          <span class="resume__date">2019</span>
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .resume {
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-8);
  }

  .resume__header {
    margin-bottom: var(--space-7);
  }
  .resume__title {
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }
  .resume__subtitle {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }
  .resume__download {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    border-bottom: 1px dashed var(--accent);
    padding-bottom: 1px;
  }
  .resume__download:hover {
    text-decoration: none;
    border-bottom-style: solid;
  }

  .resume__section {
    margin-bottom: var(--space-7);
  }
  .resume__heading {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--accent);
    opacity: 0.7;
    text-transform: lowercase;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .resume__entry {
    margin-bottom: var(--space-5);
  }
  .resume__entry:last-child {
    margin-bottom: 0;
  }
  .resume__entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }
  .resume__company {
    font-size: var(--text-base);
    font-weight: 600;
  }
  .resume__role {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }
  .resume__date {
    font-size: var(--text-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .resume__desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin-top: var(--space-2);
  }

  @media (max-width: 600px) {
    .resume__entry-header {
      flex-direction: column;
      gap: 0;
    }
    .resume__date {
      margin-top: var(--space-1);
    }
  }
</style>
