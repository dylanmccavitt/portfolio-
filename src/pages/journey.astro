---
import Editorial from '@/layouts/Editorial.astro';
import { RESUME } from '@/data/resume';
import { journeyMeta } from '@/lib/seo';

const meta = journeyMeta();
---

<Editorial title={meta.title} meta={meta}>
  <section class="device-route-screen journey-console">
    <nav class="screen-nav" aria-label="Primary">
      <a href="/">DM / Journey</a>
      <span class="screen-nav-links">
        <a href="/">Home</a>
        <a href="/library">Work</a>
        <a href="/resume">Resume</a>
        <a href="/contact">Contact</a>
        <button type="button" data-open-guide>Ask DM</button>
      </span>
    </nav>

    <header>
      <h1 class="screen-title">The path here</h1>
      <p class="screen-lede">{RESUME.line}</p>
    </header>

    <ol class="journey-list">
      {RESUME.tracks.map((entry) => (
        <li class:list={{ current: entry.current }}>
          <a href={`/journey/${entry.id}`}>
            <span>{entry.when}</span>
            <strong>{entry.title}<small>{entry.role}</small></strong>
            <span>{entry.notes[0]}</span>
          </a>
        </li>
      ))}
    </ol>

    <nav class="journey-actions" aria-label="Journey actions">
      <button type="button" data-open-guide>Ask DM about my path</button>
      <a href="/resume">View full resume</a>
    </nav>
    <p class="screen-footer">↑↓ explore · Enter details · Esc home</p>
  </section>
</Editorial>

<script is:inline>
  document.querySelectorAll('[data-open-guide]').forEach((button) => {
    button.addEventListener('click', () => document.querySelector('[data-dm-open]')?.click());
  });
</script>

<style>
  .journey-console { padding: clamp(30px, 4.7vw, 70px); }
  .screen-nav button { min-height: 44px; padding: 0 .75rem; color: inherit; background: transparent; border: 1px solid var(--pl-accent); text-transform: uppercase; cursor: pointer; }
  .journey-list { position: relative; list-style: none; margin: clamp(2rem, 5vh, 4rem) 0 0; padding: 0 0 0 1.5rem; border-left: 2px solid #617ba7; }
  .journey-list li { position: relative; }
  .journey-list li::before { content: ''; position: absolute; top: 50%; left: -1.82rem; width: .55rem; height: .55rem; border: 2px solid #718ab3; background: #071321; transform: translateY(-50%); }
  .journey-list li + li { border-top: 1px solid rgba(87, 111, 150, .42); }
  .journey-list a { display: grid; grid-template-columns: 155px minmax(240px, 1fr) minmax(260px, 1.15fr); align-items: center; gap: 1.4rem; min-height: clamp(70px, 8vh, 92px); padding: .8rem 1rem; color: var(--pl-text); text-decoration: none; text-transform: uppercase; }
  .journey-list li.current a, .journey-list a:hover, .journey-list a.is-key-selected { outline: 1px solid #718ab3; background: linear-gradient(90deg, rgba(66, 91, 134, .42), rgba(44, 63, 95, .12)); }
  .journey-list a > span { color: var(--pl-accent); font-size: .72rem; }
  .journey-list strong { font-size: .88rem; font-weight: 500; }
  .journey-list small { display: block; margin-top: .4rem; color: var(--pl-accent); font-size: .65rem; font-weight: 400; }
  .journey-actions { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 1.5rem; }
  .journey-actions button, .journey-actions a { min-height: 44px; padding: .7rem 1rem; color: var(--pl-accent); background: transparent; border: 1px solid var(--pl-accent); text-transform: uppercase; text-decoration: none; cursor: pointer; }
  @media (max-width: 900px) { .journey-list a { grid-template-columns: 110px 1fr; } .journey-list a > span:last-child { grid-column: 2; } }
  @media (max-width: 560px) { .journey-list a { grid-template-columns: 1fr; } .journey-list a > span:last-child { grid-column: auto; } .journey-actions { align-items: stretch; flex-direction: column; } }
</style>
