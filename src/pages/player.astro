---
/**
 * Shell demo page — renders the redesigned app shell (sidebar, main frame,
 * player bar) with a placeholder main region. View content (library lists,
 * project/resume detail) lands in the dedicated view issues; this page exists
 * only to demonstrate and verify the shell from issue #20.
 */
import PlayerLayout from '../layouts/Player.astro';
import { CATALOG } from '../data/catalog';

const now = CATALOG[0];
---

<PlayerLayout title="Dylan McCavitt — now playing" active="all" now={now}>
  <div class="view">
    <div class="head">
      <div class="hero">
        <span class="art lg" style={`--a:${now.hue}`}>{now.sym}</span>
        <div class="info">
          <span class="kind">Now playing · {now.status[1]}</span>
          <h1>{now.title}</h1>
          <p>{now.line}</p>
          <div class="meta">
            <span class:list={['badge', now.status[0]]}>{now.status[1]}</span>
          </div>
        </div>
      </div>
    </div>
    <div class="placeholder">
      <p>App shell scaffold — view content lands in the view issues.</p>
    </div>
  </div>
</PlayerLayout>

<style>
  .hero {
    display: flex;
    gap: 24px;
    align-items: flex-end;
  }
  .kind {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-dim);
  }
  h1 {
    font-size: clamp(26px, 4.2vw, 44px);
    font-weight: 800;
    letter-spacing: -1.5px;
    margin: 6px 0 8px;
  }
  .hero p {
    color: var(--pl-dim);
    max-width: 58ch;
    font-size: 13.5px;
  }
  .meta {
    margin-top: 12px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .placeholder {
    padding: 26px 30px;
    color: var(--pl-faint);
  }
</style>
