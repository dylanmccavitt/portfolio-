---
/**
 * Project card — the canonical "Typographic" project card (#85).
 *
 * Image-free and tile-free by intent: a project's identity is type + color only.
 * The monospace project `id` is the sole mark, over a strong title, a `area ·
 * year` / status badge / activity meta line, and the tagline. Hue is a fine
 * accent — a hairline top rule carries a short hue tick that extends full-width
 * and brightens on hover/focus, and the id/title pick up the hue. Surfaces stay
 * flat (no boxes); hairlines + whitespace do the framing.
 *
 * This is the one canonical project card site-wide: it never uses screenshots,
 * icons, generated marks, or project initials. Static, zero client JS; links to
 * `/projects/{id}` with a visible keyboard focus ring.
 *
 * Reused by the library index, the project-detail "More projects" rail, and the
 * résumé "Shipped during this era" rail; see `ProjectCardGrid.astro` for the
 * responsive grid wrapper.
 */
import type { Project } from '@/data/catalog';
import type { ProjectCardReadModel } from '@/lib/db/project-reads';

type RenderProjectCard = Project | ProjectCardReadModel;

export interface Props {
  project: RenderProjectCard;
}
const { project } = Astro.props;
const [kind, label] = project.status;
const href = 'href' in project ? project.href : `/projects/${project.id}`;
---

<a class="pcard" href={href} style={`--hue:${project.hue}`}>
  <span class="pcard__rule" aria-hidden="true"></span>
  <span class="pcard__id">{project.id}</span>
  <span class="pcard__title">{project.title}</span>
  <div class="pcard__meta">
    <span class="pcard__cat">{project.area} · {project.year}</span>
    <span class={`badge ${kind}`}>{label}</span>
    <span class="pcard__act">{project.activity}</span>
  </div>
  <p class="pcard__line">{project.line}</p>
</a>

<style>
  /* One card: flat, a hairline top rule with a hue tick. */
  .pcard {
    position: relative;
    display: block;
    padding: 24px 0 28px;
    border-top: 1px solid var(--pl-line);
    color: inherit;
  }
  /* The only color mark on the surface: a short hue segment on the top rule. */
  .pcard__rule {
    position: absolute;
    top: -1px;
    left: 0;
    height: 2px;
    width: 40px;
    background: var(--hue);
    opacity: 0.82;
    transition:
      width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .pcard__id {
    display: block;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--hue) 58%, var(--pl-faint));
    transition: color 0.18s ease;
  }

  .pcard__title {
    display: block;
    margin-top: 11px;
    font-size: clamp(21px, 2.3vw, 27px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--pl-text);
    overflow-wrap: break-word;
    transition: color 0.18s ease;
  }

  .pcard__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 14px;
  }
  .pcard__cat {
    font-size: 12.5px;
    color: var(--pl-faint);
  }
  .pcard__act {
    margin-left: auto;
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }

  .pcard__line {
    margin-top: 15px;
    max-width: 48ch;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--pl-dim);
  }

  /* Hover/focus: the hue accent strengthens and the type warms. */
  .pcard:hover .pcard__rule,
  .pcard:focus-visible .pcard__rule {
    width: 100%;
    opacity: 1;
  }
  .pcard:hover .pcard__id,
  .pcard:focus-visible .pcard__id {
    color: var(--hue);
  }
  .pcard:hover .pcard__title,
  .pcard:focus-visible .pcard__title {
    color: color-mix(in srgb, var(--hue) 22%, var(--pl-text));
  }
  .pcard:focus-visible {
    outline: 2px solid var(--pl-focus);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard__rule,
    .pcard__id,
    .pcard__title {
      transition: none;
    }
  }
</style>
