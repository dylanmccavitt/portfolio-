---
interface ProjectLink {
  slug: string;
  title: string;
}

interface Props {
  slug: string;
  section?: string;
  sectionHref?: string;
  siblings?: ProjectLink[];
  parent?: { label: string; href: string };
}

const { slug, section = 'projects', sectionHref, siblings = [], parent } = Astro.props;
const resolvedSectionHref = sectionHref ?? `/#${section}`;

const themes = [
  { id: 'nord', name: 'Nord', swatches: ['#8fbcbb', '#88c0d0', '#81a1c1', '#5e81ac'] },
  { id: 'dracula', name: 'Dracula', swatches: ['#bd93f9', '#8be9fd', '#50fa7b', '#ff79c6'] },
  { id: 'rose-pine', name: 'Rosé Pine', swatches: ['#ebbcba', '#f6c177', '#c4a7e7', '#9ccfd8'] },
  { id: 'gruvbox', name: 'Gruvbox', swatches: ['#cc241d', '#d79921', '#689d6a', '#458588'] },
  { id: 'everforest', name: 'Everforest', swatches: ['#a7c080', '#dbbc7f', '#7fbbb3', '#d699b6'] },
  { id: 'night-owl', name: 'Night Owl', swatches: ['#c792ea', '#82aaff', '#c3e88d', '#f78c6c'] },
  { id: 'dark-plus', name: 'Dark+', swatches: ['#569cd6', '#4ec9b0', '#9cdcfe', '#ce9178'] },
  { id: 'retro', name: 'Retro', swatches: ['#33ff33', '#66ff66', '#00cc00', '#009900'] },
  { id: 'heeler', name: 'Heeler', swatches: ['#e63232', '#8cc832', '#3296f0', '#f0a030'] },
  { id: 'purple-rain', name: 'Purple Rain', swatches: ['#b464f0', '#e63264', '#3296f0', '#32e6e6'] },
  { id: 'monochrome', name: 'Monochrome', swatches: ['#c0c0c0', '#a0a0a0', '#888888', '#666666'] },
  { id: 'tokyo-night', name: 'Tokyo Night', swatches: ['#7aa2f7', '#9ece6a', '#bb9af7', '#f7768e'] },
  { id: 'catppuccin', name: 'Catppuccin', swatches: ['#f38ba8', '#a6e3a1', '#89b4fa', '#fab387'] },
];

const hasSiblings = siblings.length > 0;
---

<div class="breadcrumb-wrapper">
  <div class="breadcrumb-bar__theme">
    <button
      class="breadcrumb-bar__theme-toggle"
      data-theme-toggle
      aria-expanded="false"
      aria-haspopup="true"
    >
      theme ▾
    </button>
    <div class="breadcrumb-bar__dropdown" data-theme-dropdown hidden>
      {themes.map((theme) => (
        <button
          class="palette-nav__dropdown-item"
          data-theme-id={theme.id}
        >
          <span class="palette-nav__dropdown-swatches">
            {theme.swatches.map((color) => (
              <span class="palette-nav__dropdown-swatch" style={`background:${color}`}></span>
            ))}
          </span>
          <span class="palette-nav__dropdown-name">{theme.name}</span>
          <span class="palette-nav__dropdown-check" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </div>
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <div class="breadcrumb-bar__path">
      <a href="/" class="breadcrumb-bar__segment breadcrumb-bar__segment--1">~</a>
      {section !== slug && (
        <>
          <span class="breadcrumb-bar__sep">/</span>
          <a href={resolvedSectionHref} class="breadcrumb-bar__segment breadcrumb-bar__segment--2">{section}</a>
        </>
      )}
      {parent && (
        <>
          <span class="breadcrumb-bar__sep">/</span>
          <a href={parent.href} class="breadcrumb-bar__segment breadcrumb-bar__segment--3">{parent.label}</a>
        </>
      )}
      <span class="breadcrumb-bar__sep">/</span>
      <span class="breadcrumb-bar__segment breadcrumb-bar__segment--3">{slug}</span>
    </div>
  </nav>
  {hasSiblings && (
    <nav class="breadcrumb-tabs" aria-label="Project navigation">
      {siblings.map((project) => (
        project.slug === slug ? (
          <span class="breadcrumb-tabs__tab breadcrumb-tabs__tab--active">{project.slug}</span>
        ) : (
          <a href={`/projects/${project.slug}/`} class="breadcrumb-tabs__tab">{project.slug}</a>
        )
      ))}
    </nav>
  )}
</div>
