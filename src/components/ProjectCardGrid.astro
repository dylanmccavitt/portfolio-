---
/**
 * Project card grid — the canonical responsive layout for {@link ProjectCard}
 * (#85). Flat, hairline-separated editorial index: cards flow into
 * `minmax(360px, 1fr)` columns and collapse to one column at the site-standard
 * 820px breakpoint.
 *
 * Scope (#319): this grid is no longer the site's only project surface. The
 * device-console routes list projects through the `work-list` rows in
 * `LibraryView.astro`; `journey/[track].astro` is the single remaining consumer
 * of this grid, for its "Related projects" era rail. Two surfaces exist on
 * purpose — route any new project listing through one of them, not a third.
 */
import ProjectCard from './ProjectCard.astro';
import type { Project } from '@/data/catalog';
import type { ProjectCardReadModel } from '@/lib/db/project-reads';

export interface Props {
  projects: (Project | ProjectCardReadModel)[];
}
const { projects } = Astro.props;
---

<div class="pcard-grid">
  {projects.map((project) => <ProjectCard project={project} />)}
</div>

<style>
  .pcard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    column-gap: 56px;
  }

  @media (max-width: 820px) {
    .pcard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
