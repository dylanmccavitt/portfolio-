---
import { layout } from "../../data/topology/layout";
import type { NodeTone, ChipTone, FrameTone } from "../../data/topology/layout";

const { viewBox, frames, nodes, edges } = layout;

const CARD_PAD = 16;
const EYEBROW_SIZE = 14;
const LABEL_SIZE = 22;
const CAPTION_SIZE = 13;
const CHIP_H = 36;
const CHIP_GAP = 6;
const CHIP_PAD = 10;

const nodeToneVar: Record<NodeTone, string> = {
  edge: "--nav-4",
  network: "--nav-1",
  platform: "--nav-2",
  runtime: "--nav-3",
  device: "--text-muted",
  client: "--text-muted",
};

const chipToneVar: Record<ChipTone, string> = {
  service: "--nav-1",
  controller: "--nav-2",
  monitoring: "--nav-3",
  agent: "--nav-4",
  utility: "--text-muted",
};

const frameToneVar: Record<FrameTone, string> = {
  management: "--nav-3",
  service: "--nav-1",
  signal: "--nav-2",
  automation: "--nav-4",
};

const edgeKindVar: Record<string, string> = {
  physical: "--nav-1",
  runtime: "--nav-2",
  policy: "--nav-3",
};
---

<section class="topology-screen" id="topology-screen">
  <svg
    viewBox={viewBox}
    role="img"
    aria-label="Interactive homelab topology map"
    class="topology-svg"
    id="topology-svg"
  >
    <rect x="0" y="0" width="2400" height="2800" class="topo-bg" fill="var(--bg)" />

    <g id="topology-camera">
      <rect x="0" y="0" width="2400" height="2800" fill="transparent" id="topology-bg" />

      {frames.map((frame) => {
        const colorVar = frameToneVar[frame.tone];
        return (
          <g
            class="topo-frame"
            data-frame-id={frame.id}
            data-entity-id={frame.entityId ?? ""}
          >
            <rect
              class="topo-frame-bg"
              x={frame.x}
              y={frame.y}
              width={frame.w}
              height={frame.h}
              rx={8}
              fill={`color-mix(in srgb, var(${colorVar}) 6%, transparent)`}
              stroke={`var(${colorVar})`}
              stroke-width="1.5"
              stroke-dasharray="8 6"
              stroke-opacity="0.4"
            />
            <text
              class="topo-frame-label"
              x={frame.x + 16}
              y={frame.y + 24}
              fill={`var(${colorVar})`}
              fill-opacity="0.7"
              text-anchor="start"
              dominant-baseline="hanging"
            >
              {frame.label}
            </text>
          </g>
        );
      })}

      {edges.map((edge) => {
        const colorVar = edgeKindVar[edge.kind] ?? "--nav-1";
        const pathParts = edge.path.split(/[ML]\s*/);
        const coords = pathParts.filter(Boolean).map((p) => {
          const [x, y] = p.split(",").map(Number);
          return { x, y };
        });
        const midIdx = Math.floor(coords.length / 2);
        const mid = coords[midIdx] ?? coords[0];

        return (
          <g
            class="topo-edge-group"
            data-edge-id={edge.id}
            data-edge-from={edge.from}
            data-edge-to={edge.to}
            data-edge-kind={edge.kind}
          >
            <path
              class="topo-edge"
              d={edge.path}
              fill="none"
              stroke={`var(${colorVar})`}
              stroke-width="2"
              stroke-opacity="0.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-dasharray={edge.dashed ? "12 8" : undefined}
            />
            {edge.label && mid && (
              <text
                class="topo-edge-label"
                x={mid.x}
                y={mid.y - 8}
                fill={`var(${colorVar})`}
                fill-opacity="0.6"
                text-anchor="middle"
                dominant-baseline="auto"
              >
                {edge.label}
              </text>
            )}
          </g>
        );
      })}

      {nodes.map((node) => {
        const colorVar = nodeToneVar[node.tone];
        const px = node.x;
        const py = node.y;
        const chipStartY = py + CARD_PAD
          + (node.eyebrow ? EYEBROW_SIZE + 6 : 0)
          + (node.label ? LABEL_SIZE + 4 : 0)
          + (node.caption ? CAPTION_SIZE + 8 : 0)
          + 8;

        return (
          <g
            class="topo-node is-clickable"
            data-entity-click={node.id}
            data-node-id={node.id}
          >
            <rect
              class="topo-node-bg"
              x={px}
              y={py}
              width={node.w}
              height={node.h}
              rx={6}
              fill="var(--surface)"
              stroke={`var(${colorVar})`}
              stroke-width="1.5"
            />

            {node.eyebrow && (
              <text
                class="topo-eyebrow"
                x={px + CARD_PAD}
                y={py + CARD_PAD}
                fill={`var(${colorVar})`}
                text-anchor="start"
                dominant-baseline="hanging"
              >
                {node.eyebrow.toUpperCase()}
              </text>
            )}

            {node.label && (
              <text
                class="topo-label"
                x={px + CARD_PAD}
                y={py + CARD_PAD + (node.eyebrow ? EYEBROW_SIZE + 6 : 0)}
                fill="var(--text)"
                text-anchor="start"
                dominant-baseline="hanging"
              >
                {node.label}
              </text>
            )}

            {node.caption && (
              <text
                class="topo-caption"
                x={px + CARD_PAD}
                y={py + CARD_PAD + (node.eyebrow ? EYEBROW_SIZE + 6 : 0) + (node.label ? LABEL_SIZE + 4 : 0)}
                fill="var(--text-muted)"
                text-anchor="start"
                dominant-baseline="hanging"
              >
                {node.caption}
              </text>
            )}

            {node.chips?.map((chip, i) => {
              const chipColorVar = chipToneVar[chip.tone];
              const chipY = chipStartY + i * (CHIP_H + CHIP_GAP);
              const chipW = node.w - CARD_PAD * 2;

              return (
                <g
                  class="topo-chip is-clickable"
                  data-entity-click={chip.id}
                  data-chip-id={chip.id}
                >
                  <rect
                    class="topo-chip-bg"
                    x={px + CARD_PAD}
                    y={chipY}
                    width={chipW}
                    height={CHIP_H}
                    rx={4}
                    fill="var(--bg)"
                    stroke={`var(${chipColorVar})`}
                    stroke-width="1"
                    stroke-opacity="0.5"
                  />
                  <text
                    class="topo-chip-label"
                    x={px + CARD_PAD + CHIP_PAD}
                    y={chipY + CHIP_H / 2}
                    fill="var(--text)"
                    text-anchor="start"
                    dominant-baseline="central"
                  >
                    {chip.label}
                  </text>
                </g>
              );
            })}
          </g>
        );
      })}
    </g>
  </svg>
</section>

<script>
  import '../../scripts/topology.ts';
</script>
