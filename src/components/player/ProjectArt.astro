---
/**
 * Album-art tile primitive — rounded square with a two-letter symbol and a hue
 * accent bar, ported from the prototype `art()` helper (line 755). Base
 * `.art`/`.art.lg`/`.art.disc` rules live in shared `player.css`; this only
 * renders the element. Reused by the hero, album cards, and resume view (#23).
 * `size`: `lg` (176px hero), `card` (126px album card), `sm` (base). `disc`
 * renders the circular album-disc variant (resume hero).
 */
export interface Props {
  /** Two-letter symbol, e.g. `at`. */
  sym: string;
  /** Accent color (hex). */
  hue: string;
  size?: 'lg' | 'card' | 'sm';
  disc?: boolean;
}
const { sym, hue, size = 'sm', disc = false } = Astro.props;
const sizeClass = size === 'lg' ? 'lg' : size === 'card' ? 'card' : '';
---

<span class:list={['art', sizeClass, { disc }]} style={`--a:${hue}`}>
  {disc ? '' : sym}
</span>

<style>
  /* Album-card tile scale — prototype `.albumcard .art` (line 217). */
  .art.card {
    width: 126px;
    height: 126px;
    font-size: 28px;
    margin-bottom: 10px;
  }
</style>
