---
/** Left rail: profile, Library + Playlists with live counts, Albums, footer links. */
import { LINKS, PLAYLISTS, playlistCount, playlistHref, type PlaylistFilter } from '../../data/catalog';
import { RESUME } from '../../data/resume';

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isOn = (href: string): boolean => path === href;

const LIBRARY_FILTERS: PlaylistFilter[] = ['all', 'wip', 'money'];
const library = PLAYLISTS.filter((p) => LIBRARY_FILTERS.includes(p.filter));
const playlists = PLAYLISTS.filter((p) => !LIBRARY_FILTERS.includes(p.filter));
---

<aside class="sidebar">
  <a class="me" href="/library">
    <span class="dot">DM</span>
    <span><b>Dylan McCavitt</b><small>Software engineer · NYC</small></span>
  </a>

  <div class="g-label">Library</div>
  {
    library.map((p) => (
      <a class:list={['pl', { on: isOn(playlistHref(p.filter)) }]} href={playlistHref(p.filter)}>
        {p.label} <span>{playlistCount(p.filter)}</span>
      </a>
    ))
  }

  <div class="g-label">Albums</div>
  <a class:list={['pl', 'album-row', { on: isOn('/journey') }]} href="/journey">
    <span class="alb">TJ</span>
    <span class="tt"><b>{RESUME.title}</b><small>resume · 2019 — now</small></span>
  </a>

  <div class="g-label">Playlists</div>
  {
    playlists.map((p) => (
      <a class:list={['pl', { on: isOn(playlistHref(p.filter)) }]} href={playlistHref(p.filter)}>
        {p.label} <span>{playlistCount(p.filter)}</span>
      </a>
    ))
  }

  <div class="side-foot">
    <a href={LINKS.github} target="_blank" rel="noopener">GitHub ↗</a>
    <a href={LINKS.resume} target="_blank" rel="noopener">Resume ↗</a>
    <a href={LINKS.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>
    <a href={LINKS.email}>Email ↗</a>
  </div>
</aside>
