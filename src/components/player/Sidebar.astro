---
/**
 * Player shell sidebar — profile, Library filters with live counts, the
 * Resume row, area playlists with counts, and footer links.
 *
 * Ported from the prototype `15-player-v4.html` (sidebar markup lines
 * 267-299). Counts read from the catalog data module (#18); active state is
 * derived from the current URL, not a click handler — zero client JS.
 *
 * URL scheme (coordinate with the view issues): `/library` is the All-work
 * library; `/` is the concierge landing (#60); `/library/[filter]` for every
 * other filter; `/journey` for the resume.
 *
 * Responsive (#27): the root is a native `<details>` so the same markup serves
 * desktop and mobile with zero JS. ≥820px CSS forces it open and hides the
 * `<summary>` marker, so it reads as a plain always-on sidebar. <820px it
 * collapses to a tappable "Browse" disclosure that drops the full nav sheet —
 * every destination, active state, and the contact links stay reachable, and it
 * degrades to visible links if CSS or `<details>` support is missing.
 */
import {
  AREA_PLAYLISTS,
  playlistCount,
  playlistSlug,
  type PlaylistId,
} from '../../data/catalog';

export interface Props {
  /**
   * Active filter, `'resume'` for the album view, or `'home'` for the concierge
   * landing (which highlights no library row — it isn't a filter).
   */
  active?: PlaylistId | 'resume' | 'home';
}
const { active = 'all' } = Astro.props;

const CONTACT = {
  github: 'https://github.com/DylanMcCavitt',
  resume: 'https://dylanmccavitt.xyz/resume.pdf',
  linkedin: 'https://www.linkedin.com/in/dylan-mccavitt',
  email: 'mailto:dylanmccavitt@outlook.com',
};

/**
 * Route for a playlist filter. `all` → `/library`, everything else → its
 * canonical lowercase-kebab `/library/<slug>` (#25 — slugs come from
 * `PLAYLIST_SLUGS`, shared with the `[filter]` route and the sitemap).
 */
const filterHref = (id: PlaylistId) =>
  id === 'all' ? '/library' : `/library/${playlistSlug(id)}`;

const LIBRARY: { id: PlaylistId; label: string }[] = [
  { id: 'all', label: 'All work' },
  { id: 'wip', label: 'Now building' },
];

/** Sidebar labels for the area playlists (some differ from the raw area). */
const PLAYLIST_LABEL: Partial<Record<PlaylistId, string>> = {
  School: 'School · Stevens',
  Research: 'Research & retired',
};

/** Human label for the active destination, shown in the mobile toggle. */
const ALL_LABELS = new Map<PlaylistId | 'resume' | 'home', string>([
  ...LIBRARY.map((l) => [l.id, l.label] as const),
  ...AREA_PLAYLISTS.map((a) => [a, PLAYLIST_LABEL[a] ?? a] as const),
  ['resume', 'Resume'],
  ['home', 'Home'],
]);
const activeLabel = ALL_LABELS.get(active) ?? 'Library';
---

<details class="sidebar" open>
  <summary class="side-toggle" aria-label={`Browse — current: ${activeLabel}`}>
    <span class="st-label">Browse</span>
    <span class="st-active">{activeLabel}</span>
    <span class="st-caret" aria-hidden="true"></span>
  </summary>

  <a class="me" href="/" aria-label="Dylan McCavitt — home">
    <span class="dot" aria-hidden="true">DM</span>
    <span><b>Dylan McCavitt</b><small>Software engineer · NYC</small></span>
  </a>

  <div class="g-label">Library</div>
  {
    LIBRARY.map((item) => (
      <a
        class:list={['pl', { on: active === item.id }]}
        href={filterHref(item.id)}
        aria-current={active === item.id ? 'page' : undefined}
      >
        {item.label} <span>{playlistCount(item.id)}</span>
      </a>
    ))
  }

  <div class="g-label">Albums</div>
  <a
    class:list={['pl album-row', { on: active === 'resume' }]}
    href="/journey"
    aria-current={active === 'resume' ? 'page' : undefined}
  >
    <span class="alb" aria-hidden="true">R</span>
    <span class="tt"><b>Resume</b><small>2019 — now</small></span>
  </a>

  <div class="g-label">Playlists</div>
  {
    AREA_PLAYLISTS.map((area) => (
      <a
        class:list={['pl', { on: active === area }]}
        href={filterHref(area)}
        aria-current={active === area ? 'page' : undefined}
      >
        {PLAYLIST_LABEL[area] ?? area} <span>{playlistCount(area)}</span>
      </a>
    ))
  }

  <div class="side-foot">
    <a href={CONTACT.github} target="_blank" rel="noopener">GitHub ↗</a>
    <a href={CONTACT.resume} target="_blank" rel="noopener">Resume.pdf ↗</a>
    <a href={CONTACT.linkedin} target="_blank" rel="noopener">LinkedIn ↗</a>
    <a href={CONTACT.email}>Email ↗</a>
  </div>
</details>

{/*
  A11y (#28): the sidebar ships with `open` so its nav links are keyboard-
  focusable on desktop — a closed <details> drops its content from the tab
  order even though the ≥820px CSS renders it. With no JS this just leaves the
  mobile sheet expanded (every link still reachable). This tiny enhancement
  restores the <820px collapse: it closes the disclosure on small screens and
  re-opens it on desktop, so the native <summary> toggle works as designed.
*/}
<script is:inline>
  (() => {
    const el = document.querySelector('details.sidebar');
    if (!el) return;
    const mq = window.matchMedia('(max-width: 820px)');
    const sync = () => {
      // Desktop: always open (focusable). Mobile: collapse to the toggle.
      if (mq.matches) el.removeAttribute('open');
      else el.setAttribute('open', '');
    };
    sync();
    mq.addEventListener('change', sync);
  })();
</script>
