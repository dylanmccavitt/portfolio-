---
/**
 * Persistent bottom player bar — now-playing slot, transport controls, seek
 * rail, and right-side links. Rendered server-side with a sensible default
 * "now playing" = the first catalog project; behavior is layered on by the
 * player-state island (#24, `src/scripts/player.ts`).
 *
 * The island needs compact metadata for every catalog project and resume track
 * to re-render the bar on prev/next without a round-trip to the catalog module.
 * That playlist payload is emitted once here as a `<script type="application/
 * json">` so the island stays tiny and the data never ships twice.
 *
 * Ported from the prototype `15-player-v4.html` (player bar markup lines
 * 304-319, the project branch of `renderBar` lines 966-975). Transport controls
 * are real `<button>`s with accessible names (the prototype's decorative
 * `<span>`s couldn't be focused or operated by keyboard — #28 depends on this).
 */
import { CATALOG, type Project } from '../../data/catalog';
import { RESUME, trackSeekPct } from '../../data/resume';

export interface Props {
  /** Project shown in the now-playing slot. Defaults to the first catalog entry. */
  now?: Project;
}
const { now = CATALOG[0] } = Astro.props;

const CONTACT = {
  github: 'https://github.com/DylanMcCavitt',
  resume: 'https://dylanmccavitt.xyz/resume.pdf',
  email: 'mailto:dylanmccavitt@outlook.com',
};

/**
 * Compact now-playing payload the island consumes to hydrate + re-render the
 * bar. `p` = project (status/seek subline + project seek rail); `r` = resume
 * track (the journey's 2019 → now timeline). Ordered like the prototype's
 * playlists so prev/next wraparound matches the visible tracklists.
 */
const PLAYLIST = {
  p: CATALOG.map((proj) => ({
    id: proj.id,
    sym: proj.sym,
    hue: proj.hue,
    title: proj.title,
    sub: `${proj.status[1].toLowerCase()} · ${proj.seek.to}`,
    from: proj.seek.from,
    to: proj.seek.to,
    pct: proj.seek.pct,
    href: `/projects/${proj.id}`,
    // Extra fields the island uses to re-render the library hero (#21 contract).
    kind: `Now playing · ${proj.status[1]}`,
    about: proj.about[0],
    badgeKind: proj.status[0],
    badgeLabel: proj.status[1],
    stack: proj.stack.map((s) => s[1]).slice(0, 2).join(' · '),
  })),
  r: RESUME.tracks.map((track, i) => ({
    id: track.id,
    sym: track.sym,
    hue: track.hue,
    title: track.title,
    sub: `resume · track ${i + 1}/${RESUME.tracks.length}`,
    from: '2019',
    to: 'now',
    pct: trackSeekPct(i),
    href: `/journey/${track.id}`,
  })),
};
---

<footer class="playerbar" aria-label="Player">
  <a class="pb-now" href={`/projects/${now.id}`} data-pb-now>
    <span class="pb-art" style={`--a:${now.hue}`} data-pb-art aria-hidden="true">{now.sym}</span>
    <span aria-live="polite">
      <span class="sr-only">Now playing: </span>
      <b data-pb-title>{now.title}</b>
      <small data-pb-sub>{now.status[1].toLowerCase()} · {now.seek.to}</small>
    </span>
  </a>
  <div class="pb-center">
    <p class="sr-only" id="pb-shortcuts">
      Keyboard shortcuts: press Space to play or pause, Right Arrow for next, Left Arrow for previous.
    </p>
    <div class="controls" role="group" aria-label="Playback controls" aria-describedby="pb-shortcuts">
      <button class="ctl prev" type="button" aria-label="Previous" data-pb-prev></button>
      <button class="ctl play" type="button" aria-label="Play" data-pb-play></button>
      <button class="ctl next" type="button" aria-label="Next" data-pb-next></button>
    </div>
    <div class="seek" data-pb-seek>
      <span class="time" data-pb-from>{now.seek.from}</span>
      <span
        class="rail"
        role="progressbar"
        aria-label="Timeline (display only)"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow={Math.round(now.seek.pct)}
        aria-valuetext={`${now.seek.from} to ${now.seek.to}`}
        data-pb-rail
      >
        <i style={`width:${now.seek.pct}%`} data-pb-fill></i>
        <u style={`left:${now.seek.pct}%`} data-pb-knob></u>
      </span>
      <span class="time" data-pb-to>{now.seek.to}</span>
    </div>
  </div>
  <nav class="pb-right" aria-label="Contact and links">
    <a href={CONTACT.github} target="_blank" rel="noopener">github</a>
    <a href={CONTACT.resume} target="_blank" rel="noopener">resume</a>
    <a href={CONTACT.email}>contact</a>
  </nav>
</footer>

<script type="application/json" data-pb-playlist is:inline set:html={JSON.stringify(PLAYLIST)}></script>
