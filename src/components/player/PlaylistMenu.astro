---
/**
 * Mobile playlist dropdown — a native `<details>` menu listing the playlists
 * that have no tab of their own (All + the seven areas; Building and Resume
 * are tabs). Rendered by LibraryView at the top of every library page so each
 * playlist stays two taps away on mobile; CSS hides it ≥820px where the
 * sidebar covers this. Zero client JS: selecting an entry is a navigation,
 * which closes the menu by loading the next page.
 */
import {
  AREA_PLAYLISTS,
  playlistCount,
  playlistSlug,
  type PlaylistId,
} from '../../data/catalog';

export interface Props {
  /** The active library filter, shown in the closed menu + marked in the list. */
  active: PlaylistId;
}
const { active } = Astro.props;

/** Menu labels for areas whose sidebar label differs from the raw id. */
const LABEL: Partial<Record<PlaylistId, string>> = {
  all: 'All work',
  School: 'School · Stevens',
  Research: 'Research & retired',
};

const ITEMS: { id: PlaylistId; label: string; href: string }[] = [
  // `all` points at /library — the canonical all-work URL (relocated from `/`
  // in #60). On mobile this menu is reached via the Projects tab.
  { id: 'all', label: LABEL.all!, href: '/library' },
  ...AREA_PLAYLISTS.map((a) => ({
    id: a as PlaylistId,
    label: LABEL[a] ?? a,
    href: `/library/${playlistSlug(a)}`,
  })),
];

const activeLabel = ITEMS.find((i) => i.id === active)?.label ?? LABEL.all!;
---

<details class="playlist-menu">
  <summary aria-label={`Playlist, current: ${activeLabel}`}>
    <span class="pm-label">Playlist</span>
    <span class="pm-current">{activeLabel}</span>
    <span class="pm-caret" aria-hidden="true"></span>
  </summary>
  <nav class="pm-list" aria-label="Playlists">
    {
      ITEMS.map((item) => (
        <a
          class:list={{ on: active === item.id }}
          href={item.href}
          aria-current={active === item.id ? 'page' : undefined}
        >
          {item.label} <span>{playlistCount(item.id)}</span>
        </a>
      ))
    }
  </nav>
</details>
