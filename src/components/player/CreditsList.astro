---
/**
 * Credits list — two-column `label / value` rows with hairline separators,
 * ported from the prototype `.credits` (markup line 854, CSS 204-207). Driven
 * by the project `stack` tuples; reused by the resume track view (#23).
 */
import type { ProjectStackEntry } from '../../data/catalog';

export interface Props {
  rows: ProjectStackEntry[];
}
const { rows } = Astro.props;
---

<div class="credits">
  {
    rows.map(([label, value]) => (
      <div>
        <span>{label}</span>
        <b>{value}</b>
      </div>
    ))
  }
</div>

<style>
  .credits {
    display: grid;
    gap: 8px;
    font-size: 12.5px;
    margin-top: 18px;
  }
  .credits div {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    border-bottom: 1px solid var(--pl-line);
    padding-bottom: 8px;
  }
  .credits span {
    color: var(--pl-faint);
  }
  .credits b {
    font-weight: 500;
    font-family: var(--pl-mono);
    font-size: 11.5px;
    text-align: right;
  }
</style>
