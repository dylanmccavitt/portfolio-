---
/**
 * Screenshot rail — horizontally scrolling, scroll-snapping project evidence.
 * Each shot is either a real captured image or a small CSS placeholder keyed by
 * its artifact kind. Pure CSS, no client JavaScript.
 */
import { isImageShot, isVideoShot, type ProjectShot } from '@/data/catalog';

export interface Props {
  shots: ProjectShot[];
  hue: string;
}
const { shots, hue } = Astro.props;

const DIMS = { wide: { w: 400, h: 267 }, phone: { w: 180, h: 320 } };
const isPhone = (shot: ProjectShot) =>
  isImageShot(shot) || isVideoShot(shot) ? shot.phone === true : shot.skeletonKind === 'phone';
---

<div class="shots" role="group" aria-label="Screenshots" tabindex="0">
  {
    shots.map((shot, i) => {
      const phone = isPhone(shot);
      const dims = phone ? DIMS.phone : DIMS.wide;
      return isImageShot(shot) ? (
        <a
          class:list={['shot', { phone }]}
          href={`#shot-${i}`}
          aria-label={`Expand screenshot: ${shot.caption}`}
        >
          <img
            src={shot.src}
            alt={shot.caption}
            width={dims.w}
            height={dims.h}
            loading="lazy"
            decoding="async"
          />
          <span class="cap">{shot.caption}</span>
        </a>
      ) : isVideoShot(shot) ? (
        <div class:list={['shot', { phone }]}>
          <video
            src={shot.src}
            width={dims.w}
            height={dims.h}
            controls
            muted
            playsinline
            preload="metadata"
            poster={shot.poster}
          ></video>
          <span class="cap">{shot.caption}</span>
        </div>
      ) : (
        <div class:list={['shot', { phone }]}>
          <div class="sk" data-kind={shot.skeletonKind} style={`--sk:${hue}66`} aria-hidden="true">
            {(shot.skeletonKind === 'chart' || shot.skeletonKind === 'dash' || shot.skeletonKind === 'list' || shot.skeletonKind === 'phone') && (
              <div class="bar"></div>
            )}
            {shot.skeletonKind === 'phone' && <div class="block tall"></div>}
            {shot.skeletonKind === 'dash' && (
              <div class="row">
                <div class="block accent"></div>
                <div class="lines">
                  <i></i><i></i><i></i><i></i><i></i>
                </div>
              </div>
            )}
            {shot.skeletonKind === 'chart' && (
              <div class="row">
                <div class="block accent"></div>
              </div>
            )}
            {shot.skeletonKind === 'list' && (
              <div class="lines grow">
                <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
              </div>
            )}
            {shot.skeletonKind === 'code' && (
              <div class="lines grow">
                <i style="width:88%"></i><i style="width:64%"></i>
                <i style="width:74%"></i><i style="width:52%"></i>
                <i style="width:81%"></i><i style="width:58%"></i>
                <i style="width:70%"></i>
              </div>
            )}
            {shot.skeletonKind === 'phone' && (
              <div class="lines">
                <i></i><i></i><i></i>
              </div>
            )}
          </div>
          <span class="cap">{shot.caption}</span>
        </div>
      );
    })
  }
</div>

{
  shots.map(
    (shot, i) =>
      isImageShot(shot) && (
        <a class="lightbox" id={`shot-${i}`} href="#!" aria-label="Close screenshot">
          <img src={shot.src} alt={shot.caption} loading="lazy" decoding="async" />
          <span class="lb-cap">{shot.caption}</span>
        </a>
      ),
  )
}

<style>
  .shots {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 18px 30px 8px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    scroll-padding-inline: 30px;
  }
  .shots::-webkit-scrollbar {
    display: none;
  }
  .shot {
    display: block;
    flex: 0 0 min(400px, calc(100vw - 60px));
    aspect-ratio: 3 / 2;
    border-radius: 12px;
    overflow: hidden;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    position: relative;
    scroll-snap-align: start;
  }
  a.shot {
    cursor: zoom-in;
    background: var(--pl-bg);
  }
  .shot.phone {
    flex: 0 0 min(180px, 60vw);
    aspect-ratio: 9 / 16;
  }
  .shot img,
  .shot video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
  }
  .shot .cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 18px 14px 9px;
    font-size: 11.5px;
    color: var(--pl-text);
    background: linear-gradient(transparent, rgb(0 0 0 / 0.5) 55%, rgb(0 0 0 / 0.82));
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    place-items: center;
    align-content: center;
    gap: 10px;
    padding: 4vh 4vw;
    background: rgb(0 0 0 / 0.84);
    cursor: zoom-out;
  }
  .lightbox:target {
    display: grid;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 84vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--pl-line);
  }
  .lb-cap {
    font-size: 12.5px;
    color: #e3e6ec;
  }

  .sk {
    position: absolute;
    inset: 0;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sk .bar {
    height: 10px;
    border-radius: 4px;
    background: #ffffff10;
  }
  .sk[data-kind='chart'] .bar { width: 34%; }
  .sk[data-kind='dash'] .bar { width: 46%; }
  .sk[data-kind='list'] .bar { width: 40%; }
  .sk[data-kind='phone'] .bar { width: 52%; }
  .sk .row {
    display: flex;
    gap: 8px;
    flex: 1;
  }
  .sk .block {
    flex: 1;
    border-radius: 9px;
    background: var(--sk, #8b7cf666);
  }
  .sk .block.tall {
    flex: 1.8;
  }
  .sk .lines {
    flex: 1.5;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .sk .lines.grow {
    flex: 1;
  }
  .sk .lines i {
    display: block;
    height: 9px;
    border-radius: 99px;
    background: #ffffff12;
  }
  .sk .lines i:nth-child(2n) { width: 78%; }
  .sk .lines i:nth-child(3n) { width: 58%; }
  .sk .accent {
    background: var(--sk, #8b7cf666);
  }

  @media (max-width: 820px) {
    .shots {
      padding-left: 18px;
      padding-right: 18px;
      scroll-padding-inline: 18px;
    }
  }
</style>
