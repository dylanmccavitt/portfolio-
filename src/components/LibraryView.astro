---
/**
 * Library view — a flat, editorial index of canonical Typographic project
 * cards. Used by `/library` and `/library/[filter]`.
 *
 * The active filter is the URL; routes provide the public project read models
 * from the DB gate or the catalog fallback.
 */
import ProjectCardGrid from './ProjectCardGrid.astro';
import {
  AREA_PLAYLISTS,
  PLAYLIST_SLUGS,
  type PlaylistId,
} from '@/data/catalog';
import { filterPublicProjectDetails } from '@/lib/public-projects';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';

export interface Props {
  filter: PlaylistId;
  projects: ProjectDetailReadModel[];
}
const { filter, projects } = Astro.props;

const list = filterPublicProjectDetails(projects, filter);

const LABELS: Record<PlaylistId, string> = {
  all: 'All work',
  wip: 'Now building',
  'Shipped & Client Work': 'Shipped & Client Work',
  Apps: 'Apps',
  'AI & Developer Tools': 'AI & Developer Tools',
  'Side Projects & Experiments': 'Side Projects & Experiments',
  Coursework: 'Coursework',
};

const FILTERS = ['all', 'wip', ...AREA_PLAYLISTS] satisfies PlaylistId[];
const hrefFor = (id: PlaylistId) =>
  id === 'all' ? '/library' : `/library/${PLAYLIST_SLUGS[id]}`;
const sectionTitle = LABELS[filter];
const count = list.length;
const countFor = (id: PlaylistId) => filterPublicProjectDetails(projects, id).length;
---

<section class="library-page">
  <header class="library-topbar">
    <a class="library-mark" href="/" aria-label="Dylan McCavitt home">DM</a>
    <nav class="library-nav" aria-label="Primary">
      <a href="/">Ask DM</a>
      <a href="/journey">Resume</a>
      <a href="/hiring">Hiring tour</a>
    </nav>
  </header>

  <div class="library-wrap">
    <section class="library-hero">
      <p class="eyebrow">Project library</p>
      <h1>{sectionTitle}</h1>
      <p>
        {count} {count === 1 ? 'project' : 'projects'} from Dylan's portfolio.
        Browse by area or open a project for the full case study.
      </p>
    </section>

    <nav class="filter-nav" aria-label="Project filters">
      {
        FILTERS.map((id) => (
          <a
            class:list={['filter-link', { active: id === filter }]}
            href={hrefFor(id)}
            aria-current={id === filter ? 'page' : undefined}
          >
            <span>{LABELS[id]}</span>
            <b>{countFor(id)}</b>
          </a>
        ))
      }
    </nav>

    <ProjectCardGrid projects={list} />
  </div>
</section>

<style>
  .library-page {
    min-height: 100dvh;
    color: var(--pl-text);
    font-family: var(--pl-sans);
  }

  .library-topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 13px clamp(18px, 5vw, 40px);
    border-bottom: 1px solid var(--pl-line);
    background: color-mix(in srgb, var(--pl-bg) 84%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .library-mark {
    font-family: var(--pl-mono);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    color: var(--pl-accent);
    border: 1px solid color-mix(in srgb, var(--pl-accent) 38%, var(--pl-line));
    border-radius: 7px;
    padding: 4px 8px;
    line-height: 1;
  }

  .library-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 13px;
    color: var(--pl-dim);
  }
  .library-nav a:hover {
    color: var(--pl-text);
  }

  .library-wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 82px) clamp(18px, 5vw, 40px) clamp(64px, 10vw, 112px);
  }

  .library-hero {
    max-width: 700px;
    margin-bottom: clamp(30px, 6vw, 56px);
  }
  .eyebrow {
    font-family: var(--pl-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--pl-accent);
    margin-bottom: 16px;
  }
  .library-hero h1 {
    font-size: clamp(34px, 6vw, 64px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .library-hero p {
    max-width: 58ch;
    margin-top: 18px;
    color: var(--pl-dim);
    font-size: 16px;
    line-height: 1.6;
  }

  .filter-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: clamp(26px, 5vw, 44px);
  }
  .filter-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 38px;
    padding: 8px 12px;
    border: 1px solid var(--pl-line);
    border-radius: 999px;
    color: var(--pl-dim);
    font-size: 12.5px;
  }
  .filter-link b {
    font-family: var(--pl-mono);
    font-size: 10.5px;
    font-weight: 500;
    color: var(--pl-faint);
  }
  .filter-link:hover,
  .filter-link.active {
    color: var(--pl-text);
    border-color: var(--pl-accent);
    background: color-mix(in srgb, var(--pl-accent) 9%, transparent);
  }

  @media (max-width: 640px) {
    .library-topbar {
      align-items: flex-start;
      flex-direction: column;
    }
    .library-nav {
      justify-content: flex-start;
      gap: 11px;
    }
    .filter-link {
      width: 100%;
      justify-content: space-between;
      border-radius: 10px;
    }
  }
</style>
