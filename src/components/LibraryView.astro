---
import {
  AREA_PLAYLISTS,
  PLAYLIST_SLUGS,
  type PlaylistId,
} from '@/data/catalog';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';
import { filterPublicProjectDetails } from '@/lib/public-projects';

export interface Props {
  filter: PlaylistId;
  projects: ProjectDetailReadModel[];
}

const { filter, projects } = Astro.props;
const list = filterPublicProjectDetails(projects, filter);
const LABELS: Record<PlaylistId, string> = {
  all: 'Selected work',
  wip: 'Now building',
  'Shipped & Client Work': 'Shipped client work',
  Apps: 'Apps',
  'AI & Developer Tools': 'AI & developer tools',
  'Side Projects & Experiments': 'Side projects',
  Coursework: 'Coursework',
};
const FILTERS = ['all', 'wip', ...AREA_PLAYLISTS] satisfies PlaylistId[];
const hrefFor = (id: PlaylistId) => id === 'all' ? '/library' : `/library/${PLAYLIST_SLUGS[id]}`;
---

<section class="device-route-screen work-console">
  <nav class="screen-nav" aria-label="Primary">
    <a href="/">DM / Work</a>
    <span class="screen-nav-links">
      <a href="/">Home</a>
      <a href="/journey">Journey</a>
      <a href="/resume">Resume</a>
      <a href="/contact">Contact</a>
      <button type="button" data-open-guide>Ask DM</button>
    </span>
  </nav>

  <header class="work-console-head">
    <h1 class="screen-title">{LABELS[filter]}</h1>
    <nav class="work-filters" aria-label="Project filters">
      {FILTERS.map((id) => (
        <a href={hrefFor(id)} aria-current={id === filter ? 'page' : undefined}>{LABELS[id]}</a>
      ))}
    </nav>
  </header>

  <ol class="work-list">
    {list.map((project, index) => (
      <li>
        <a href={`/projects/${project.slug}`} class:list={['work-row', { selected: index === 0 }]}>
          <span class="work-index">{String(index + 1).padStart(2, '0')}</span>
          <strong>{project.title}</strong>
          <span>{project.area} · {project.status[1]} {project.year}</span>
          <span>Open case →</span>
        </a>
      </li>
    ))}
  </ol>

  <p class="screen-footer">↑↓ select · Enter open · / ask DM · Esc home</p>
</section>

<script is:inline>
  document.querySelector('[data-open-guide]')?.addEventListener('click', () => {
    document.querySelector('[data-dm-open]')?.click();
  });
</script>

<style>
  .work-console { padding: clamp(30px, 4.7vw, 70px); }
  .work-console-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; }
  .work-filters { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .65rem 1rem; max-width: 55%; }
  .work-filters a { min-height: 44px; display: inline-flex; align-items: center; color: var(--pl-faint); font-size: .64rem; text-decoration: none; text-transform: uppercase; }
  .work-filters a[aria-current='page'], .work-filters a:hover { color: var(--pl-text); text-decoration: underline; text-underline-offset: .3rem; }
  .screen-nav button { min-height: 44px; padding: 0 .75rem; color: inherit; background: transparent; border: 1px solid var(--pl-accent); text-transform: uppercase; cursor: pointer; }
  .work-list { list-style: none; margin: clamp(2.4rem, 6vh, 5.5rem) 0 0; padding: 0; }
  .work-list li + li { border-top: 1px solid rgba(91, 116, 154, .38); }
  .work-row { display: grid; grid-template-columns: 70px minmax(180px, 1.3fr) minmax(210px, 1fr) auto; align-items: center; gap: 1.25rem; min-height: clamp(74px, 9vh, 108px); padding: 1rem 1.25rem; color: var(--pl-text); border: 1px solid transparent; text-decoration: none; text-transform: uppercase; }
  .work-row.selected, .work-row:hover, .work-row.is-key-selected { border-color: #778cad; background: linear-gradient(90deg, rgba(78, 101, 139, .44), rgba(53, 73, 106, .15)); }
  .work-index { color: #c5cedc; font-size: 1.35rem; }
  .work-row strong { font-size: clamp(.94rem, 1.55vw, 1.35rem); font-weight: 500; letter-spacing: .04em; }
  .work-row span:nth-child(3), .work-row span:last-child { color: var(--pl-accent); font-size: .67rem; }
  @media (max-width: 900px) { .work-console-head { align-items: flex-start; flex-direction: column; } .work-filters { justify-content: flex-start; max-width: none; } .work-row { grid-template-columns: 48px 1fr auto; } .work-row span:nth-child(3) { display: none; } }
  @media (max-width: 560px) { .work-row { grid-template-columns: 38px 1fr; } .work-row span:last-child { grid-column: 2; } }
</style>
