---
import {
  type PlaylistId,
} from '@/data/catalog';
import type { ProjectDetailReadModel } from '@/lib/db/project-reads';
import { filterPublicProjectDetails } from '@/lib/public-projects';
import { resolvePublicProjectByReference } from '@/lib/public-project-route-resolver';

export interface Props {
  filter: PlaylistId;
  projects: ProjectDetailReadModel[];
}

const { filter, projects } = Astro.props;
const SELECTED_PROJECT_IDS = [
  'bellas-beads',
  'agentic-trader',
  'tradingview-mcp',
  'evalgate',
] as const;
const list = filter === 'all'
  ? SELECTED_PROJECT_IDS.map((id) => {
      const project = resolvePublicProjectByReference(projects, id);
      if (!project) throw new Error(`LibraryView: selected project "${id}" is unavailable`);
      return project;
    })
  : filterPublicProjectDetails(projects, filter);
const LABELS: Record<PlaylistId, string> = {
  all: 'Selected work',
  wip: 'Now building',
  'Shipped & Client Work': 'Shipped client work',
  Apps: 'Apps',
  'AI & Developer Tools': 'AI & developer tools',
  'Side Projects & Experiments': 'Side projects',
  Coursework: 'Coursework',
};
const projectDescriptor = (project: ProjectDetailReadModel): string => {
  if (project.slug === 'bellas-beads') return `Client ecommerce · ${project.status[1]} ${project.year}`;
  if (project.slug === 'agentic-trader') return `Automation · ${project.activity}`;
  if (project.slug === 'evalgate') return `Evaluation tooling · ${project.year}`;
  return `${project.area.replace('&', '+')} · ${project.status[1]}`;
};
---

<section class="device-route-screen work-console" data-library-filter={filter}>
  <nav class="screen-nav" aria-label="Primary">
    <a href="/">DM / Work</a>
    <span class="screen-nav-links">
      <a href="/">Home</a>
      <a href="/journey">Journey</a>
      <a href="/resume">Resume</a>
      <a href="/contact">Contact</a>
      <button type="button" data-open-guide>Ask DM</button>
    </span>
  </nav>

  <header class="work-console-head">
    <h1 class="screen-title">{LABELS[filter]}</h1>
  </header>

  <ol class="work-list">
    {list.map((project, index) => (
      <li>
        <a href={`/projects/${project.slug}`} class:list={['work-row', { selected: index === 0 }]}>
          <span class="work-index">{String(index + 1).padStart(2, '0')}</span>
          <strong>{project.title}</strong>
          <span>{projectDescriptor(project)}</span>
          <span>Open case →</span>
        </a>
      </li>
    ))}
  </ol>

  <p class="screen-footer">↑↓ select · Enter open · / ask DM · Esc home</p>
</section>

<script is:inline>
  document.querySelector('[data-open-guide]')?.addEventListener('click', () => {
    document.querySelector('[data-dm-open]')?.click();
  });
</script>

<style>
  .work-console { padding: clamp(28px, 3.5vw, 48px) clamp(32px, 4.2vw, 58px) clamp(24px, 3vw, 38px); }
  .work-console-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; }
  .screen-nav button { min-height: 44px; padding: 0 .75rem; color: inherit; background: transparent; border: 1px solid var(--pl-accent); text-transform: uppercase; cursor: pointer; }
  .work-console .screen-title { font-size: clamp(2.5rem, 3.7vw, 3.45rem); line-height: .96; }
  .work-list { list-style: none; margin: clamp(1.35rem, 3vh, 2rem) 0 0; padding: 0; }
  .work-list li + li { border-top: 1px solid rgba(91, 116, 154, .38); }
  .work-row { display: grid; grid-template-columns: 68px minmax(220px, 1.15fr) minmax(220px, 1fr) auto; align-items: center; gap: 1.35rem; min-height: clamp(68px, 8.2vh, 84px); padding: .85rem 1.3rem; color: var(--pl-text); border: 1px solid transparent; text-decoration: none; text-transform: uppercase; }
  .work-row.selected, .work-row:hover, .work-row.is-key-selected { border-color: #7893bf; box-shadow: inset 5px 0 0 #3c82ff; background: linear-gradient(90deg, rgba(59, 91, 151, .6), rgba(32, 54, 93, .2)); }
  .work-index { color: #d5dfec; font-size: 1.55rem; }
  .work-row strong { font-size: clamp(1.08rem, 1.65vw, 1.5rem); font-weight: 600; letter-spacing: .045em; }
  .work-row span:nth-child(3), .work-row span:last-child { color: #81a9eb; font-size: .76rem; letter-spacing: .055em; }
  .work-console .screen-footer { margin-top: clamp(1.6rem, 4vh, 2.8rem); }
  @media (max-width: 900px) { .work-console-head { align-items: flex-start; flex-direction: column; } .work-row { grid-template-columns: 48px 1fr auto; } .work-row span:nth-child(3) { display: none; } }
  @media (max-width: 560px) { .work-row { grid-template-columns: 38px 1fr; } .work-row span:last-child { grid-column: 2; } }
</style>
