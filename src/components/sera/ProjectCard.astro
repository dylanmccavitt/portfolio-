---
interface Props {
  slug: string;
  name: string;
  kind: string;
  blurb: string;
  coverSrc: string;
  coverAlt: string;
  href?: string;
}
const { slug, name, kind, blurb, coverSrc, coverAlt, href } = Astro.props;
const target = href ?? `/projects/${slug}`;
---

<a href={target} class="proj-card">
  <div class="proj-cover">
    <img
      class="proj-cover__img"
      src={coverSrc}
      alt={coverAlt}
      loading="lazy"
      decoding="async"
    />
    <span class="proj-cover__label">[{slug}]</span>
  </div>
  <div class="proj-card__meta">
    <div class="proj-card__text">
      <h3 class="proj-title">&gt; {name}</h3>
      <p class="proj-card__blurb">{blurb}</p>
    </div>
    <span class="proj-card__kind">&mdash; {kind}</span>
  </div>
</a>

<style>
  .proj-card {
    display: block;
    color: var(--ink);
    text-decoration: none;
    transition: transform 0.3s var(--ease);
  }
  .proj-card:hover {
    text-decoration: none;
  }
  .proj-cover {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--line);
    background: rgba(17, 14, 12, 0.04);
    transition:
      border-color 0.3s var(--ease),
      transform 0.35s var(--ease);
  }
  .proj-card:hover .proj-cover {
    border-color: var(--ink);
  }
  .proj-card:hover .proj-cover__img {
    transform: scale(1.02);
  }
  .proj-cover__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.45s var(--ease);
  }
  .proj-cover__label {
    position: absolute;
    left: 14px;
    bottom: 12px;
    padding: 5px 8px;
    border: 1px solid rgba(250, 247, 240, 0.28);
    background: rgba(17, 14, 12, 0.62);
    color: #faf7f0;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .proj-card__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-top: 16px;
  }
  .proj-card__text {
    min-width: 0;
  }
  .proj-title {
    font-family: var(--font-mono);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.3;
    transition: color 0.2s var(--ease);
  }
  .proj-card:hover .proj-title {
    color: var(--accent);
  }
  .proj-card__blurb {
    margin-top: 4px;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--muted);
  }
  .proj-card__kind {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
</style>
