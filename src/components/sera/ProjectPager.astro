---
import Pager from './Pager.astro';

interface ProjectRef {
  slug: string;
  name: string;
}
interface Props {
  prev?: ProjectRef | null;
  next?: ProjectRef | null;
}
const { prev = null, next = null } = Astro.props;
const prevItem = prev ? { href: `/projects/${prev.slug}`, label: prev.name } : null;
const nextItem = next ? { href: `/projects/${next.slug}`, label: next.name } : null;
---

<Pager
  prev={prevItem}
  next={nextItem}
  prevKicker="Prev project"
  nextKicker="Next project"
/>
