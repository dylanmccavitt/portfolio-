---
/**
 * Player redesign app shell. Implements the prototype grid (`1fr / 84px` rows,
 * `236px / 1fr` columns): the main region scrolls, the body does not, and the
 * sidebar + player bar stay fixed. View content is projected into the `<main>`
 * slot; the redesigned view pages render inside this layout.
 *
 * Dark-only, self-contained shell: it does not extend Base.astro / the Sera
 * theme. Zero client JS — active sidebar state comes from the URL.
 *
 * Ported from the prototype `15-player-v4.html` (shell CSS in `player.css`).
 */
import Sidebar from '../components/player/Sidebar.astro';
import PlayerBar from '../components/player/PlayerBar.astro';
import type { PlaylistId, Project } from '../data/catalog';
import '../styles/player.css';

export interface Props {
  title: string;
  description?: string;
  /** Active sidebar filter (or `'resume'` for the album view). */
  active?: PlaylistId | 'resume';
  /** Override the now-playing project in the bottom bar. */
  now?: Project;
}
const {
  title,
  description = 'Dylan McCavitt — Portfolio',
  active = 'all',
  now,
} = Astro.props;

// Canonical URL for this page (#25) — absolute, origin from `Astro.site`.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content="Dylan McCavitt | Portfolio" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="player-body">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="body">
      <nav class="sidebar-nav" aria-label="Primary">
        <Sidebar active={active} />
      </nav>
      <main class="main" id="main" tabindex="-1">
        <slot />
      </main>
    </div>
    <PlayerBar now={now} />
    <script src="../scripts/player.ts"></script>
  </body>
</html>
