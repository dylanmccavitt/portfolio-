---
/**
 * Player redesign app shell. Implements the prototype grid (`1fr / 84px` rows,
 * `236px / 1fr` columns): the main region scrolls, the body does not, and the
 * sidebar + player bar stay fixed. View content is projected into the `<main>`
 * slot; the redesigned view pages render inside this layout.
 *
 * Dark-only, self-contained shell: it does not extend Base.astro / the Sera
 * theme. Zero client JS — active sidebar state comes from the URL.
 *
 * Ported from the prototype `15-player-v4.html` (shell CSS in `player.css`).
 */
import Sidebar from '../components/player/Sidebar.astro';
import PlayerBar from '../components/player/PlayerBar.astro';
import TabBar from '../components/player/TabBar.astro';
import type { PlaylistId, Project } from '../data/catalog';
import { OG_FALLBACK, type PageMeta } from '../lib/seo';
import '../styles/player.css';

export interface Props {
  title: string;
  description?: string;
  /**
   * Per-page SEO bundle (#29) — drives OG/Twitter tags, `og:type`, the OG
   * image, and optional JSON-LD. Pages pass data-derived meta from `lib/seo`;
   * when omitted, the layout falls back to the site-wide defaults below.
   */
  meta?: PageMeta;
  /**
   * Active sidebar filter, `'resume'` for the album view, or `'home'` for the
   * concierge landing (no sidebar row highlighted).
   */
  active?: PlaylistId | 'resume' | 'home';
  /** Override the now-playing project in the bottom bar. */
  now?: Project;
}
const {
  title,
  description = 'Dylan McCavitt — Portfolio',
  meta,
  active = 'all',
  now,
} = Astro.props;

// Canonical URL for this page (#25) — absolute, origin from `Astro.site`.
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Site-wide meta defaults; `meta` (when passed) overrides each field (#29).
const metaDescription = meta?.description ?? description;
const ogTitle = title;
const ogDescription = meta?.description ?? description;
const ogType = meta?.ogType ?? 'website';
const ogImage = new URL(meta?.ogImage ?? OG_FALLBACK, Astro.site).href;
const jsonLd = meta?.jsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!--
      viewport-fit=cover (#58): without it iOS Safari resolves every
      env(safe-area-inset-*) to 0px, so the bottom tab bar's safe-area padding
      in player.css is a no-op and the bar collides with the home indicator.
      cover lets the shell paint edge-to-edge and the insets report real values.
    -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Dylan McCavitt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="player-body">
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="body">
      <nav class="sidebar-nav" aria-label="Primary">
        <Sidebar active={active} />
      </nav>
      <main class="main" id="main" tabindex="-1">
        <slot />
      </main>
    </div>
    <PlayerBar now={now} />
    <TabBar />
    <script src="../scripts/player.ts"></script>
  </body>
</html>
