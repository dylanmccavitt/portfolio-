---
import Header from '../components/Header.astro';
import PaletteNav from '../components/PaletteNav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  showPaletteNav?: boolean;
}
const {
  title,
  description = 'Dylan McCavitt — Portfolio',
  showPaletteNav = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/screenshots/image-preview.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/screenshots/image-preview.webp" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('portfolio-theme') || 'nord';
        const mode = localStorage.getItem('portfolio-mode') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('data-mode', mode);
      })();
    </script>
  </head>
  <body>
    <Header />
    {showPaletteNav && <PaletteNav />}
    <slot />
    <Footer />
    <script src="../scripts/theme-switcher.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
