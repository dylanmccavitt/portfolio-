---
import Header from '../components/Header.astro';
import PaletteNav from '../components/PaletteNav.astro';
import TopBar from '../components/sera/TopBar.astro';

interface Props {
  title: string;
  description?: string;
  showPaletteNav?: boolean;
  showTopBar?: boolean;
}
const {
  title,
  description = 'Dylan McCavitt — Portfolio',
  showPaletteNav = false,
  showTopBar = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content="Dylan McCavitt | Portfolio" />
    <meta property="og:description" content="Portfolio" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://dylanmccavitt.xyz/screenshots/image-preview.webp" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)"
          ).matches;
          const isDark =
            stored === "dark" || (stored === null && prefersDark);
          if (isDark) document.documentElement.classList.add("dark");
        } catch {
          /* noop — pre-paint theme application is best-effort. */
        }
      })();
    </script>
  </head>
  <body class="paper">
    <div class="site">
      {showTopBar ? <TopBar /> : <Header />}
      {showPaletteNav && <PaletteNav />}
      <slot />
    </div>
    <script src="../scripts/theme-switcher.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  .site {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .site > main {
    flex: 1;
  }
</style>
