---
/**
 * Static route display inside the muted Three.js hardware frame.
 *
 * The slot remains complete semantic HTML; Device adds the optional renderer
 * and the existing route-bound contextual guide without changing its contract.
 */
import Device from '@/layouts/Device.astro';
import type { DMPageContextKind } from '@/lib/dm/guide';
import type { PageMeta } from '@/lib/seo';

export interface Props {
  title: string;
  description?: string;
  meta?: PageMeta;
}

const { title, description, meta } = Astro.props;
const path = Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, '') : '/';
const guide = (() => {
  if (path === '/library' || path.startsWith('/library/')) return { kind: 'library' as const };
  if (path.startsWith('/projects/')) return { kind: 'project' as const, reference: path.split('/').at(-1) };
  if (path === '/journey') return { kind: 'journey' as const };
  if (path.startsWith('/journey/')) return { kind: 'journey' as const, reference: path.split('/').at(-1) };
  return null;
})() satisfies { kind: DMPageContextKind; reference?: string } | null;
---

<Device
  title={title}
  description={description}
  meta={meta}
  surface="route"
  guideKind={guide?.kind}
  guideReference={guide?.reference}
>
  <slot />
</Device>
