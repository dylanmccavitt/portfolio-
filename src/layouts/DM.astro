---
/**
 * DM landing layout (#86) — the full-height shell for the Split-canvas chat
 * surface. It carries the same per-page SEO head the rest of the site uses,
 * then hands the whole viewport to the DM conversation island.
 *
 * Tokens + the `.badge` primitive come from `player.css`; the Split-canvas
 * styling (global, `.dm-`-namespaced so the JS-built thread is styled too)
 * comes from `dm.css`. The chat client (`scripts/dm.ts`) is the one earned
 * client-JS island on the landing.
 */
import { OG_FALLBACK, serializeJsonLd, type PageMeta } from '@/lib/seo';
import '@/styles/player.css';
import '@/styles/dm.css';

export interface Props {
  title: string;
  meta: PageMeta;
}
const { title, meta } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(meta.ogImage ?? OG_FALLBACK, Astro.site).href;
const jsonLd = meta.jsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={meta.description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Dylan McCavitt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={meta.description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={serializeJsonLd(jsonLd)}
        />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="dm-body">
    <slot />
    <script src="../scripts/dm.ts"></script>
  </body>
</html>
