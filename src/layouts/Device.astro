---
import ContextualGuide from '@/components/ContextualGuide.astro';
import type { DMPageContextKind } from '@/lib/dm/guide';
import { OG_FALLBACK, serializeJsonLd, type PageMeta } from '@/lib/seo';
import '@/styles/player.css';
import '@/styles/dm.css';
import '@/styles/device.css';

export interface Props {
  title: string;
  description?: string;
  meta?: PageMeta;
  guideKind?: DMPageContextKind;
  guideReference?: string;
  surface?: 'home' | 'route';
}

const {
  title,
  description = 'Dylan McCavitt · Portfolio',
  meta,
  guideKind,
  guideReference,
  surface = 'route',
} = Astro.props;

const path = Astro.url.pathname.length > 1 ? Astro.url.pathname.replace(/\/$/, '') : '/';
const canonical = new URL(path, Astro.site).href;
const metaDescription = meta?.description ?? description;
const ogImage = new URL(meta?.ogImage ?? OG_FALLBACK, Astro.site).href;
---

<!doctype html>
<html lang="en" data-webgl="pending">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={meta?.ogType ?? 'website'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Dylan McCavitt" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    {meta?.jsonLd && <script is:inline type="application/ld+json" set:html={serializeJsonLd(meta.jsonLd)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body class:list={['device-body', `device-body--${surface}`]}>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="device-stage" data-device-stage data-device-surface={surface}>
      <canvas class="device-canvas" data-device-canvas aria-hidden="true"></canvas>
      <p class="device-status" data-device-status aria-live="polite">
        {guideKind
          ? 'Device status: portfolio ready; contextual guide available.'
          : 'Device status: portfolio ready.'}
      </p>
      <main id="main" class:list={['device-content', `device-content--${surface}`]} tabindex="-1">
        <slot />
      </main>
      {
        guideKind && (
          <ContextualGuide
            kind={guideKind}
            path={path}
            reference={guideReference}
          />
        )
      }
    </div>
    <script src="../scripts/device.ts"></script>
    {guideKind && <script src="../scripts/dm.ts"></script>}
  </body>
</html>
