{
  "name": "dylan-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "test:db": "node --import tsx --test tests/db-foundation.test.ts",
    "test:discovery": "node --import tsx --test tests/github-discovery.test.ts",
    "test:slack": "node --import tsx --test tests/slack-control-plane.test.ts",
    "test:admin": "node --import tsx --test tests/admin-auth.test.ts tests/admin-publish.test.ts tests/admin-readiness.test.ts && node --import tsx --test tests/admin-rag-sources.test.ts",
    "test:release": "node --import tsx --test tests/release-gates.test.ts",
    "test:dm": "node --import tsx --test tests/dm-runtime.test.ts tests/dm-streaming.test.ts tests/dm-contextual-guide.test.ts tests/dm-public-agent-tools.test.ts tests/dm-site-brief.test.ts && npm run test:dm-boundary",
    "test:dm-boundary": "node --test tests/public-dm-tool-boundary.test.mjs && npm run build && node scripts/check-public-dm-tool-boundary.mjs",
    "test:dm-tools": "node --import tsx --test tests/dm-public-agent-tools.test.ts tests/dm-site-brief.test.ts",
    "test:metrics": "node --import tsx --test tests/dm-metrics.test.ts",
    "test:rag": "node --import tsx --test tests/rag-ingestion.test.ts tests/rag-retrieval.test.ts",
    "test:outbox": "node --import tsx --test tests/outbox-worker.test.ts",
    "test:proof": "node --import tsx --test tests/publish-proof.test.ts",
    "test:visual": "node --import tsx --test tests/device-visual-system.test.ts",
    "test:quality": "node --import tsx --test tests/replacement-quality-proof.test.ts",
    "proof:quality": "tsx scripts/replacement-quality-proof.ts",
    "package:quality": "tsx scripts/build-replacement-quality-artifact.ts",
    "typecheck": "astro check",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "db:migrate": "tsx scripts/db.ts migrate",
    "db:seed": "tsx scripts/db.ts seed",
    "db:reset": "tsx scripts/db.ts reset",
    "db:published-media:preflight": "tsx scripts/published-media-preflight.ts",
    "db:catalog:shadow": "tsx scripts/catalog-shadow.ts import-and-report",
    "db:catalog:parity": "tsx scripts/catalog-shadow.ts report",
    "db:catalog:cutover": "tsx scripts/catalog-shadow.ts cutover",
    "db:github:scan": "tsx scripts/github-discovery.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/vercel": "^11.0.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^7.0.2",
    "astro": "^7.0.3",
    "openai": "^6.45.0",
    "three": "^0.185.1",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "@types/three": "^0.185.1",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "path-to-regexp": "6.3.0",
    "yaml": "2.8.3"
  }
}
