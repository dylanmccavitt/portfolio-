{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; manifest-src 'self'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/projects/epl-ml-model", "destination": "/projects/epl-ml", "permanent": true },
    { "source": "/library/trading-systems", "destination": "/library/side-projects-experiments", "permanent": true },
    { "source": "/library/agents-mcp", "destination": "/library/ai-developer-tools", "permanent": true },
    { "source": "/library/ios", "destination": "/library/apps", "permanent": true },
    { "source": "/library/shipped", "destination": "/library/shipped-client-work", "permanent": true },
    { "source": "/library/school", "destination": "/library/coursework", "permanent": true },
    { "source": "/library/infrastructure", "destination": "/library/side-projects-experiments", "permanent": true },
    { "source": "/library/research", "destination": "/library/side-projects-experiments", "permanent": true },
    { "source": "/experience", "destination": "/journey", "permanent": true },
    { "source": "/resume", "destination": "/journey", "permanent": true },
    { "source": "/about", "destination": "/journey/now", "permanent": true },
    { "source": "/contact", "destination": "/journey/now", "permanent": true },
    { "source": "/log", "destination": "/library", "permanent": true },
    { "source": "/log/:slug", "destination": "/library", "permanent": true },
    { "source": "/homelab/topology", "destination": "/projects/homeserver", "permanent": true },
    { "source": "/player", "destination": "/", "permanent": true },
    { "source": "/projects", "destination": "/library", "permanent": true }
  ]
}
